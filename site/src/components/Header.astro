---
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/inventory', label: 'Inventory' },
  { href: '/financing', label: 'Financing' },
  { href: '/about', label: 'About' },
  { href: '/testimonials', label: 'Reviews' },
  { href: '/faq', label: 'FAQ' },
  { href: '/contact', label: 'Contact' },
];
---

<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="flex justify-between items-center w-full px-6 lg:px-8 py-4 max-w-7xl mx-auto">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0">
      <img src="/brand/logo-header.png" alt="Maxim Autos" class="h-10 md:h-12 w-auto" />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium transition-colors duration-200',
            currentPath.startsWith(link.href)
              ? 'text-navy border-b-2 border-orange pb-1'
              : 'text-gray-500 hover:text-navy',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA + Mobile Toggle -->
    <div class="flex items-center gap-3">
      <a
        href="sms:8475108947&body=Hi Jerry, I'm interested in a vehicle at Maxim Autos."
        class="hidden sm:inline-flex items-center gap-2 bg-orange text-white px-5 py-2.5 rounded-lg font-bold text-sm hover:bg-orange-dark transition-colors"
      >
        <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">sms</span>
        Text Jerry
      </a>
      <a
        href="tel:8475108947"
        class="hidden sm:inline-flex items-center gap-2 bg-navy text-white px-5 py-2.5 rounded-lg font-bold text-sm hover:bg-navy-light transition-colors"
      >
        <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">call</span>
        (847) 510-8947
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-gray-600 hover:text-navy"
        aria-label="Toggle menu"
      >
        <span class="material-symbols-outlined text-3xl">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 pb-4">
    <div class="px-6 py-2 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'block py-3 px-4 rounded-lg text-sm font-medium',
            currentPath.startsWith(link.href)
              ? 'bg-navy/5 text-navy'
              : 'text-gray-600 hover:bg-gray-50',
          ]}
        >
          {link.label}
        </a>
      ))}
      <div class="flex gap-2 pt-3">
        <a
          href="sms:8475108947&body=Hi Jerry, I'm interested in a vehicle at Maxim Autos."
          class="flex-1 flex items-center justify-center gap-2 bg-orange text-white py-3 rounded-lg font-bold text-sm"
        >
          <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">sms</span>
          Text Jerry
        </a>
        <a
          href="tel:8475108947"
          class="flex-1 flex items-center justify-center gap-2 bg-navy text-white py-3 rounded-lg font-bold text-sm"
        >
          <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">call</span>
          Call
        </a>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
