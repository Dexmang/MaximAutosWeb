---
interface Props {
  slug: string;
  year: number;
  make: string;
  model: string;
  trim: string;
  price: number;
  mileage: number;
  drivetrain: string;
  engine: string;
  bodyStyle: string;
  photoPath: string;
  photoPrefix: string;
  inspected: boolean;
  primaryPhotoUrl?: string;
  photos?: { exterior: number; interior: number; source: string };
  dealRating?: string;
  priceSavings?: number;
}

const DEAL_BADGE: Record<string, { label: string; bg: string; text: string }> = {
  GREAT_PRICE: { label: 'Great Deal', bg: '#1a9b3b', text: '#fff' },
  GOOD_PRICE:  { label: 'Good Deal',  bg: '#2ecc71', text: '#fff' },
  FAIR_PRICE:  { label: 'Fair Deal',  bg: '#3498db', text: '#fff' },
};

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { slug, year, make, model, trim, price, mileage, drivetrain, engine, bodyStyle, photoPath, photoPrefix, inspected, primaryPhotoUrl, photos, dealRating, priceSavings } = Astro.props;
const dealBadge = dealRating ? (DEAL_BADGE[dealRating] || null) : null;
const savingsStr = (priceSavings && priceSavings > 0) ? `$${priceSavings.toLocaleString()} below` : '';
const title = `${year} ${make} ${model}`;

// Use CDN URL if available, fall back to local path, or null if no valid source
const localThumb = photoPath ? `${base}/${photoPath}/thumb/${photoPrefix}-photo-exterior-maxim-autos-skokie-il-01.jpg` : null;
const photoSrc = primaryPhotoUrl || localThumb;

// Payment estimate: 10% down, 9.9% APR, 60 months
const downPayment = Math.round(price * 0.10);
const principal = price - downPayment;
const monthlyRate = 0.099 / 12;
const numPayments = 60;
const monthlyPayment = Math.round(
  principal * (monthlyRate * Math.pow(1 + monthlyRate, numPayments)) /
  (Math.pow(1 + monthlyRate, numPayments) - 1)
);
---

<div class="vehicle-card group relative bg-white overflow-hidden rounded-xl shadow-sm hover:shadow-lg transition-all duration-300" data-price={price} data-body={bodyStyle} data-mileage={mileage} data-year={year}>
  <!-- Stretched link covers the full card; financing link sits above it via z-index -->
  <a href={`${base}/vehicle/${slug}`} class="absolute inset-0 z-10" aria-label={`View ${title}`}></a>

  <div class="relative h-48 overflow-hidden bg-gray-100">
    {photoSrc ? (
      <img
        src={photoSrc}
        alt={`${title} for sale at Maxim Autos Skokie IL`}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        width="1024"
        height="768"
      />
    ) : (
      <div class="w-full h-full flex flex-col items-center justify-center bg-gray-100 text-gray-400 gap-2">
        <span class="material-symbols-outlined text-4xl">no_photography</span>
        <span class="text-xs font-medium">Photos coming soon</span>
      </div>
    )}
    {inspected && (
      <div class="absolute top-2 right-2 bg-navy text-white text-xs font-bold px-2.5 py-1 rounded-md flex items-center gap-1">
        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">verified</span>
        FULLY INSPECTED
      </div>
    )}
  </div>
  <div class="px-3 py-4 sm:px-4">
    <h3 class="font-headline text-base font-bold text-gray-900 mb-0.5">{title}</h3>
    <p class="text-xs text-gray-500 mb-3">{trim} &bull; {engine} &bull; {drivetrain}</p>

    <!-- Price + Payment -->
    <div class="flex flex-wrap justify-between items-end mb-3 gap-y-1">
      <div>
        <span class="text-xl font-extrabold text-navy">${price.toLocaleString()}</span>
        {dealBadge && (
          <div class="flex items-center gap-1 mt-1">
            <!-- CarGurus-style price-tag badge with left arrow notch -->
            <span class="inline-flex items-center gap-1 text-xs font-bold px-2 py-0.5 rounded"
              style={`background:${dealBadge.bg};color:${dealBadge.text}`}>
              {dealBadge.label}{savingsStr ? ` · ${savingsStr}` : ''}
            </span>
            <span class="text-[9px] text-gray-400 font-medium leading-none">CarGurus</span>
          </div>
        )}
        <div class="flex items-center gap-1 mt-0.5">
          <span class="text-xs font-bold text-navy">${monthlyPayment}/mo est.</span>
          <span class="text-xs text-gray-400 font-normal">*</span>
        </div>
      </div>
      <span class="text-sm text-gray-500">{mileage.toLocaleString()} mi</span>
    </div>

    <div class="flex flex-wrap gap-1.5">
      <span class="inline-flex items-center gap-1 text-xs bg-gray-100 text-gray-500 px-2 py-1 rounded-full font-medium">
        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">search</span>
        Inspected
      </span>
      <span class="inline-flex items-center gap-1 text-xs bg-gray-100 text-gray-500 px-2 py-1 rounded-full font-medium">
        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">description</span>
        Free CARFAX
      </span>
      <a href={`${base}/financing`} class="relative z-20 inline-flex items-center gap-1 text-xs bg-orange/10 text-orange px-2 py-1 rounded-full font-medium">
        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">payments</span>
        Financing
      </a>
    </div>
  </div>
</div>
