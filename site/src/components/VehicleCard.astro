---
interface Props {
  slug: string;
  year: number;
  make: string;
  model: string;
  trim: string;
  price: number;
  mileage: number;
  drivetrain: string;
  engine: string;
  bodyStyle: string;
  photoPath: string;
  photoPrefix: string;
  inspected: boolean;
  primaryPhotoUrl?: string;
  photos?: { exterior: number; interior: number; source: string };
  stockNumber?: string;
  dateAdded?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { slug, year, make, model, trim, price, mileage, drivetrain, engine, bodyStyle, photoPath, photoPrefix, inspected, primaryPhotoUrl, photos, stockNumber, dateAdded } = Astro.props;
const title = `${year} ${make} ${model}`;

// "Just Listed" badge if vehicle added within last 7 days
function daysSince(dateStr?: string): number | null {
  if (!dateStr) return null;
  const d = new Date(dateStr);
  if (Number.isNaN(d.getTime())) return null;
  return Math.floor((Date.now() - d.getTime()) / (1000 * 60 * 60 * 24));
}
const daysOnLot = daysSince(dateAdded);
const isJustListed = daysOnLot !== null && daysOnLot <= 7;

// Use CDN URL if available, fall back to local path, or null if no valid source
const localThumb = photoPath ? `${base}/${photoPath}/thumb/${photoPrefix}-photo-exterior-maxim-autos-skokie-il-01.jpg` : null;
const photoSrc = primaryPhotoUrl || localThumb;

// Payment estimate: 10% down, 9.9% APR, 60 months
const downPayment = Math.round(price * 0.10);
const principal = price - downPayment;
const monthlyRate = 0.099 / 12;
const numPayments = 60;
const monthlyPayment = Math.round(
  principal * (monthlyRate * Math.pow(1 + monthlyRate, numPayments)) /
  (Math.pow(1 + monthlyRate, numPayments) - 1)
);
---

<a href={`${base}/vehicle/${slug}`} class="vehicle-card group block bg-white overflow-hidden rounded-xl shadow-sm hover:shadow-lg transition-all duration-300" data-price={price} data-body={bodyStyle} data-mileage={mileage} data-year={year}>
  <div class="relative h-48 overflow-hidden bg-gray-100">
    {photoSrc ? (
      <img
        src={photoSrc}
        alt={`${title} for sale at Maxim Autos Skokie IL`}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex flex-col items-center justify-center bg-gray-100 text-gray-400 gap-2">
        <span class="material-symbols-outlined text-4xl">no_photography</span>
        <span class="text-xs font-medium">Photos coming soon</span>
      </div>
    )}
    {inspected && (
      <div class="absolute top-2 left-2 bg-navy text-white text-xs font-bold px-2.5 py-1 rounded-md flex items-center gap-1">
        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">verified</span>
        FULLY INSPECTED
      </div>
    )}
    {isJustListed && (
      <div class="absolute top-2 right-2 bg-orange text-white text-xs font-bold px-2.5 py-1 rounded-md flex items-center gap-1">
        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">new_releases</span>
        JUST LISTED
      </div>
    )}
  </div>
  <div class="px-3 py-4 sm:px-4">
    <div class="flex items-start justify-between gap-2 mb-0.5">
      <h3 class="font-headline text-base font-bold text-gray-900">{title}</h3>
      {stockNumber && (
        <span class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider shrink-0 mt-1">Stock #{stockNumber}</span>
      )}
    </div>
    <p class="text-xs text-gray-500 mb-3">{trim} &bull; {engine} &bull; {drivetrain}</p>

    <!-- Price + Payment -->
    <div class="flex flex-wrap justify-between items-end mb-1 gap-y-1">
      <div>
        <span class="text-xl font-extrabold text-navy">${price.toLocaleString()}</span>
        <div class="flex items-center gap-1 mt-0.5">
          <span class="text-xs font-bold text-navy">${monthlyPayment}/mo est.*</span>
        </div>
      </div>
      <span class="text-sm text-gray-500">{mileage.toLocaleString()} mi</span>
    </div>
    <!-- Reg Z compliance: APR + down payment + term adjacent to trigger term -->
    <p class="text-[10px] text-gray-400 leading-tight mb-3">* Est. 9.9% APR, 10% down, 60 mo. Actual terms vary by credit. <a href={`${base}/financing`} class="underline hover:text-orange">See disclosures</a>.</p>

    <div class="flex flex-wrap gap-1.5">
      <span class="inline-flex items-center gap-1 text-xs bg-green-50 text-green-700 px-2 py-1 rounded-full font-medium">
        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">search</span>
        Inspected
      </span>
      <span class="inline-flex items-center gap-1 text-xs bg-blue-50 text-blue-700 px-2 py-1 rounded-full font-medium">
        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">description</span>
        Free CARFAX
      </span>
      <span class="inline-flex items-center gap-1 text-xs bg-orange/10 text-orange px-2 py-1 rounded-full font-medium">
        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">payments</span>
        Financing
      </span>
    </div>
  </div>
</a>
