---
interface Props {
  slug: string;
  year: number;
  make: string;
  model: string;
  trim: string;
  price: number;
  mileage: number;
  drivetrain: string;
  engine: string;
  bodyStyle: string;
  photoPath: string;
  photoPrefix: string;
  certified: boolean;
}

const { slug, year, make, model, trim, price, mileage, drivetrain, engine, bodyStyle, photoPath, photoPrefix, certified } = Astro.props;
const title = `${year} ${make} ${model}`;
const photoSrc = `/${photoPath}/thumb/${photoPrefix}-photo-exterior-maxim-autos-skokie-il-01.jpg`;
---

<a href={`/vehicle/${slug}`} class="vehicle-card group block bg-white overflow-hidden rounded-xl shadow-sm hover:shadow-lg transition-all duration-300" data-price={price} data-body={bodyStyle} data-mileage={mileage} data-year={year}>
  <div class="relative h-56 overflow-hidden bg-gray-100">
    <img
      src={photoSrc}
      alt={`${title} for sale at Maxim Autos Skokie IL`}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    {certified && (
      <div class="absolute top-3 left-3 bg-navy text-white text-xs font-bold px-3 py-1.5 rounded-md flex items-center gap-1">
        <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">verified</span>
        MAXIM SELECT
      </div>
    )}
  </div>
  <div class="p-5">
    <h3 class="font-headline text-lg font-bold text-gray-900 mb-1">{title}</h3>
    <p class="text-sm text-gray-500 mb-3">{trim} &bull; {engine} &bull; {drivetrain}</p>
    <div class="flex justify-between items-center mb-4">
      <span class="text-2xl font-extrabold text-navy">${price.toLocaleString()}</span>
      <span class="text-sm text-gray-500">{mileage.toLocaleString()} mi</span>
    </div>
    <div class="flex gap-2">
      <span class="inline-flex items-center gap-1 text-xs bg-green-50 text-green-700 px-2.5 py-1 rounded-full font-medium">
        <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">shield</span>
        3-Mo Warranty
      </span>
      <span class="inline-flex items-center gap-1 text-xs bg-blue-50 text-blue-700 px-2.5 py-1 rounded-full font-medium">
        <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">description</span>
        Free CARFAX
      </span>
    </div>
  </div>
</a>
