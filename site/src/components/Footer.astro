---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-950 text-gray-400">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-12 w-full px-6 lg:px-8 py-16 max-w-7xl mx-auto">
    <!-- Brand & Contact -->
    <div>
      <img src="/brand/logo-header.png" alt="Maxim Autos" class="h-10 mb-6 brightness-0 invert" />
      <p class="text-sm mb-6 leading-relaxed">
        Quality used cars in Skokie, IL. Every vehicle inspected, every price transparent, every customer protected.
      </p>
      <div class="space-y-3 text-sm">
        <p class="flex items-start gap-3">
          <span class="material-symbols-outlined text-orange text-xl" style="font-variation-settings: 'FILL' 1;">location_on</span>
          Skokie, IL 60077
        </p>
        <a href="tel:8475108947" class="flex items-center gap-3 hover:text-white transition-colors">
          <span class="material-symbols-outlined text-orange text-xl" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947
        </a>
        <a href="mailto:jerryf@maximautos.com" class="flex items-center gap-3 hover:text-white transition-colors">
          <span class="material-symbols-outlined text-orange text-xl" style="font-variation-settings: 'FILL' 1;">mail</span>
          jerryf@maximautos.com
        </a>
      </div>
    </div>

    <!-- Hours -->
    <div>
      <h3 class="text-orange font-bold mb-6 font-headline text-sm uppercase tracking-widest">Business Hours</h3>
      <div class="space-y-3 text-sm">
        <div class="flex justify-between border-b border-white/5 pb-2">
          <span>Mon / Tue / Thu / Fri</span>
          <span class="text-white">3:00 PM – 7:00 PM</span>
        </div>
        <div class="flex justify-between border-b border-white/5 pb-2">
          <span>Saturday</span>
          <span class="text-white">10:00 AM – 3:00 PM</span>
        </div>
        <div class="flex justify-between border-b border-white/5 pb-2">
          <span>Wednesday / Sunday</span>
          <span class="text-white font-medium">Closed</span>
        </div>
        <p class="mt-6 text-orange font-semibold italic text-sm">
          After-hours appointments welcome — text Jerry at (847) 510-8947
        </p>
      </div>
    </div>

    <!-- Quick Links -->
    <div>
      <h3 class="text-orange font-bold mb-6 font-headline text-sm uppercase tracking-widest">Quick Links</h3>
      <ul class="space-y-3 text-sm">
        <li><a class="hover:text-white transition-colors" href="/inventory">Browse Inventory</a></li>
        <li><a class="hover:text-white transition-colors" href="/financing">Financing</a></li>
        <li><a class="hover:text-white transition-colors" href="/sell-trade">Sell / Trade</a></li>
        <li><a class="hover:text-white transition-colors" href="/about">About Jerry</a></li>
        <li><a class="hover:text-white transition-colors" href="/testimonials">Reviews</a></li>
        <li><a class="hover:text-white transition-colors" href="/faq">FAQ</a></li>
        <li><a class="hover:text-white transition-colors" href="/contact">Contact</a></li>
      </ul>
    </div>
  </div>

  <div class="px-6 lg:px-8 py-6 border-t border-white/5 max-w-7xl mx-auto text-xs flex flex-col sm:flex-row justify-between items-center gap-2 opacity-60">
    <span>&copy; {currentYear} Maxim Autos. Skokie, IL. All rights reserved.</span>
    <span>Maxim Select Certified &bull; Used Cars Skokie IL</span>
  </div>
</footer>

<!-- Sticky Mobile CTA -->
<div class="fixed bottom-0 left-0 right-0 z-50 bg-navy p-3 flex gap-2 sm:hidden">
  <a
    href="sms:8475108947&body=Hi Jerry, I'm interested in a vehicle at Maxim Autos."
    class="flex-1 flex items-center justify-center gap-2 bg-orange text-white py-3 rounded-lg font-bold text-sm"
  >
    <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">sms</span>
    Text Jerry
  </a>
  <a
    href="tel:8475108947"
    class="flex-1 flex items-center justify-center gap-2 bg-white text-navy py-3 rounded-lg font-bold text-sm"
  >
    <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">call</span>
    Call Now
  </a>
</div>
