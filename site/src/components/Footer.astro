---
import suburbs from '../data/suburbs.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-950 text-gray-400">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 w-full px-6 lg:px-8 py-16 max-w-7xl mx-auto">
    <!-- Brand & Contact -->
    <div>
      <img src={`${base}/brand/logo-header.png`} alt="Maxim Autos" class="h-10 mb-6 brightness-0 invert" />
      <p class="text-sm mb-6 leading-relaxed">
        Quality used cars in Skokie, IL. Every vehicle inspected, every price transparent, every customer protected.
      </p>
      <div class="space-y-3 text-sm">
        <p class="flex items-start gap-3">
          <span class="material-symbols-outlined text-orange text-xl" style="font-variation-settings: 'FILL' 1;">location_on</span>
          Skokie, IL 60077
        </p>
        <a href="tel:8475108947" class="flex items-center gap-3 hover:text-white transition-colors">
          <span class="material-symbols-outlined text-orange text-xl" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947
        </a>
        <a href="mailto:jerryf@maximautos.com" class="flex items-center gap-3 hover:text-white transition-colors">
          <span class="material-symbols-outlined text-orange text-xl" style="font-variation-settings: 'FILL' 1;">mail</span>
          jerryf@maximautos.com
        </a>
      </div>
    </div>

    <!-- Hours -->
    <div>
      <h3 class="text-white/70 font-bold mb-6 font-headline text-sm uppercase tracking-widest">Business Hours</h3>
      <div class="space-y-3 text-sm">
        <div class="flex justify-between border-b border-white/5 pb-2">
          <span>Mon / Tue / Thu / Fri</span>
          <span class="text-white">3:00 PM – 7:00 PM</span>
        </div>
        <div class="flex justify-between border-b border-white/5 pb-2">
          <span>Saturday</span>
          <span class="text-white">10:00 AM – 3:00 PM</span>
        </div>
        <div class="flex justify-between border-b border-white/5 pb-2">
          <span>Wednesday / Sunday</span>
          <span class="text-white font-medium">Closed</span>
        </div>
        <p class="mt-6 text-white/60 font-semibold italic text-sm">
          After-hours appointments welcome. Text Jerry at (847) 510-8947
        </p>
      </div>
    </div>

    <!-- Quick Links -->
    <div>
      <h3 class="text-white/70 font-bold mb-6 font-headline text-sm uppercase tracking-widest">Quick Links</h3>
      <ul class="space-y-3 text-sm">
        <li><a class="hover:text-white transition-colors" href={`${base}/inventory`}>Browse Inventory</a></li>
        <li><a class="hover:text-white transition-colors" href={`${base}/financing`}>Financing</a></li>
        <li><a class="hover:text-white transition-colors" href={`${base}/sell-trade`}>Sell / Trade</a></li>
        <li><a class="hover:text-white transition-colors" href={`${base}/ship`}>Delivered Anywhere in the U.S.</a></li>
        <li><a class="hover:text-white transition-colors" href={`${base}/about`}>About Jerry</a></li>
        <li><a class="hover:text-white transition-colors" href={`${base}/testimonials`}>Reviews</a></li>
        <li><a class="hover:text-white transition-colors" href={`${base}/faq`}>FAQ</a></li>
        <li><a class="hover:text-white transition-colors" href={`${base}/contact`}>Contact</a></li>
      </ul>
    </div>

    <!-- Areas We Serve -->
    <div>
      <h3 class="text-white/70 font-bold mb-6 font-headline text-sm uppercase tracking-widest">Areas We Serve</h3>
      <ul class="space-y-3 text-sm">
        {suburbs.map(s => (
          <li>
            <a class="hover:text-white transition-colors" href={`${base}/used-cars-${s.slug}-il`}>
              {s.city} Used Cars
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="px-6 lg:px-8 py-6 border-t border-white/5 max-w-7xl mx-auto text-xs flex flex-col sm:flex-row justify-between items-center gap-2 opacity-60">
    <span>
      &copy; {currentYear} Maxim Autos. Skokie, IL. All rights reserved.
      &nbsp;&middot;&nbsp;
      <a href={`${base}/privacy-policy`} class="hover:text-white transition-colors">Privacy Policy</a>
      &nbsp;&middot;&nbsp;
      <a href={`${base}/terms`} class="hover:text-white transition-colors">Terms of Use</a>
      &nbsp;&middot;&nbsp;
      <a href="https://vault007.com" rel="nofollow noopener" target="_blank" class="hover:text-white transition-colors">Private Client</a>
    </span>
    <span>Fully Inspected &bull; Used Cars Skokie IL</span>
  </div>
</footer>

<!-- Sticky Mobile CTA — 3-button bar consistent across all pages -->
<div id="footer-sticky-cta" class="fixed bottom-0 left-0 right-0 z-40 md:hidden bg-white border-t border-gray-200 shadow-[0_-4px_12px_rgba(0,0,0,0.08)]">
  <div class="flex">
    <a href="sms:8475108947&body=Hi Jerry, I'm interested in a vehicle at Maxim Autos." class="flex-1 flex flex-col items-center justify-center py-3 gap-0.5 text-navy hover:bg-gray-50 transition-colors">
      <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1;">sms</span>
      <span class="text-xs font-bold">Text Jerry</span>
    </a>
    <a href="tel:8475108947" class="flex-1 flex flex-col items-center justify-center py-3 gap-0.5 text-navy hover:bg-gray-50 transition-colors border-x border-gray-200">
      <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1;">call</span>
      <span class="text-xs font-bold">Call</span>
    </a>
    <a href={`${base}/apply`} class="flex-1 flex flex-col items-center justify-center py-3 gap-0.5 bg-orange text-white hover:bg-orange-dark transition-colors">
      <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1;">payments</span>
      <span class="text-xs font-bold">Pre-Qualify</span>
    </a>
  </div>
</div>
<div id="footer-sticky-spacer" class="h-16 md:hidden"></div>
