---
import suburbs from '../data/suburbs.json';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const isSpanish = lang === 'es';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentYear = new Date().getFullYear();

const invHref      = isSpanish ? `${base}/es/inventario`            : `${base}/inventory`;
const finHref      = isSpanish ? `${base}/es/financiamiento`        : `${base}/financing`;
const applyHref    = isSpanish ? `${base}/es/aplicacion-de-credito` : `${base}/apply`;
const sellHref     = isSpanish ? `${base}/es/vender-intercambiar`   : `${base}/sell-trade`;
const shipHref     = isSpanish ? `${base}/es/compra-en-linea`       : `${base}/ship`;
const aboutHref    = isSpanish ? `${base}/es/sobre-nosotros`        : `${base}/about`;
const contactHref  = isSpanish ? `${base}/es/contacto`              : `${base}/contact`;
// English-only fallback (no Spanish equivalents per scope)
const reviewsHref      = `${base}/testimonials`;
const faqHref          = `${base}/faq`;
const privacyHref      = `${base}/privacy-policy`;
const termsHref        = `${base}/terms`;
const returnPolicyHref = `${base}/return-policy`;

const labels = isSpanish
  ? {
      tagline:           'Autos usados de calidad en Skokie, IL. Cada vehiculo inspeccionado, cada precio transparente, cada cliente protegido.',
      hours:             'Horario',
      days1:             'Lun / Mar / Jue / Vie',
      time1:             '3:00 PM â€“ 7:00 PM',
      days2:             'Sabado',
      time2:             '10:00 AM â€“ 3:00 PM',
      days3:             'Miercoles / Domingo',
      closed:            'Cerrado',
      afterHours:        'Citas fuera de horario bienvenidas. Escribe a Jerry al (847) 510-8947',
      quickLinks:        'Enlaces',
      browseInventory:   'Ver Inventario',
      financing:         'Financiamiento',
      sellTrade:         'Vender / Cambiar',
      deliveredAnywhere: 'Entrega en Todo EE.UU.',
      about:             'Sobre Jerry',
      reviews:           'Resenas',
      faq:               'Preguntas',
      contact:           'Contacto',
      areasServed:       'Areas que Servimos',
      usedCars:          'Autos Usados',
      allRightsReserved: 'Todos los derechos reservados.',
      privacy:           'Politica de Privacidad',
      terms:             'Terminos de Uso',
      returnPolicy:      'Politica de Devolucion',
      privateClient:     'Cliente Privado',
      taglineShort:      'Totalmente Inspeccionados â€¢ Autos Usados Skokie IL',
      mobileText:        'Escribe',
      mobileCall:        'Llamar',
      mobileDirections:  'Direcciones',
      mobileFinancing:   'Financiamiento',
    }
  : {
      tagline:           'Quality used cars in Skokie, IL. Every vehicle inspected, every price transparent, every customer protected.',
      hours:             'Business Hours',
      days1:             'Mon / Tue / Thu / Fri',
      time1:             '3:00 PM â€“ 7:00 PM',
      days2:             'Saturday',
      time2:             '10:00 AM â€“ 3:00 PM',
      days3:             'Wednesday / Sunday',
      closed:            'Closed',
      afterHours:        'After-hours appointments welcome. Text Jerry at (847) 510-8947',
      quickLinks:        'Quick Links',
      browseInventory:   'Browse Inventory',
      financing:         'Financing',
      sellTrade:         'Sell / Trade',
      deliveredAnywhere: 'Delivered Anywhere in the U.S.',
      about:             'About Jerry',
      reviews:           'Reviews',
      faq:               'FAQ',
      contact:           'Contact',
      areasServed:       'Areas We Serve',
      usedCars:          'Used Cars',
      allRightsReserved: 'All rights reserved.',
      privacy:           'Privacy Policy',
      terms:             'Terms of Use',
      returnPolicy:      'Return Policy',
      privateClient:     'Private Client',
      taglineShort:      'Fully Inspected â€¢ Used Cars Skokie IL',
      mobileText:        'Text Jerry',
      mobileCall:        'Call',
      mobileDirections:  'Directions',
      mobileFinancing:   'Financing',
    };
---

<footer class="bg-gray-950 text-gray-400">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 w-full px-6 lg:px-8 py-16 max-w-7xl mx-auto">
    <!-- Brand & Contact -->
    <div>
      <img src={`${base}/brand/logo-header.png`} alt="Maxim Autos" class="h-10 mb-6 brightness-0 invert" />
      <p class="text-sm mb-6 leading-relaxed">{labels.tagline}</p>
      <div class="space-y-3 text-sm">
        <p class="flex items-start gap-3">
          <span class="material-symbols-outlined text-orange text-xl" style="font-variation-settings: 'FILL' 1;">location_on</span>
          Skokie, IL 60077
        </p>
        <a href="tel:8475108947" class="flex items-center gap-3 hover:text-white transition-colors">
          <span class="material-symbols-outlined text-orange text-xl" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947
        </a>
        <a href="mailto:jfranco@maximautos.com" class="flex items-center gap-3 hover:text-white transition-colors">
          <span class="material-symbols-outlined text-orange text-xl" style="font-variation-settings: 'FILL' 1;">mail</span>
          jfranco@maximautos.com
        </a>
      </div>
    </div>

    <!-- Hours -->
    <div>
      <h3 class="text-white/70 font-bold mb-6 font-headline text-sm uppercase tracking-widest">{labels.hours}</h3>
      <div class="space-y-3 text-sm">
        <div class="flex justify-between border-b border-white/5 pb-2">
          <span>{labels.days1}</span>
          <span class="text-white">{labels.time1}</span>
        </div>
        <div class="flex justify-between border-b border-white/5 pb-2">
          <span>{labels.days2}</span>
          <span class="text-white">{labels.time2}</span>
        </div>
        <div class="flex justify-between border-b border-white/5 pb-2">
          <span>{labels.days3}</span>
          <span class="text-white font-medium">{labels.closed}</span>
        </div>
        <p class="mt-6 text-white/60 font-semibold italic text-sm">{labels.afterHours}</p>
      </div>
    </div>

    <!-- Quick Links -->
    <div>
      <h3 class="text-white/70 font-bold mb-6 font-headline text-sm uppercase tracking-widest">{labels.quickLinks}</h3>
      <ul class="space-y-3 text-sm">
        <li><a class="hover:text-white transition-colors" href={invHref}>{labels.browseInventory}</a></li>
        <li><a class="hover:text-white transition-colors" href={finHref}>{labels.financing}</a></li>
        <li><a class="hover:text-white transition-colors" href={sellHref}>{labels.sellTrade}</a></li>
        <li><a class="hover:text-white transition-colors" href={shipHref}>{labels.deliveredAnywhere}</a></li>
        <li><a class="hover:text-white transition-colors" href={aboutHref}>{labels.about}</a></li>
        <li><a class="hover:text-white transition-colors" href={reviewsHref}>{labels.reviews}</a></li>
        <li><a class="hover:text-white transition-colors" href={faqHref}>{labels.faq}</a></li>
        <li><a class="hover:text-white transition-colors" href={contactHref}>{labels.contact}</a></li>
      </ul>
    </div>

    <!-- Areas We Serve -->
    <div>
      <h3 class="text-white/70 font-bold mb-6 font-headline text-sm uppercase tracking-widest">{labels.areasServed}</h3>
      <ul class="space-y-3 text-sm">
        {suburbs.map(s => (
          <li>
            <a class="hover:text-white transition-colors" href={`${base}/used-cars-${s.slug}-il`}>
              {s.city} {labels.usedCars}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="px-6 lg:px-8 py-6 border-t border-white/5 max-w-7xl mx-auto text-xs flex flex-col sm:flex-row justify-between items-center gap-2 opacity-60">
    <span>
      &copy; {currentYear} Maxim Autos. Skokie, IL. {labels.allRightsReserved}
      &nbsp;&middot;&nbsp;
      <a href={privacyHref} class="hover:text-white transition-colors">{labels.privacy}</a>
      &nbsp;&middot;&nbsp;
      <a href={termsHref} class="hover:text-white transition-colors">{labels.terms}</a>
      &nbsp;&middot;&nbsp;
      <a href={returnPolicyHref} class="hover:text-white transition-colors">{labels.returnPolicy}</a>
      &nbsp;&middot;&nbsp;
      <a href="https://vault007.com" rel="nofollow noopener" target="_blank" class="hover:text-white transition-colors">{labels.privateClient}</a>
    </span>
    <span>{labels.taglineShort}</span>
  </div>
</footer>

<!-- Sticky Mobile CTA â€” 3-button bar consistent across all pages -->
<div id="footer-sticky-cta" class="fixed bottom-0 left-0 right-0 z-40 md:hidden bg-white border-t border-gray-200 shadow-[0_-4px_12px_rgba(0,0,0,0.08)]">
  <div class="flex">
    <a href="sms:8475108947&body=Hi Jerry, I'm interested in a vehicle at Maxim Autos." class="flex-1 flex flex-col items-center justify-center py-3 gap-0.5 text-navy hover:bg-gray-50 transition-colors">
      <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1;">sms</span>
      <span class="text-xs font-bold">{labels.mobileText}</span>
    </a>
    <a href="tel:8475108947" class="flex-1 flex flex-col items-center justify-center py-3 gap-0.5 text-navy hover:bg-gray-50 transition-colors border-x border-gray-200">
      <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1;">call</span>
      <span class="text-xs font-bold">{labels.mobileCall}</span>
    </a>
    <a href="https://www.google.com/maps/place/Maxim+Autos/@42.0464352,-87.7546134,17z/data=!3m1!4b1!4m6!3m5!1s0x880fcfcb0a430aed:0x4d36c77af06ce602!8m2!3d42.0464352!4d-87.7546134!16s%2Fg%2F11wmzx_p4t" target="_blank" rel="noopener noreferrer" class="flex-1 flex flex-col items-center justify-center py-3 gap-0.5 text-navy hover:bg-gray-50 transition-colors border-r border-gray-200">
      <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1;">location_on</span>
      <span class="text-xs font-bold">{labels.mobileDirections}</span>
    </a>
    <a href={finHref} class="flex-1 flex flex-col items-center justify-center py-3 gap-0.5 bg-orange text-white hover:bg-orange-dark transition-colors">
      <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1;">payments</span>
      <span class="text-xs font-bold">{labels.mobileFinancing}</span>
    </a>
  </div>
</div>
<div id="footer-sticky-spacer" class="h-16 md:hidden"></div>
