---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
  lang?: string;
  hreflangEn?: string;
  hreflangEs?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const {
  title,
  description,
  ogImage,
  canonicalUrl,
  noIndex = false,
  lang = 'en',
  hreflangEn,
  hreflangEs,
} = Astro.props;

const isSpanish = lang === 'es';
const defaultDescription = isSpanish
  ? 'Maxim Autos: autos usados completamente inspeccionados de $5,000 a $15,000 en Skokie, IL. Placas el mismo dia. Sin tramites del DMV. Financiamiento para todos los niveles de credito. Resenas de 5 estrellas en Google.'
  : 'Quality used cars in Skokie, IL. Every vehicle inspected, every price transparent. Metal plates on the spot. Skip the DMV. Financing for all credit levels. Maxim Autos.';
const resolvedDescription = description ?? defaultDescription;

const trust = isSpanish
  ? {
      heading: 'Por que confian en nosotros',
      protection: 'Proteccion Total',
      protectionDetail: 'Inspeccion · Garantia 3 Meses · CARFAX',
      protectionHref: `${base}/es/sobre-nosotros`,
      skipDmv: 'Sin tramites del DMV',
      skipDmvDetail: 'Placas el mismo dia',
      pricing: 'Precios Transparentes',
      pricingDetail: 'Sin cargos ocultos · Todos los creditos bienvenidos',
      pricingHref: `${base}/es/financiamiento`,
    }
  : {
      heading: 'Why Buyers Trust Us',
      protection: 'Total Protection',
      protectionDetail: 'Inspection · 3-Mo Warranty · CARFAX',
      protectionHref: `${base}/about`,
      skipDmv: 'Skip the DMV',
      skipDmvDetail: 'Metal plates on the spot',
      pricing: 'Transparent Pricing',
      pricingDetail: 'No hidden fees · All credit welcome',
      pricingHref: `${base}/financing`,
    };

const siteName = 'Maxim Autos';
// Dedupe: if title already contains siteName, don't append it again
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

// Build canonical and OG image as absolute URLs using Astro.site (from astro.config.mjs)
// so they always match the configured canonical domain regardless of inbound host
const siteUrl = Astro.site ?? new URL('https://www.maximautos.com/');
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const ogImageAbsolute = new URL(ogImage ?? `${base}/brand/hero-family.jpg`, siteUrl).href;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={resolvedDescription} />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>

    <link rel="canonical" href={canonical} />

    <!-- Favicons (full asset set) -->
    <link rel="icon" type="image/x-icon" href={`${base}/favicon.ico`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}/favicon-16x16.png`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="48x48" href={`${base}/favicon-48x48.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}/site.webmanifest`} />
    <meta name="theme-color" content="#f08010" />
    <meta name="msapplication-TileColor" content="#f08010" />
    <meta name="msapplication-TileImage" content={`${base}/mstile-150x150.png`} />

    <!-- hreflang alternate links for i18n -->
    {hreflangEn && <link rel="alternate" hreflang="en" href={hreflangEn} />}
    {hreflangEs && <link rel="alternate" hreflang="es" href={hreflangEs} />}
    {hreflangEn && hreflangEs && <link rel="alternate" hreflang="x-default" href={hreflangEn} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@MaximAutosSkokie" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- Material Symbols -->
    <style is:inline>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>

    <!-- Organization schema — emitted on every page so SERP/knowledge-panel logo signal is universal -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Maxim Autos",
      "url": "https://www.maximautos.com",
      "logo": "https://www.maximautos.com/brand/logo-512.png",
      "sameAs": [
        "https://www.facebook.com/p/Maxim-Autos-61584813440976/",
        "https://www.cargurus.com/Cars/m-Maxim-Autos-sp457703",
        "https://www.cars.com/dealers/6072153/maxim-autos/"
      ]
    })} />

    <!-- Structured Data Slot -->
    <slot name="structured-data" />

    <!-- Sold vehicle pages: keep URL live but exclude from search index -->
    {noIndex && <meta name="robots" content="noindex, follow" />}

    <!-- Google Search Console Verification -->
    <!-- TODO: Add meta name="google-site-verification" content="YOUR_VERIFICATION_CODE" here -->

    <!-- Google Analytics 4 — Measurement ID: G-H05CD3EHE9 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-H05CD3EHE9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-H05CD3EHE9');
    </script>

    <!-- GA4 lead events — tel:/sms: clicks, lead form submits, chat (future).
         Capture phase so AJAX forms (preventDefault in bubble phase) and
         dynamically rendered links are still counted. -->
    <script is:inline>
      (function () {
        function lead(channel) {
          if (typeof gtag === 'function') {
            gtag('event', 'generate_lead', { lead_channel: channel, transport_type: 'beacon' });
          }
        }
        document.addEventListener('click', function (e) {
          var t = e.target;
          if (!t || typeof t.closest !== 'function') return;
          var a = t.closest('a[href^="tel:"], a[href^="sms:"]');
          if (!a) return;
          lead(a.getAttribute('href').indexOf('sms:') === 0 ? 'sms' : 'phone');
        }, true);
        var FORM_CHANNELS = {
          'contact-form': 'contact_form',
          'financing-form': 'financing_form',
          'apply-form': 'credit_app',
          'sell-trade-form': 'sell_trade_form'
        };
        document.addEventListener('submit', function (e) {
          var f = e.target;
          if (!f || !f.tagName || f.tagName !== 'FORM') return;
          lead(FORM_CHANNELS[f.id] || 'form');
        }, true);
        // Tawk.to is NOT installed today — this is a defensive no-op hook so
        // chat leads start counting automatically if it ever gets added.
        window.Tawk_API = window.Tawk_API || {};
        window.Tawk_API.onChatStarted = function () { lead('chat'); };
      })();
    </script>
  </head>
  <body class="bg-surface font-body text-gray-900 antialiased">
    <slot name="header" />

    <!-- Trust Strip — every page -->
    <div class="bg-orange text-white py-2">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs">
          <span class="font-bold uppercase tracking-widest text-white/80 shrink-0">{trust.heading}</span>
          <span class="text-white/40 hidden sm:block">|</span>
          <a href={trust.protectionHref} class="flex items-center gap-1 hover:underline shrink-0">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">verified_user</span>
            <span class="font-bold">{trust.protection}</span>
            <span class="text-white/70 hidden lg:inline">· {trust.protectionDetail}</span>
          </a>
          <span class="text-white/40 hidden sm:block">·</span>
          <div class="flex items-center gap-1 shrink-0">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">directions_car</span>
            <span class="font-bold">{trust.skipDmv}</span>
            <span class="text-white/70 hidden lg:inline">· {trust.skipDmvDetail}</span>
          </div>
          <span class="text-white/40 hidden sm:block">·</span>
          <a href={trust.pricingHref} class="flex items-center gap-1 hover:underline shrink-0">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">sell</span>
            <span class="font-bold">{trust.pricing}</span>
            <span class="text-white/70 hidden lg:inline">· {trust.pricingDetail}</span>
          </a>
        </div>
      </div>
    </div>

    <main>
      <slot />
    </main>
    <slot name="footer" />

    <!-- GHL Chat Widget (disabled) -->
    <!-- <script src="https://widgets.leadconnectorhq.com/loader.js" data-resources-url="https://widgets.leadconnectorhq.com/chat-widget/loader.js" data-widget-id="6a26cef49372a70f7d2c31e3" data-source="WEB_USER"></script> -->
  </body>
</html>
