---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const {
  title,
  description = 'Quality used cars in Skokie, IL. Every vehicle inspected, every price transparent. Metal plates on the spot. Skip the DMV. Financing for all credit levels. Maxim Autos.',
  ogImage,
  canonicalUrl,
} = Astro.props;

const siteName = 'Maxim Autos';
// Dedupe: if title already contains siteName, don't append it again
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

// Build canonical and OG image as absolute URLs using Astro.site (from astro.config.mjs)
// so they always match the configured canonical domain regardless of inbound host
const siteUrl = Astro.site ?? new URL('https://www.maximautos.com/');
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const ogImageAbsolute = new URL(ogImage ?? `${base}/brand/hero-family.jpg`, siteUrl).href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>

    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${base}/brand/logo-header.png`} type="image/png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- Material Symbols -->
    <style is:inline>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>

    <!-- Structured Data Slot -->
    <slot name="structured-data" />

    <!-- Google Search Console Verification -->
    <!-- TODO: Add meta name="google-site-verification" content="YOUR_VERIFICATION_CODE" here -->

    <!-- Google Analytics 4 — Measurement ID: G-H05CD3EHE9 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-H05CD3EHE9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-H05CD3EHE9');
    </script>
  </head>
  <body class="bg-surface font-body text-gray-900 antialiased">
    <slot name="header" />

    <!-- Trust Strip — every page -->
    <div class="bg-orange text-white py-2">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs">
          <span class="font-bold uppercase tracking-widest text-white/80 shrink-0">Why Buyers Trust Us</span>
          <span class="text-white/40 hidden sm:block">|</span>
          <a href={`${base}/about`} class="flex items-center gap-1 hover:underline shrink-0">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">verified_user</span>
            <span class="font-bold">Total Protection</span>
            <span class="text-white/70 hidden lg:inline">· Inspection · 3-Mo Warranty · CARFAX</span>
          </a>
          <span class="text-white/40 hidden sm:block">·</span>
          <div class="flex items-center gap-1 shrink-0">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">directions_car</span>
            <span class="font-bold">Skip the DMV</span>
            <span class="text-white/70 hidden lg:inline">· Metal plates on the spot</span>
          </div>
          <span class="text-white/40 hidden sm:block">·</span>
          <a href={`${base}/financing`} class="flex items-center gap-1 hover:underline shrink-0">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">sell</span>
            <span class="font-bold">Transparent Pricing</span>
            <span class="text-white/70 hidden lg:inline">· No hidden fees · All credit welcome</span>
          </a>
        </div>
      </div>
    </div>

    <main>
      <slot />
    </main>
    <slot name="footer" />

    <!--Start of Tawk.to Script-->
    <script type="text/javascript">
      var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
      Tawk_API.customStyle = {
        visibility: {
          desktop: { position: 'br', xOffset: 24, yOffset: 24 },
          mobile:  { position: 'br', xOffset: 12, yOffset: 72 }
        }
      };
      (function(){
        var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
        s1.async=true;
        s1.src='https://embed.tawk.to/69dfdfcf38b4681c3225155b/1jm984g8m';
        s1.charset='UTF-8';
        s1.setAttribute('crossorigin','*');
        s0.parentNode.insertBefore(s1,s0);
      })();
    </script>
    <!--End of Tawk.to Script-->
  </body>
</html>
