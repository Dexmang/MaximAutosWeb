---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const {
  title,
  description = 'Quality used cars in Skokie, IL. Every vehicle inspected, every price transparent. Metal plates on the spot. Skip the DMV. Financing for all credit levels. Maxim Autos.',
  ogImage = `${base}/brand/hero-family.jpg`,
  canonicalUrl,
} = Astro.props;

const siteName = 'Maxim Autos';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const canonical = canonicalUrl || Astro.url.href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>

    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${base}/brand/logo-header.png`} type="image/png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- Material Symbols -->
    <style is:inline>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>

    <!-- Structured Data Slot -->
    <slot name="structured-data" />

    <!-- Google Search Console Verification -->
    <!-- TODO: Add meta name="google-site-verification" content="YOUR_VERIFICATION_CODE" here -->

    <!-- Google Analytics 4 — Measurement ID: G-H05CD3EHE9 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-H05CD3EHE9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-H05CD3EHE9');
    </script>
  </head>
  <body class="bg-surface font-body text-gray-900 antialiased">
    <slot name="header" />

    <!-- Trust Strip — every page -->
    <div class="bg-orange text-white py-2.5">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex flex-wrap justify-center gap-x-5 gap-y-1 text-xs font-bold tracking-wide text-center">
          <span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">check_circle</span>Skip the DMV</span>
          <span class="hidden sm:flex items-center gap-1"><span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">check_circle</span>Free CARFAX Every Car</span>
          <span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">check_circle</span>Fully Inspected</span>
          <span class="hidden sm:flex items-center gap-1"><span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">check_circle</span>No Hidden Fees</span>
          <a href={`${base}/financing`} class="flex items-center gap-1 hover:underline"><span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">check_circle</span>All Credit Welcome</a>
        </div>
      </div>
    </div>

    <main>
      <slot />
    </main>
    <slot name="footer" />

    <!-- ============================================================
         TAWK.TO LIVE CHAT — replaces the custom chat widget below
         Setup: 1) Go to tawk.to and create a free account
                2) Add a property for maximautos.com
                3) Get your Property ID and Widget ID
                4) Replace PROPERTY_ID and WIDGET_ID below
                5) Delete the "Floating Chat Widget" section below
         ============================================================
    -->
    <!--
    <script type="text/javascript">
      var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
      Tawk_API.visitor = { name: 'Visitor', email: '' };
      Tawk_API.customStyle = { visibility: { desktop: { position: 'br', xOffset: 24, yOffset: 24 }, mobile: { position: 'br', xOffset: 12, yOffset: 60 } } };
      (function(){
        var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
        s1.async=true;
        s1.src='https://embed.tawk.to/PROPERTY_ID/WIDGET_ID';
        s1.charset='UTF-8';
        s1.setAttribute('crossorigin','*');
        s0.parentNode.insertBefore(s1,s0);
      })();
    </script>
    -->

    <!-- Floating Chat Widget -->
    <div id="chat-widget" class="fixed bottom-20 right-4 sm:bottom-6 sm:right-6 z-50 flex flex-col items-end gap-3">
      <!-- Chat Panel (hidden by default) -->
      <div id="chat-panel" class="hidden bg-white rounded-2xl shadow-2xl border border-gray-100 w-80 overflow-hidden">
        <div class="bg-navy px-5 py-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-orange rounded-full flex items-center justify-center font-bold text-white text-lg">J</div>
            <div>
              <p class="text-white font-bold text-sm">Jerry Franco</p>
              <p class="text-orange text-xs flex items-center gap-1"><span class="w-1.5 h-1.5 bg-green-400 rounded-full inline-block"></span>Usually replies in minutes</p>
            </div>
          </div>
          <button id="chat-close" class="text-white/60 hover:text-white transition-colors">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
        <div class="p-5">
          <p class="text-sm text-gray-600 mb-4 leading-relaxed">Hi! I'm Jerry, owner of Maxim Autos. Text me directly. Fastest way to get answers about any car on the lot.</p>
          <div class="bg-surface rounded-xl p-3 mb-4 text-xs text-gray-500">
            <p class="font-semibold text-gray-700 mb-1">Hours:</p>
            <p>Mon, Tue, Thu, Fri: 3–7pm</p>
            <p>Saturday: 10am–3pm</p>
            <p class="text-orange font-semibold mt-1">After hours? Text anytime. I check!</p>
          </div>
          <a href="sms:8475108947&body=Hi Jerry, I have a question about a vehicle at Maxim Autos."
             class="w-full flex items-center justify-center gap-2 bg-orange text-white py-3 rounded-xl font-bold text-sm hover:bg-orange-dark transition-colors mb-2">
            <span class="material-symbols-outlined text-lg" style="font-variation-settings:'FILL' 1;">sms</span>
            Text Jerry Now
          </a>
          <a href="tel:8475108947"
             class="w-full flex items-center justify-center gap-2 bg-navy text-white py-3 rounded-xl font-bold text-sm hover:bg-navy-light transition-colors">
            <span class="material-symbols-outlined text-lg" style="font-variation-settings:'FILL' 1;">call</span>
            Call (847) 510-8947
          </a>
        </div>
      </div>
      <!-- Chat Bubble Button -->
      <button id="chat-toggle"
        class="flex items-center gap-2 bg-orange text-white px-5 py-3.5 rounded-full shadow-xl hover:bg-orange-dark transition-all hover:scale-105 font-bold text-sm"
        aria-label="Chat with Jerry">
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;" id="chat-icon">chat</span>
        <span id="chat-label">Chat with Jerry</span>
      </button>
    </div>

    <script is:inline>
    (function() {
      var panel = document.getElementById('chat-panel');
      var toggle = document.getElementById('chat-toggle');
      var closeBtn = document.getElementById('chat-close');
      var icon = document.getElementById('chat-icon');
      var label = document.getElementById('chat-label');
      var open = false;
      function setOpen(val) {
        open = val;
        panel.classList.toggle('hidden', !open);
        icon.textContent = open ? 'close' : 'chat';
        label.textContent = open ? 'Close' : 'Chat with Jerry';
      }
      toggle.addEventListener('click', function() { setOpen(!open); });
      closeBtn.addEventListener('click', function() { setOpen(false); });
    })();
    </script>
  </body>
</html>
