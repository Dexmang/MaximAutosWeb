---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = 'Buy Online | Skip the Dealership | Maxim Autos';
const description = 'Buy a car from Maxim Autos 100% online from anywhere. Personal video walkthrough, digital paperwork, secure payment. Pick up in Skokie or door-to-door delivery nationwide.';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "I'm local — can I still buy online?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The entire transaction — video, paperwork, payment — can be handled remotely even if you're 10 minutes away. Pick up when it's convenient or have it delivered." } },
    { "@type": "Question", "name": "What if the car doesn't match the listing?", "acceptedAnswer": { "@type": "Answer", "text": "Before any money moves, Jerry records a personal video of the car showing every imperfection — every scratch, every wear item — and provides a full written condition disclosure. We want you confident before we finalize anything." } },
    { "@type": "Question", "name": "How does payment work?", "acceptedAnswer": { "@type": "Answer", "text": "Secure wire or bank transfer. Paperwork is handled digitally via DocuSign. We do not release the car until payment clears and you have confirmed you're ready." } },
    { "@type": "Question", "name": "What about taxes and registration in my state?", "acceptedAnswer": { "@type": "Answer", "text": "We provide a standard bill of sale. You register in your home state. We handle out-of-state deals regularly and can walk you through exactly what your state requires." } },
    { "@type": "Question", "name": "Is my car insured during shipping?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. All carriers we work with are FMCSA-licensed and insured. You receive the carrier's insurance certificate before the car is loaded." } },
    { "@type": "Question", "name": "How long does delivery take?", "acceptedAnswer": { "@type": "Answer", "text": "Local pickup is available anytime during business hours once the deal is done. Shipping depends on distance — nearby states 1–2 days, mid-range 2–5 days, West Coast 5–9 days. We provide carrier contact info and tracking once the car is picked up." } },
    { "@type": "Question", "name": "Can I have the car independently inspected before buying?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. We welcome third-party pre-purchase inspections through services like Lemon Squad or YourMechanic. Arrange it at your expense and we'll coordinate access." } }
  ]
};
---

<Layout title={title} description={description}>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://maximautos.com/" },
        { "@type": "ListItem", "position": 2, "name": "Buy Online", "item": "https://maximautos.com/ship" }
      ]
    })} />
  </Fragment>
  <Header slot="header" />

  <!-- Hero -->
  <section class="bg-navy py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Buy Online</span>
      <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
        Buy the Car.<br class="hidden md:block" /> Skip the Dealership.
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed mb-8">
        Browse, negotiate, and close the deal entirely online — from anywhere. Pick up in Skokie or get it delivered to your door, anywhere in the U.S.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="sms:8475108947&body=Hi Jerry, I'm interested in buying a vehicle online from Maxim Autos."
           class="sm:hidden inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors shadow-lg shadow-orange/20">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">sms</span>
          Text Jerry
        </a>
        <div class="hidden sm:inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947
        </div>
        <a href={`${base}/inventory`}
           class="inline-flex items-center justify-center gap-2 bg-white/10 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/20 transition-colors border border-white/20">
          Browse Inventory
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-14 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-2 block">The Process</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold">How It Works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        {[
          { step: '1', icon: 'search', title: 'Browse Online', text: 'Find a vehicle you like. Text or call Jerry with any questions — you get the owner directly, not a call center.' },
          { step: '2', icon: 'videocam', title: 'Personal Video', text: 'Jerry records a video of the car for you. Every scratch, every wear item shown. Full CARFAX and written condition report included.' },
          { step: '3', icon: 'payments', title: 'Secure Payment', text: 'Paperwork handled digitally. Secure payment. We do not release the car until everything clears and you are ready.' },
          { step: '4', icon: 'fork_right', title: 'Pick Up or Get It Delivered', text: 'Come grab it from our Skokie lot — or we arrange door-to-door delivery anywhere in the U.S. Licensed carrier, fully insured, tracking provided.' },
        ].map(s => (
          <div class="flex flex-col items-start gap-3 bg-white rounded-2xl p-6 border border-gray-100 shadow-sm">
            <div class="flex items-center gap-3">
              <span class="w-7 h-7 bg-orange text-white text-xs font-extrabold rounded-full flex items-center justify-center shrink-0">{s.step}</span>
              <span class="material-symbols-outlined text-2xl text-navy" style="font-variation-settings:'FILL' 1;">{s.icon}</span>
            </div>
            <h3 class="font-headline text-base font-bold">{s.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Two Ways to Get Your Car -->
  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-2 block">Your Choice</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold">Two Ways to Get Your Car</h2>
        <p class="text-gray-500 mt-3 max-w-xl mx-auto">The entire transaction is online either way. How you take delivery is up to you.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Pick Up -->
        <div class="bg-surface rounded-2xl p-8 border border-gray-200">
          <div class="w-14 h-14 bg-navy/5 rounded-2xl flex items-center justify-center mb-5">
            <span class="material-symbols-outlined text-3xl text-navy" style="font-variation-settings:'FILL' 1;">directions_car</span>
          </div>
          <h3 class="font-headline text-xl font-extrabold mb-3">Pick Up in Skokie</h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-5">
            Come get it at 9101 Terminal Ave. We'll have everything ready — metal plates, paperwork, keys. In and out in under 30 minutes. No waiting, no surprises.
          </p>
          <div class="space-y-2">
            {['No delivery cost', 'Metal plates ready on pickup', 'Deal already done before you arrive'].map(item => (
              <div class="flex items-center gap-2 text-sm text-gray-700">
                <span class="material-symbols-outlined text-sm text-orange" style="font-variation-settings:'FILL' 1;">check_circle</span>
                {item}
              </div>
            ))}
          </div>
          <a href="https://www.google.com/maps/place/Maxim+Autos/@42.0464352,-87.7546134,17z/data=!3m1!4b1!4m6!3m5!1s0x880fcfcb0a430aed:0x4d36c77af06ce602!8m2!3d42.0464352!4d-87.7546134!16s%2Fg%2F11wmzx_p4t"
             target="_blank" rel="noopener"
             class="inline-flex items-center gap-1.5 mt-5 text-sm font-bold text-navy hover:text-orange transition-colors">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">location_on</span>
            9101 Terminal Ave, Skokie IL
          </a>
        </div>

        <!-- Delivery -->
        <div class="bg-navy rounded-2xl p-8 text-white">
          <div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center mb-5">
            <span class="material-symbols-outlined text-3xl text-orange" style="font-variation-settings:'FILL' 1;">local_shipping</span>
          </div>
          <h3 class="font-headline text-xl font-extrabold mb-3">Door-to-Door Delivery</h3>
          <p class="text-gray-300 text-sm leading-relaxed mb-5">
            We arrange a licensed, insured carrier. You get the transport company info and insurance certificate before we load. Works for any address in the U.S. — local or cross-country.
          </p>
          <div class="space-y-2 mb-5">
            {['FMCSA-licensed carriers only', 'Insurance certificate before loading', 'Tracking provided once picked up'].map(item => (
              <div class="flex items-center gap-2 text-sm text-gray-300">
                <span class="material-symbols-outlined text-sm text-orange" style="font-variation-settings:'FILL' 1;">check_circle</span>
                {item}
              </div>
            ))}
          </div>
          <div class="bg-white/10 rounded-xl p-4 text-xs text-gray-300 space-y-1.5">
            <p class="font-bold text-white text-sm mb-2">Estimated shipping from Chicago</p>
            {[
              { to: 'Indiana / Wisconsin / Missouri', cost: '$350–$500' },
              { to: 'New York / Atlanta / Charlotte', cost: '$700–$900' },
              { to: 'Dallas / Miami / Nashville', cost: '$850–$1,075' },
              { to: 'Phoenix / Denver / LA / Seattle', cost: '$950–$1,225' },
            ].map(row => (
              <div class="flex justify-between">
                <span>{row.to}</span>
                <span class="font-semibold text-white">{row.cost}</span>
              </div>
            ))}
            <p class="text-white/50 pt-1">Open transport. No markup. Exact quote from Jerry before anything is finalized.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-14 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-2 block">What You Get</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold">You Know Exactly What You're Buying</h2>
        <p class="text-gray-500 mt-3 max-w-2xl mx-auto">Before you commit to anything, you'll have a personal video, full history report, and written disclosure. We'd rather lose a sale than have a frustrated customer.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {[
          { icon: 'videocam', title: 'Personal Video Walkthrough', sub: 'Jerry records it for you. Every ding, every wear item — named and shown on camera.' },
          { icon: 'description', title: 'Full CARFAX Report', sub: 'Accident history, title status, service records, previous owners.' },
          { icon: 'fact_check', title: 'Written Condition Disclosure', sub: 'Every cosmetic and mechanical issue noted in writing before purchase.' },
          { icon: 'draw', title: 'Digital Paperwork', sub: 'DocuSign. No trip to a notary, no printer required. Sign from anywhere.' },
          { icon: 'verified_user', title: 'Carrier Insurance Certificate', sub: 'FMCSA-licensed carrier. You get the insurance docs before the car is loaded.' },
          { icon: 'gavel', title: 'Out-of-State Title Support', sub: 'We provide the bill of sale and can walk you through your state\'s registration process.' },
        ].map(item => (
          <div class="flex items-start gap-4 bg-white rounded-2xl p-6 border border-gray-100">
            <div class="w-10 h-10 bg-navy/5 rounded-xl flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-xl text-navy" style="font-variation-settings:'FILL' 1;">{item.icon}</span>
            </div>
            <div>
              <p class="font-bold text-sm text-gray-900 mb-1">{item.title}</p>
              <p class="text-gray-500 text-sm">{item.sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-14 bg-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-2 block">FAQ</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold">Common Questions</h2>
      </div>
      <div class="space-y-4">
        {[
          { q: "I'm local — can I still buy online?", a: "Yes. The entire transaction — video, paperwork, payment — can be handled remotely even if you're 10 minutes away. Pick up when it's convenient or have it delivered." },
          { q: "What if the car doesn't match the listing?", a: "Before any money moves, Jerry records a personal video showing every imperfection and provides a full written condition disclosure. We want you confident before we finalize anything." },
          { q: "How does payment work?", a: "Secure wire or bank transfer. Paperwork via DocuSign. We do not release the car until payment clears and you have confirmed you're ready." },
          { q: "What about taxes and registration in my state?", a: "We provide a standard bill of sale. You register in your home state. We handle out-of-state deals regularly and can walk you through exactly what your state requires." },
          { q: "Is my car insured during shipping?", a: "Yes. All carriers we work with are FMCSA-licensed and insured. You receive the carrier's insurance certificate before the car is loaded." },
          { q: "How long does delivery take?", a: "Local pickup is available anytime once the deal is done. Shipping depends on distance — nearby states 1–2 days, mid-range 2–5 days, West Coast 5–9 days. We give you carrier contact info and tracking once the car is picked up." },
          { q: "Can I have the car inspected before buying?", a: "Absolutely. We welcome third-party pre-purchase inspections through services like Lemon Squad or YourMechanic. Arrange it at your expense and we'll coordinate access." },
        ].map(item => (
          <details class="bg-surface rounded-xl border border-gray-200 group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-bold text-sm text-gray-900 list-none">
              {item.q}
              <span class="material-symbols-outlined text-orange text-lg shrink-0 group-open:rotate-180 transition-transform">expand_more</span>
            </summary>
            <p class="px-6 pb-5 text-gray-500 text-sm leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 bg-navy">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-white mb-4">Ready to Get Started?</h2>
      <p class="text-white/70 text-lg mb-8">Text Jerry a link to the vehicle you're interested in. He'll send you a personal video the same day.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="sms:8475108947&body=Hi Jerry, I'm interested in buying a vehicle online from Maxim Autos."
           class="sm:hidden inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">sms</span>
          Text Jerry Now
        </a>
        <div class="hidden sm:inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947
        </div>
        <a href={`${base}/inventory`}
           class="inline-flex items-center justify-center gap-2 bg-white/10 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/20 transition-colors border border-white/20">
          Browse Inventory
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
