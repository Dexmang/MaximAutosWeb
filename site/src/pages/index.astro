---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VehicleCard from '../components/VehicleCard.astro';
import vehicles from '../data/vehicles.json';
import reviews from '../data/reviews.json';
import suburbs from '../data/suburbs.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = 'Quality Used Cars in Skokie, IL | Maxim Autos';
const description = 'Maxim Autos: fully inspected used cars $5K–$15K in Skokie, IL. Metal plates on the spot. Skip the DMV. Financing for all credit levels. 5-star Google reviews.';
const featured = vehicles.slice(0, 6);
---

<Layout title={title} description={description}>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AutoDealer",
      "name": "Maxim Autos",
      "sameAs": [
        "https://www.google.com/maps/place/Maxim+Autos/@42.0464352,-87.7546134,17z/data=!3m1!4b1!4m6!3m5!1s0x880fcfcb0a430aed:0x4d36c77af06ce602!8m2!3d42.0464352!4d-87.7546134!16s%2Fg%2F11wmzx_p4t"
      ],
      "description": description,
      "url": "https://maximautos.com",
      "telephone": "+1-847-510-8947",
      "email": "jerryf@maximautos.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Skokie",
        "addressRegion": "IL",
        "postalCode": "60077",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 42.0334,
        "longitude": -87.7334
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Thursday","Friday"], "opens": "15:00", "closes": "19:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "10:00", "closes": "15:00" }
      ],
      "priceRange": "$5,000 – $15,000",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "34",
        "bestRating": "5"
      },
      "areaServed": [
        { "@type": "City", "name": "Skokie" },
        { "@type": "City", "name": "Evanston" },
        { "@type": "City", "name": "Niles" },
        { "@type": "City", "name": "Morton Grove" },
        { "@type": "City", "name": "Lincolnwood" },
        { "@type": "City", "name": "Des Plaines" },
        { "@type": "City", "name": "Wilmette" },
        { "@type": "City", "name": "Glenview" }
      ]
    })} />
  </Fragment>

  <Header slot="header" />

  <!-- Hero -->
  <section class="bg-navy overflow-hidden md:relative md:min-h-[448px] lg:min-h-[512px] md:flex md:items-center">
    <div class="relative w-full md:absolute md:inset-0 md:z-0">
      <picture>
        <source srcset={`${base}/brand/hero-family.webp`} type="image/webp" />
        <img
          src={`${base}/brand/hero-family.jpg`}
          alt="Family enjoying their car purchased from Maxim Autos in Skokie IL"
          class="w-full h-auto md:h-full md:object-cover md:object-center"
          loading="eager"
        />
      </picture>
      <!-- Mobile: fade bottom of photo into navy content area -->
      <div class="md:hidden absolute inset-0 bg-gradient-to-b from-navy/20 to-navy"></div>
      <!-- Desktop: left-to-right overlay (unchanged) -->
      <div class="hidden md:block absolute inset-0 bg-gradient-to-r from-navy/90 via-navy/70 to-navy/20"></div>
    </div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-8 pt-4 pb-8 md:py-10">
      <div class="max-w-xl">
        <a href="https://www.google.com/search?q=Maxim+Autos+Skokie+IL+reviews" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white rounded-full px-4 py-2 mb-6 hover:bg-white/20 transition-colors">
          <span class="material-symbols-outlined text-orange text-base" style="font-variation-settings: 'FILL' 1;">star</span>
          <span class="font-bold text-sm">5.0 Stars on Google</span>
          <span class="text-white/60 text-xs">· 34 Reviews</span>
        </a>
        <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-4">
          Pre-Owned Cars<br/>in Skokie, IL
        </h1>
        <p class="font-headline text-lg md:text-2xl lg:text-3xl font-bold text-white mb-3">Pre-Owned Cars You Can Actually Trust.</p>
        <p class="text-lg md:text-xl text-white/80 mb-7 leading-relaxed">
          Every car inspected, every price upfront. Metal plates on the spot. Skip the DMV.
        </p>
        <div class="flex flex-wrap gap-2 mb-8">
          {[
            { label: 'Under $10K', href: `${base}/inventory?price=under10k` },
            { label: 'SUVs', href: `${base}/inventory?body=SUV` },
            { label: 'Sedans', href: `${base}/inventory?body=Sedan` },
            { label: 'View All', href: `${base}/inventory` },
          ].map(chip => (
            <a href={chip.href}
               class="bg-white/15 backdrop-blur-sm border border-white/25 text-white text-sm font-semibold px-4 py-2 rounded-full hover:bg-white/30 transition-all">
              {chip.label}
            </a>
          ))}
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={`${base}/inventory`}
             class="inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors shadow-lg">
            Browse Inventory <span class="material-symbols-outlined">arrow_forward</span>
          </a>
          <a href="sms:8475108947&body=Hi Jerry, I'm interested in a vehicle at Maxim Autos."
             class="sm:hidden inline-flex items-center justify-center gap-2 bg-white text-navy px-8 py-4 rounded-xl font-bold text-lg hover:bg-gray-100 transition-colors">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">sms</span>
            Text Jerry
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Vehicles -->
  <section class="py-10 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex justify-between items-center mb-6">
        <div>
          <span class="text-orange font-bold uppercase tracking-widest text-sm mb-1 block">Current Inventory</span>
          <h2 class="font-headline text-2xl md:text-3xl font-extrabold">Available Now</h2>
        </div>
        <a href={`${base}/inventory`} class="flex items-center gap-1 text-navy font-bold hover:text-orange transition-colors text-sm">
          View All <span class="material-symbols-outlined text-lg">arrow_forward</span>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featured.map(v => (
          <VehicleCard
            slug={v.slug}
            year={v.year}
            make={v.make}
            model={v.model}
            trim={v.trim}
            price={v.price}
            mileage={v.mileage}
            drivetrain={v.drivetrain}
            engine={v.engine}
            bodyStyle={v.bodyStyle}
            photoPath={v.photoPath}
            photoPrefix={v.photoPrefix}
            inspected={v.inspected}
            primaryPhotoUrl={v.primaryPhotoUrl}
            photos={v.photos}
          />
        ))}
      </div>
      <div class="text-center mt-10 md:hidden">
        <a href={`${base}/inventory`} class="inline-flex items-center gap-2 bg-navy text-white px-8 py-4 rounded-xl font-bold hover:bg-navy-light transition-colors">
          View All Inventory <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Three Pillars -->
  <section class="py-10 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="flex items-start gap-4 p-4 md:p-6 rounded-xl border border-gray-100 hover:border-orange/20 hover:shadow-md transition-all">
          <div class="w-12 h-12 bg-navy/5 rounded-xl flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-2xl text-navy" style="font-variation-settings: 'FILL' 1;">verified_user</span>
          </div>
          <div class="min-w-0">
            <h3 class="font-headline text-base font-bold mb-1">Total Protection</h3>
            <p class="text-gray-500 text-sm">Independent inspection report included · 3-Month Warranty · Free CARFAX</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 md:p-6 rounded-xl border border-gray-100 hover:border-orange/20 hover:shadow-md transition-all">
          <div class="w-12 h-12 bg-navy/5 rounded-xl flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-2xl text-navy" style="font-variation-settings: 'FILL' 1;">directions_car</span>
          </div>
          <div class="min-w-0">
            <h3 class="font-headline text-base font-bold mb-1">Skip the DMV</h3>
            <p class="text-gray-500 text-sm">Metal plates on the spot. Skip the DMV. Drive home today.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 md:p-6 rounded-xl border border-gray-100 hover:border-orange/20 hover:shadow-md transition-all">
          <div class="w-12 h-12 bg-navy/5 rounded-xl flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-2xl text-navy" style="font-variation-settings: 'FILL' 1;">sell</span>
          </div>
          <div class="min-w-0">
            <h3 class="font-headline text-base font-bold mb-1">Transparent Pricing</h3>
            <p class="text-gray-500 text-sm">No hidden fees · Upfront pricing · Financing for all credit levels</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- We Buy Cars -->
  <section class="py-10 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="bg-navy rounded-2xl p-8 md:p-10 flex flex-col md:flex-row items-center gap-6 md:gap-10">
        <div class="w-16 h-16 bg-orange/20 rounded-2xl flex items-center justify-center shrink-0">
          <span class="material-symbols-outlined text-4xl text-orange" style="font-variation-settings: 'FILL' 1;">monetization_on</span>
        </div>
        <div class="flex-1 text-center md:text-left">
          <h2 class="font-headline text-2xl md:text-3xl font-extrabold text-white mb-2">Selling Your Car? We Buy Private Party.</h2>
          <p class="text-gray-300 text-base">Get a fast, fair cash offer. No dealer games, no lowball tricks. Text Jerry a photo and your asking price.</p>
        </div>
        <a href="sms:8475108947&body=Hi Jerry, I'd like to sell my car. Here's what I have:"
           class="sm:hidden shrink-0 inline-flex items-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors whitespace-nowrap">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">sms</span>
          Get an Offer
        </a>
        <div class="hidden sm:inline-flex shrink-0 items-center gap-2 bg-white/10 border border-white/20 text-white px-8 py-4 rounded-xl font-bold text-lg whitespace-nowrap">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="py-12 bg-navy text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <div class="flex justify-center items-center gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <span class="material-symbols-outlined text-orange text-2xl" style="font-variation-settings: 'FILL' 1;">star</span>
          ))}
        </div>
        <h2 class="font-headline text-3xl md:text-5xl font-extrabold mb-3">5.0 Stars on Google</h2>
        <p class="text-gray-400 text-lg">34+ reviews from North Shore neighbors</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {reviews.map(review => (
          <div class="bg-white/5 p-8 rounded-xl border border-white/10">
            <div class="flex items-center gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <span class="material-symbols-outlined text-orange text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
              ))}
            </div>
            <p class="text-lg italic mb-6 leading-relaxed text-gray-300">"{review.text}"</p>
            <div class="flex items-center justify-between">
              <span class="font-bold text-orange">{review.name}</span>
              <span class="text-xs text-gray-500">{review.source}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={`${base}/testimonials`} class="inline-flex items-center gap-2 text-orange font-bold hover:underline">
          Read All Reviews <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Serving North Shore -->
  <section class="py-10 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="flex-1">
          <h2 class="font-headline text-2xl md:text-3xl font-extrabold mb-3">Serving Chicago's North Shore</h2>
          <p class="text-gray-600 mb-4">Located in Skokie. Fully inspected pre-owned cars $5K–$15K with financing for all credit levels.</p>
          <div class="flex flex-wrap gap-2 mb-5">
            {['Skokie', 'Evanston', 'Niles', 'Morton Grove', 'Lincolnwood', 'Des Plaines', 'Wilmette', 'Glenview', 'Chicago'].map(city => (
              <span class="px-3 py-1.5 bg-surface rounded-full text-sm font-medium text-gray-700 border border-gray-200">{city}</span>
            ))}
          </div>
          <a href="https://www.google.com/maps/dir/?api=1&destination=9101+Terminal+Ave,+Skokie,+IL+60077" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-navy text-white px-6 py-3 rounded-xl font-bold hover:bg-navy-light transition-colors">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">location_on</span>
            Get Directions
          </a>
        </div>
        <div class="hidden md:block w-72 h-48 bg-surface rounded-2xl overflow-hidden border border-gray-200">
          <iframe
            src="https://maps.google.com/maps?q=9101+Terminal+Ave,+Skokie,+IL+60077&output=embed"
            width="100%" height="100%" style="border:0;" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            title="Maxim Autos location map Skokie IL"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Areas We Serve -->
  <section class="py-12 bg-surface border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-8">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-2 block">Service Area</span>
        <h2 class="font-headline text-2xl md:text-3xl font-extrabold text-navy mb-3">We Bring the Dealership to Your Neighborhood</h2>
        <p class="text-gray-600 text-base max-w-2xl mx-auto">Serving Skokie, Evanston, Niles, and all surrounding communities on Chicago's North Shore.</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-7 gap-3">
        {suburbs.map(s => (
          <a
            href={`${base}/used-cars-${s.slug}-il`}
            class="group flex flex-col items-center justify-center text-center p-4 rounded-xl bg-white border border-gray-200 hover:border-orange/40 hover:shadow-md transition-all"
          >
            <span class="font-headline font-bold text-navy text-sm group-hover:text-orange transition-colors">{s.city}</span>
            <span class="text-xs text-gray-400 mt-0.5">Used Cars</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-12 bg-navy">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-white mb-4">Ready to Find Your Next Car?</h2>
      <p class="text-white/70 text-lg mb-8">Call or text Jerry for a quick response, or browse the full inventory online.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="sms:8475108947&body=Hi Jerry, I'm interested in a vehicle at Maxim Autos." class="sm:hidden inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">sms</span>
          Text Jerry Now
        </a>
        <div class="hidden sm:inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947
        </div>
        <a href={`${base}/inventory`} class="inline-flex items-center justify-center gap-2 bg-white/10 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/20 transition-colors border border-white/20">
          Browse Inventory
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
