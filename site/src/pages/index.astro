---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VehicleCard from '../components/VehicleCard.astro';
import vehicles from '../data/vehicles.json';
import reviews from '../data/reviews.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = 'Quality Used Cars in Skokie, IL — Maxim Autos';
const description = 'Maxim Autos: quality-inspected used cars $5K–$15K in Skokie, IL. Metal plates on-the-spot, financing for all credit levels. 5-star Google reviews.';
const featured = vehicles.slice(0, 6);
---

<Layout title={title} description={description}>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AutoDealer",
      "name": "Maxim Autos",
      "description": description,
      "url": "https://maximautos.com",
      "telephone": "+1-847-510-8947",
      "email": "jerryf@maximautos.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Skokie",
        "addressRegion": "IL",
        "postalCode": "60077",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 42.0334,
        "longitude": -87.7334
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Thursday","Friday"], "opens": "15:00", "closes": "19:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "10:00", "closes": "15:00" }
      ],
      "priceRange": "$5,000 – $15,000",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "33",
        "bestRating": "5"
      },
      "areaServed": [
        { "@type": "City", "name": "Skokie" },
        { "@type": "City", "name": "Evanston" },
        { "@type": "City", "name": "Niles" },
        { "@type": "City", "name": "Morton Grove" },
        { "@type": "City", "name": "Lincolnwood" },
        { "@type": "City", "name": "Des Plaines" },
        { "@type": "City", "name": "Wilmette" },
        { "@type": "City", "name": "Glenview" }
      ]
    })} />
  </Fragment>

  <Header slot="header" />

  <!-- Hero -->
  <section class="relative min-h-[600px] lg:min-h-[700px] flex items-center bg-navy">
    <div class="absolute inset-0 bg-gradient-to-r from-navy/95 via-navy/80 to-navy/60 z-10"></div>
    <div class="relative z-20 w-full max-w-7xl mx-auto px-6 lg:px-8 py-20">
      <div class="max-w-2xl">
        <div class="flex items-center gap-2 mb-6">
          <span class="material-symbols-outlined text-orange" style="font-variation-settings: 'FILL' 1;">star</span>
          <span class="text-orange font-bold text-sm">5.0 Stars on Google &bull; 33+ Reviews</span>
        </div>
        <h1 class="font-headline text-4xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight tracking-tight mb-6">
          Quality Used Cars in Skokie, IL
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 mb-10 leading-relaxed">
          Every car inspected. Every price transparent. Every customer protected.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={`${base}/inventory`} class="inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors shadow-lg shadow-orange/20">
            Browse Inventory
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
          <a href="sms:8475108947&body=Hi Jerry, I'm interested in a vehicle at Maxim Autos." class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white/30 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/10 transition-colors">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">sms</span>
            Text Jerry
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Three Pillars -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">The Maxim Autos Difference</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold">Why Buyers Choose Us</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-8 rounded-xl border border-gray-100 hover:border-orange/20 hover:shadow-md transition-all">
          <div class="w-16 h-16 bg-navy/5 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-4xl text-navy" style="font-variation-settings: 'FILL' 1;">verified_user</span>
          </div>
          <h3 class="font-headline text-xl font-bold mb-3">Total Protection</h3>
          <ul class="text-gray-600 text-sm space-y-2">
            <li>Independent Inspection Report included</li>
            <li>Independent Inspection Report included</li>
            <li>Fully inspected vehicles</li>
          </ul>
        </div>
        <div class="text-center p-8 rounded-xl border border-gray-100 hover:border-orange/20 hover:shadow-md transition-all">
          <div class="w-16 h-16 bg-navy/5 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-4xl text-navy" style="font-variation-settings: 'FILL' 1;">directions_car</span>
          </div>
          <h3 class="font-headline text-xl font-bold mb-3">Skip the DMV Headache</h3>
          <ul class="text-gray-600 text-sm space-y-2">
            <li>Metal plates issued on-the-spot</li>
            <li>Drive home today</li>
            <li>Instant DMV registration</li>
          </ul>
        </div>
        <div class="text-center p-8 rounded-xl border border-gray-100 hover:border-orange/20 hover:shadow-md transition-all">
          <div class="w-16 h-16 bg-navy/5 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-4xl text-navy" style="font-variation-settings: 'FILL' 1;">sell</span>
          </div>
          <h3 class="font-headline text-xl font-bold mb-3">Transparent Pricing</h3>
          <ul class="text-gray-600 text-sm space-y-2">
            <li>No hidden fees or surprises</li>
            <li>Upfront competitive pricing</li>
            <li>Financing for all credit levels</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Vehicles -->
  <section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex justify-between items-end mb-12">
        <div>
          <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Current Inventory</span>
          <h2 class="font-headline text-3xl md:text-4xl font-extrabold">Featured Vehicles</h2>
        </div>
        <a href={`${base}/inventory`} class="hidden md:flex items-center gap-1 text-navy font-bold hover:text-orange transition-colors">
          View All <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featured.map(v => (
          <VehicleCard
            slug={v.slug}
            year={v.year}
            make={v.make}
            model={v.model}
            trim={v.trim}
            price={v.price}
            mileage={v.mileage}
            drivetrain={v.drivetrain}
            engine={v.engine}
            bodyStyle={v.bodyStyle}
            photoPath={v.photoPath}
            photoPrefix={v.photoPrefix}
            certified={v.certified}
          />
        ))}
      </div>
      <div class="text-center mt-10 md:hidden">
        <a href={`${base}/inventory`} class="inline-flex items-center gap-2 bg-navy text-white px-8 py-4 rounded-xl font-bold hover:bg-navy-light transition-colors">
          View All Inventory <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="py-20 bg-navy text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-14">
        <div class="flex justify-center items-center gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <span class="material-symbols-outlined text-orange text-2xl" style="font-variation-settings: 'FILL' 1;">star</span>
          ))}
        </div>
        <h2 class="font-headline text-3xl md:text-5xl font-extrabold mb-3">5.0 Stars on Google</h2>
        <p class="text-gray-400 text-lg">33+ reviews from North Shore neighbors</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {reviews.map(review => (
          <div class="bg-white/5 p-8 rounded-xl border border-white/10">
            <div class="flex items-center gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <span class="material-symbols-outlined text-orange text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
              ))}
            </div>
            <p class="text-lg italic mb-6 leading-relaxed text-gray-300">"{review.text}"</p>
            <div class="flex items-center justify-between">
              <span class="font-bold text-orange">— {review.name}</span>
              <span class="text-xs text-gray-500">{review.source}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={`${base}/testimonials`} class="inline-flex items-center gap-2 text-orange font-bold hover:underline">
          Read All Reviews <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Serving North Shore -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-6">Serving Chicago's North Shore</h2>
        <p class="text-gray-600 text-lg mb-10 leading-relaxed">
          Located in Skokie, Maxim Autos proudly serves buyers across Chicago's North Shore suburbs.
          Quality-inspected used cars from $5,000 to $15,000 with financing for all credit levels.
        </p>
        <div class="flex flex-wrap justify-center gap-3 mb-10">
          {['Skokie', 'Evanston', 'Niles', 'Morton Grove', 'Lincolnwood', 'Des Plaines', 'Wilmette', 'Glenview', 'Chicago'].map(city => (
            <span class="px-5 py-2.5 bg-surface rounded-full text-sm font-medium text-gray-700 border border-gray-200">{city}</span>
          ))}
        </div>
        <a href={`${base}/contact`} class="inline-flex items-center gap-2 bg-navy text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-navy-light transition-colors">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">location_on</span>
          Get Directions
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 bg-orange">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-white mb-4">Ready to Find Your Next Car?</h2>
      <p class="text-white/90 text-lg mb-8">Text Jerry for a quick response, or browse the full inventory online.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="sms:8475108947&body=Hi Jerry, I'm interested in a vehicle at Maxim Autos." class="inline-flex items-center justify-center gap-2 bg-white text-navy px-8 py-4 rounded-xl font-bold text-lg hover:bg-gray-100 transition-colors">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">sms</span>
          Text Jerry Now
        </a>
        <a href={`${base}/inventory`} class="inline-flex items-center justify-center gap-2 bg-navy text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-navy-light transition-colors">
          Browse Inventory
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
