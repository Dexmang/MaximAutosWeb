<script is:inline>
(function () {
  var photoDataEl = document.getElementById('photo-data');
  var photos = photoDataEl ? JSON.parse(photoDataEl.textContent) : [];
  var currentIndex = 0;

  // Lightbox
  var lightbox = document.getElementById('lightbox');
  var lightboxImg = document.getElementById('lightbox-img');
  var lightboxCounter = document.getElementById('lightbox-counter');

  function updateLightbox(index) {
    currentIndex = index;
    if (lightboxImg) lightboxImg.src = photos[index];
    if (lightboxCounter) lightboxCounter.textContent = (index + 1) + ' / ' + photos.length;
  }
  function openLightbox(index) {
    if (!lightbox || !photos.length) return;
    updateLightbox(index);
    lightbox.showModal();
  }

  var galleryHero = document.getElementById('gallery-hero');
  if (galleryHero) galleryHero.addEventListener('click', function () { openLightbox(0); });
  document.querySelectorAll('.gallery-thumb').forEach(function (el) {
    el.addEventListener('click', function () { openLightbox(parseInt(el.dataset.index, 10)); });
  });
  var mobileHero = document.getElementById('gallery-hero-mobile');
  if (mobileHero) mobileHero.addEventListener('click', function () { openLightbox(0); });
  var viewAllBtn = document.getElementById('view-all-btn');
  if (viewAllBtn) viewAllBtn.addEventListener('click', function () { openLightbox(0); });

  var lightboxClose = document.getElementById('lightbox-close');
  var lightboxPrev = document.getElementById('lightbox-prev');
  var lightboxNext = document.getElementById('lightbox-next');
  if (lightboxClose) lightboxClose.addEventListener('click', function () { lightbox.close(); });
  if (lightboxPrev) lightboxPrev.addEventListener('click', function () { updateLightbox((currentIndex - 1 + photos.length) % photos.length); });
  if (lightboxNext) lightboxNext.addEventListener('click', function () { updateLightbox((currentIndex + 1) % photos.length); });
  if (lightbox) {
    lightbox.addEventListener('click', function (e) { if (e.target === lightbox) lightbox.close(); });
    lightbox.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft') updateLightbox((currentIndex - 1 + photos.length) % photos.length);
      if (e.key === 'ArrowRight') updateLightbox((currentIndex + 1) % photos.length);
    });
  }

  // FAQ accordion
  var faqList = document.getElementById('faq-list');
  if (faqList) {
    faqList.addEventListener('click', function (e) {
      var toggle = e.target.closest('.faq-toggle');
      if (!toggle) return;
      var item = toggle.closest('.faq-item');
      var answer = item.querySelector('.faq-answer');
      var icon = toggle.querySelector('.faq-icon');
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      answer.classList.toggle('hidden', expanded);
      icon.style.transform = expanded ? '' : 'rotate(180deg)';
    });
  }

  // Mobile payment calculator (collapsible callout)
  (function () {
    var toggleBtn = document.getElementById('mobile-calc-toggle');
    var panel = document.getElementById('mobile-calc-panel');
    var icon = document.getElementById('mobile-calc-icon');
    if (!toggleBtn || !panel) return;

    toggleBtn.addEventListener('click', function () {
      var open = !panel.classList.contains('hidden');
      panel.classList.toggle('hidden', open);
      icon.style.transform = open ? '' : 'rotate(180deg)';
      if (!open) mUpdate();
    });

    var priceEl = document.querySelector('[data-vehicle-price]');
    var mPrice = priceEl ? parseFloat(priceEl.dataset.vehiclePrice || 0) : 0;
    var mDown = document.getElementById('m-fin-down-slider');
    var mApr = document.getElementById('m-fin-apr-slider');
    var mTermSel = document.getElementById('m-fin-term-selector');
    var mDownDisp = document.getElementById('m-fin-down-display');
    var mAprDisp = document.getElementById('m-fin-apr-display');
    var mResult = document.getElementById('m-fin-result');
    var mPrincipal = document.getElementById('m-fin-principal');
    var mActiveTerm = 60;

    function mCalc(p, d, apr, n) {
      var principal = p - d;
      if (principal <= 0) return 0;
      var r = (apr / 100) / 12;
      if (r === 0) return Math.round(principal / n);
      return Math.round(principal * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1));
    }
    function mUpdate() {
      if (!mDown || !mApr) return;
      var d = parseFloat(mDown.value);
      var apr = parseFloat(mApr.value);
      var payment = mCalc(mPrice, d, apr, mActiveTerm);
      if (mDownDisp) mDownDisp.textContent = '$' + Math.round(d).toLocaleString();
      if (mAprDisp) mAprDisp.textContent = apr.toFixed(1) + '%';
      if (mResult) mResult.textContent = '$' + payment + '/mo';
      if (mPrincipal) mPrincipal.textContent = '$' + Math.round(mPrice - d).toLocaleString();
    }
    if (mDown) { mDown.value = Math.round(mPrice * 0.10); mDown.addEventListener('input', mUpdate); }
    if (mApr) mApr.addEventListener('input', mUpdate);
    if (mTermSel) {
      mTermSel.addEventListener('click', function (e) {
        var btn = e.target.closest('.m-fin-term-btn');
        if (!btn) return;
        mActiveTerm = parseInt(btn.dataset.term);
        mTermSel.querySelectorAll('.m-fin-term-btn').forEach(function (b) {
          var a = b.dataset.term == mActiveTerm;
          b.classList.toggle('bg-navy', a); b.classList.toggle('text-white', a); b.classList.toggle('border-navy', a);
          b.classList.toggle('bg-white', !a); b.classList.toggle('text-gray-600', !a); b.classList.toggle('border-gray-200', !a);
        });
        mUpdate();
      });
    }
    mUpdate();
  })();

  // Sidebar (desktop) payment calculator
  (function () {
    var priceEl = document.querySelector('[data-vehicle-price]');
    var sbPrice = priceEl ? parseFloat(priceEl.dataset.vehiclePrice || 0) : 0;
    var sbDown = document.getElementById('sb-fin-down-slider');
    var sbApr = document.getElementById('sb-fin-apr-slider');
    var sbTermSel = document.getElementById('sb-fin-term-selector');
    var sbDownDisp = document.getElementById('sb-fin-down-display');
    var sbAprDisp = document.getElementById('sb-fin-apr-display');
    var sbResult = document.getElementById('sb-fin-result');
    var sbPrincipal = document.getElementById('sb-fin-principal');
    var sbActiveTerm = 60;

    function sbCalc(p, d, apr, n) {
      var principal = p - d;
      if (principal <= 0) return 0;
      var r = (apr / 100) / 12;
      if (r === 0) return Math.round(principal / n);
      return Math.round(principal * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1));
    }
    function sbUpdate() {
      if (!sbDown || !sbApr) return;
      var d = parseFloat(sbDown.value);
      var apr = parseFloat(sbApr.value);
      var payment = sbCalc(sbPrice, d, apr, sbActiveTerm);
      if (sbDownDisp) sbDownDisp.textContent = '$' + Math.round(d).toLocaleString();
      if (sbAprDisp) sbAprDisp.textContent = apr.toFixed(1) + '%';
      if (sbResult) sbResult.textContent = '$' + payment + '/mo';
      if (sbPrincipal) sbPrincipal.textContent = '$' + Math.round(sbPrice - d).toLocaleString();
    }
    if (sbDown) { sbDown.value = Math.round(sbPrice * 0.10); sbDown.addEventListener('input', sbUpdate); }
    if (sbApr) sbApr.addEventListener('input', sbUpdate);
    if (sbTermSel) {
      sbTermSel.addEventListener('click', function (e) {
        var btn = e.target.closest('.sb-fin-term-btn');
        if (!btn) return;
        sbActiveTerm = parseInt(btn.dataset.term);
        sbTermSel.querySelectorAll('.sb-fin-term-btn').forEach(function (b) {
          var a = b.dataset.term == sbActiveTerm;
          b.classList.toggle('bg-navy', a); b.classList.toggle('text-white', a); b.classList.toggle('border-navy', a);
          b.classList.toggle('bg-white', !a); b.classList.toggle('text-gray-500', !a); b.classList.toggle('border-gray-200', !a);
        });
        sbUpdate();
      });
    }
    sbUpdate();
  })();
})();
</script>

