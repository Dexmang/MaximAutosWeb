  }
  #lightbox-prev, #lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.12);
    border: none;
    border-radius: 50%;
    width: 3.25rem;
    height: 3.25rem;
    display: flex;
    align-items: center;
