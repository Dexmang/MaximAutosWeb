---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import VehicleCard from '../../components/VehicleCard.astro';
import vehicles from '../../data/vehicles.json';

export function getStaticPaths() {
  return vehicles.map(v => ({
    params: { slug: v.slug },
    props: { vehicle: v },
  }));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { vehicle } = Astro.props;
const v = vehicle;
const titleText = `${v.year} ${v.make} ${v.model} ${v.trim}`;
const pageTitle = `${titleText} for Sale in Skokie, IL`;
const pageDesc = `${titleText} with ${v.mileage.toLocaleString()} miles for $${v.price.toLocaleString()} at Maxim Autos in Skokie, IL. ${v.engine}, ${v.transmission}, ${v.drivetrain}. Fully inspected with free CARFAX. Same-day metal plates.`;
const seoSuffix = 'maxim-autos-skokie-il';

// Build photo arrays
let allPhotos: string[];
if (v.photoUrls?.length > 0) {
  allPhotos = v.photoUrls;
} else {
  const ext = Array.from({ length: v.photos?.exterior ?? 0 }, (_, i) => {
    const num = String(i + 1).padStart(2, '0');
    return `${base}/${v.photoPath}/web/${v.photoPrefix}-photo-exterior-${seoSuffix}-${num}.jpg`;
  });
  const intr = Array.from({ length: v.photos?.interior ?? 0 }, (_, i) => {
    const num = String(i + 1).padStart(2, '0');
    return `${base}/${v.photoPath}/web/${v.photoPrefix}-photo-interior-${seoSuffix}-${num}.jpg`;
  });
  allPhotos = [...ext, ...intr];
}

const otherVehicles = vehicles.filter(o => o.slug !== v.slug).slice(0, 3);
const smsBody = encodeURIComponent(`Hi Jerry, I'm interested in the ${titleText} listed on MaximAutos.com.`);

// Static payment estimate (10% down, 9.9% APR, 60 mo)
const downPayment = Math.round(v.price * 0.10);
const principal = v.price - downPayment;
const monthlyRate = 0.099 / 12;
const numPayments = 60;
const monthlyPayment = Math.round(
  principal * (monthlyRate * Math.pow(1 + monthlyRate, numPayments)) /
  (Math.pow(1 + monthlyRate, numPayments) - 1)
);

const highlights: string[] = (v as any).highlights || [];
const historyBadges: string[] = (v as any).historyBadges || [];
const description: string = (v as any).description || '';
const stockNumber: string = (v as any).stockNumber || '';
const imv: number | null = (v as any).imv || null;
const mpg: string = (v as any).mpg || '';

// Deal badge
let dealLabel = '';
let dealColor = '';
if (imv && imv > 0) {
  const ratio = v.price / imv;
  if (ratio < 0.93) { dealLabel = 'Great Deal'; dealColor = 'bg-green-100 text-green-800 border-green-200'; }
  else if (ratio < 1.0) { dealLabel = 'Good Deal'; dealColor = 'bg-teal-100 text-teal-800 border-teal-200'; }
  else { dealLabel = 'Fair Price'; dealColor = 'bg-gray-100 text-gray-600 border-gray-200'; }
}

// Feature categorization
const safetyKeywords = ['eyesight','blind spot','backup camera','backup','lane','collision','abs','airbag','alert','safety','stability','traction','monitor','sensor','assist','warning'];
const comfortKeywords = ['leather','heated','sunroof','moonroof','ventilat','memory','massage','lumbar','seat','climate','panoramic','pano','comfort','power seat'];
const techKeywords = ['carplay','android auto','bluetooth','navigation','nav','sync','wifi','usb','display','audio','harman','bose','premium sound','satellite','sirius','wireless','touchscreen'];

function categorize(features: string[]) {
  const safety: string[] = [], comfort: string[] = [], tech: string[] = [], other: string[] = [];
  features.forEach(f => {
    const fl = f.toLowerCase();
    if (safetyKeywords.some(k => fl.includes(k))) safety.push(f);
    else if (techKeywords.some(k => fl.includes(k))) tech.push(f);
    else if (comfortKeywords.some(k => fl.includes(k))) comfort.push(f);
    else other.push(f);
  });
  return { safety, comfort, tech, other };
}
const featureCats = categorize(v.features);
const hasCategories = featureCats.safety.length > 0 || featureCats.comfort.length > 0 || featureCats.tech.length > 0;

const faqs = [
  { q: `Is the ${v.year} ${v.make} ${v.model} reliable?`, a: `The ${v.year} ${v.make} ${v.model} is well-regarded for reliability. This pre-owned vehicle has been fully inspected by an independent mechanic and the report is included with your purchase.` },
  { q: `Is this pre-owned ${v.make} ${v.model} inspected before sale?`, a: `Yes. This ${titleText} has been inspected by an independent mechanic. The full inspection report is included with purchase so you can review every detail before buying.` },
  { q: `Can I get pre-approved for financing on this ${v.make} ${v.model}?`, a: `Yes. Maxim Autos offers financing for all credit levels, including first-time buyers and those rebuilding credit. Get pre-approved quickly with no impact to your credit score. Contact Jerry directly to discuss your options.` },
  { q: `Does this pre-owned ${v.make} ${v.model} come with a CARFAX report?`, a: `Yes. A CARFAX vehicle history report is included with every pre-owned vehicle at Maxim Autos at no extra cost. Review the full history of this ${titleText} before making a decision.` },
  { q: `Can I drive this ${v.make} ${v.model} home the same day?`, a: `Yes. Maxim Autos is an authorized Illinois CVR (Computer Vehicle Registration) electronic registration dealer. We process your title and registration on the spot and issue real metal plates the same day. No waiting for temporary plates, no trip to the DMV.` },
  { q: `Are there any hidden fees on this pre-owned ${v.make} ${v.model}?`, a: `No. Maxim Autos uses transparent, upfront pricing. The listed price of $${v.price.toLocaleString()} is what you pay plus standard state tax, title, and license fees. No hidden charges.` },
];

// Structured data
const vehicleSchema = {
  "@context": "https://schema.org",
  "@type": "Car",
  "name": titleText,
  "description": pageDesc,
  "brand": { "@type": "Brand", "name": v.make },
  "model": v.model,
  "vehicleModelDate": String(v.year),
  "mileageFromOdometer": { "@type": "QuantitativeValue", "value": v.mileage, "unitCode": "SMI" },
  "color": v.exteriorColor,
  "vehicleInteriorColor": v.interiorColor,
  "vehicleEngine": { "@type": "EngineSpecification", "name": v.engine },
  "vehicleTransmission": v.transmission,
  "driveWheelConfiguration": v.drivetrain,
  "fuelType": v.fuelType,
  "bodyType": v.bodyStyle,
  "itemCondition": "https://schema.org/UsedCondition",
  "offers": {
    "@type": "Offer",
    "price": v.price,
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "AutoDealer", "name": "Maxim Autos", "telephone": "+1-847-510-8947", "address": { "@type": "PostalAddress", "addressLocality": "Skokie", "addressRegion": "IL", "postalCode": "60077", "addressCountry": "US" } }
  },
  "image": allPhotos.length > 0 ? allPhotos[0] : undefined,
  "url": `https://www.maximautos.com/vehicle/${v.slug}`
};
if (v.vin && v.vin !== 'TBD') (vehicleSchema as any).vehicleIdentificationNumber = v.vin;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
};
---

<Layout title={pageTitle} description={pageDesc} ogImage={allPhotos.length > 0 ? allPhotos[0] : undefined}>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(vehicleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.maximautos.com/" },
        { "@type": "ListItem", "position": 2, "name": "Inventory", "item": "https://www.maximautos.com/inventory" },
        { "@type": "ListItem", "position": 3, "name": titleText }
      ]
    })} />
  </Fragment>
  <Header slot="header" />

  <!-- Photo data for JS -->
  <script id="photo-data" type="application/json" set:html={JSON.stringify(allPhotos)} />

  <!-- ===== GALLERY ===== -->
  <section class="bg-gray-900">
    <div class="max-w-7xl mx-auto">
      {allPhotos.length > 0 ? (
        <div>
          {/* Desktop: 60/40 split */}
          <div class="gallery-desktop hidden md:grid">
            <div class="relative overflow-hidden cursor-pointer group" id="gallery-hero" data-index="0">
              <img src={allPhotos[0]} alt={`${titleText} for sale at Maxim Autos Skokie IL`}
                   class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]" />
              {v.inspected && (
                <div class="absolute top-3 left-3 bg-green-600 text-white text-xs font-bold px-2.5 py-1 rounded-md flex items-center gap-1">
                  <span class="material-symbols-outlined text-xs" style="font-variation-settings:'FILL' 1;">verified</span>
                  FULLY INSPECTED
                </div>
              )}
              <div class="absolute bottom-3 left-3 bg-black/60 text-white text-sm font-semibold px-3 py-1.5 rounded-md flex items-center gap-1.5">
                <span class="material-symbols-outlined text-base">photo_camera</span>
                {allPhotos.length} photos · Click to view all
              </div>
            </div>
            <div class="gallery-right">
              {[1, 2, 3, 4].map((idx) => {
                const src = allPhotos[idx] ?? allPhotos[0];
                const showOverlay = idx === 4 && allPhotos.length > 5;
                return (
                  <div class="relative overflow-hidden cursor-pointer group gallery-thumb" data-index={idx}>
                    <img src={src} alt={`${titleText} photo ${idx + 1}`}
                         class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.04]" loading="lazy" />
                    {showOverlay && (
                      <div class="absolute inset-0 bg-black/65 flex flex-col items-center justify-center text-white pointer-events-none">
                        <span class="text-3xl font-extrabold">+{allPhotos.length - 5}</span>
                        <span class="text-sm font-semibold mt-1">more photos</span>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
          {/* Mobile: single hero */}
          <div class="md:hidden relative">
            <div class="relative cursor-pointer" id="gallery-hero-mobile">
              <img src={allPhotos[0]} alt={`${titleText} for sale at Maxim Autos Skokie IL`}
                   class="w-full aspect-video object-cover" />
              {v.inspected && (
                <div class="absolute top-3 left-3 bg-green-600 text-white text-xs font-bold px-2.5 py-1 rounded-md flex items-center gap-1">
                  <span class="material-symbols-outlined text-xs" style="font-variation-settings:'FILL' 1;">verified</span>
                  FULLY INSPECTED
                </div>
              )}
              {allPhotos.length > 1 && (
                <button id="view-all-btn"
                  class="absolute bottom-3 right-3 bg-black/70 text-white text-sm font-semibold px-3 py-1.5 rounded-md flex items-center gap-1.5">
                  <span class="material-symbols-outlined text-base">photo_library</span>
                  View all {allPhotos.length} photos
                </button>
              )}
            </div>
          </div>
        </div>
      ) : (
        <div class="bg-gray-800 h-64 flex items-center justify-center">
          <div class="text-center text-gray-500">
            <span class="material-symbols-outlined text-6xl mb-2 block">no_photography</span>
            <p class="font-medium text-gray-400">Photos coming soon</p>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ===== MAIN 2-COLUMN LAYOUT ===== -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-10">
      <div class="flex flex-col lg:flex-row gap-10">

        <!-- ===== LEFT COLUMN ===== -->
        <div class="flex-1 min-w-0">

          <!-- Breadcrumb -->
          <nav class="flex items-center gap-1.5 text-sm text-gray-400 mb-4">
            <a href={`${base}/`} class="hover:text-navy transition-colors">Home</a>
            <span class="material-symbols-outlined text-xs">chevron_right</span>
            <a href={`${base}/inventory`} class="hover:text-navy transition-colors">Inventory</a>
            <span class="material-symbols-outlined text-xs">chevron_right</span>
            <span class="text-gray-600 font-medium truncate">{titleText}</span>
          </nav>

          <!-- Title -->
          <h1 class="font-headline text-2xl md:text-3xl font-extrabold text-navy leading-tight mb-2">{titleText}</h1>
          <div class="flex flex-wrap items-center gap-2 text-sm text-gray-500 mb-4">
            <span>{v.mileage.toLocaleString()} mi</span>
            <span class="text-gray-300">·</span>
            <span>{v.drivetrain}</span>
            <span class="text-gray-300">·</span>
            <span>{v.engine}</span>
            <span class="text-gray-300">·</span>
            <span>{v.exteriorColor}</span>
            {stockNumber && <><span class="text-gray-300">·</span><span>Stock #{stockNumber}</span></>}
          </div>

          <!-- Mobile price (shown below title on mobile, hidden on lg where sidebar shows) -->
          <div class="lg:hidden mb-5 pb-5 border-b border-gray-100">
            <span class="text-3xl font-extrabold text-navy" data-vehicle-price={v.price}>${v.price.toLocaleString()}</span>
            <span class="text-sm text-gray-500 ml-2">Est. ${monthlyPayment}/mo</span>

            <!-- Orange payment estimator callout -->
            <button id="mobile-calc-toggle"
              class="mt-3 w-full flex items-center justify-between bg-orange/10 border border-orange/30 text-orange rounded-xl px-4 py-3 font-bold text-sm hover:bg-orange/15 transition-colors">
              <span class="flex items-center gap-2">
                <span class="material-symbols-outlined text-lg" style="font-variation-settings:'FILL' 1;">calculate</span>
                Estimate Your Payment
              </span>
              <span class="material-symbols-outlined text-base transition-transform duration-200" id="mobile-calc-icon">expand_more</span>
            </button>

            <!-- Expandable payment calculator -->
            <div id="mobile-calc-panel" class="hidden mt-3 animate-slideDown">
              <div class="bg-surface rounded-xl border border-orange/20 p-5">
                <div class="mb-4">
                  <div class="flex justify-between items-center mb-2">
                    <label class="text-sm font-semibold text-gray-700">Down Payment</label>
                    <span class="text-sm font-bold text-navy" id="m-fin-down-display">$0</span>
                  </div>
                  <input type="range" id="m-fin-down-slider"
                    min="0" max={Math.round(v.price * 0.5)} step="250"
                    value={Math.round(v.price * 0.10)}
                    class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-orange" />
                  <div class="flex justify-between text-xs text-gray-400 mt-1">
                    <span>$0</span><span>${Math.round(v.price * 0.5).toLocaleString()}</span>
                  </div>
                </div>
                <div class="mb-4">
                  <div class="flex justify-between items-center mb-2">
                    <label class="text-sm font-semibold text-gray-700">Interest Rate (APR)</label>
                    <span class="text-sm font-bold text-navy" id="m-fin-apr-display">9.9%</span>
                  </div>
                  <input type="range" id="m-fin-apr-slider"
                    min="3.9" max="24.9" step="0.5" value="9.9"
                    class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-orange" />
                  <div class="flex justify-between text-xs text-gray-400 mt-1">
                    <span>3.9%</span><span>24.9%</span>
                  </div>
                </div>
                <div class="mb-4">
                  <label class="text-sm font-semibold text-gray-700 block mb-2">Loan Term</label>
                  <div class="flex gap-2" id="m-fin-term-selector">
                    {[36, 48, 60, 72].map(t => (
                      <button data-term={t}
                        class:list={['m-fin-term-btn flex-1 py-2 rounded-lg text-sm font-bold border transition-all', t === 60 ? 'bg-navy text-white border-navy' : 'bg-white text-gray-600 border-gray-200 hover:border-navy']}>
                        {t}mo
                      </button>
                    ))}
                  </div>
                </div>
                <div class="bg-navy rounded-xl p-4 text-center mb-3">
                  <p class="text-white/60 text-xs mb-1">Estimated Monthly Payment</p>
                  <p class="text-3xl font-extrabold text-white" id="m-fin-result">--</p>
                  <p class="text-white/50 text-xs mt-1">Financed: <span id="m-fin-principal">--</span></p>
                </div>
                <p class="text-xs text-gray-400 mb-3">Estimates for illustration only. Actual terms depend on credit approval.</p>
                <a href={`${base}/apply`}
                   class="w-full flex items-center justify-center gap-2 bg-orange text-white py-3 rounded-xl font-bold text-sm hover:bg-orange-dark transition-colors">
                  <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">payments</span>
                  Get Pre-Approved
                </a>
              </div>
            </div>
          </div>

          <!-- History badges — shown first as top trust signal -->
          {historyBadges.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-5">
              <a href={`${base}/ship`} class="inline-flex items-center gap-1.5 bg-navy/5 text-navy border border-navy/15 px-3 py-1.5 rounded-full text-xs font-semibold hover:bg-navy/10 transition-colors">
                <span class="material-symbols-outlined text-xs text-navy" style="font-variation-settings:'FILL' 1;">local_shipping</span>
                Ships Nationwide
              </a>
              {historyBadges.map((badge: string) => (
                <span class="inline-flex items-center gap-1.5 bg-green-50 text-green-800 border border-green-100 px-3 py-1.5 rounded-full text-xs font-semibold">
                  <span class="material-symbols-outlined text-xs text-green-600" style="font-variation-settings:'FILL' 1;">check_circle</span>
                  {badge}
                </span>
              ))}
              {dealLabel && (
                <span class:list={['inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold border', dealColor]}>
                  <span class="material-symbols-outlined text-xs" style="font-variation-settings:'FILL' 1;">check_circle</span>
                  {dealLabel}
                </span>
              )}
            </div>
          )}

          <!-- Features & Specifications (unified section) -->
          <div class="mb-8">
            <h2 class="font-headline text-base font-bold text-navy mb-4">Features &amp; Specifications</h2>

            <!-- A. Features by category -->
            {v.features.length > 0 && (
              <div class="mb-6">
                {hasCategories ? (
                  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-2">
                    {featureCats.safety.length > 0 && (
                      <div>
                        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2 flex items-center gap-1">
                          <span class="material-symbols-outlined text-sm text-green-600">shield</span>Safety
                        </p>
                        <ul class="space-y-1.5">
                          {featureCats.safety.map((f: string) => (
                            <li class="flex items-center gap-2 text-sm text-gray-700">
                              <span class="material-symbols-outlined text-sm text-orange" style="font-variation-settings:'FILL' 1;">check_circle</span>{f}
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                    {featureCats.comfort.length > 0 && (
                      <div>
                        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2 flex items-center gap-1">
                          <span class="material-symbols-outlined text-sm text-blue-500">chair</span>Comfort
                        </p>
                        <ul class="space-y-1.5">
                          {featureCats.comfort.map((f: string) => (
                            <li class="flex items-center gap-2 text-sm text-gray-700">
                              <span class="material-symbols-outlined text-sm text-orange" style="font-variation-settings:'FILL' 1;">check_circle</span>{f}
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                    {(featureCats.tech.length > 0 || featureCats.other.length > 0) && (
                      <div>
                        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2 flex items-center gap-1">
                          <span class="material-symbols-outlined text-sm text-purple-500">devices</span>Technology
                        </p>
                        <ul class="space-y-1.5">
                          {[...featureCats.tech, ...featureCats.other].map((f: string) => (
                            <li class="flex items-center gap-2 text-sm text-gray-700">
                              <span class="material-symbols-outlined text-sm text-orange" style="font-variation-settings:'FILL' 1;">check_circle</span>{f}
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </div>
                ) : (
                  <div class="flex flex-wrap gap-2 mb-4">
                    {v.features.map((feat: string) => (
                      <span class="inline-flex items-center gap-1 bg-surface text-gray-700 px-3 py-1.5 rounded-full text-sm font-medium border border-gray-200">
                        <span class="material-symbols-outlined text-sm text-orange" style="font-variation-settings:'FILL' 1;">check_circle</span>{feat}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            )}

            <!-- B. Specifications table -->
            <div class="rounded-xl border border-gray-100 overflow-hidden mb-5">
              {[
                { label: 'Year', value: v.year },
                { label: 'Mileage', value: `${v.mileage.toLocaleString()} mi` },
                { label: 'Engine', value: v.engine },
                { label: 'Transmission', value: v.transmission },
                { label: 'Drivetrain', value: v.drivetrain },
                { label: 'Body Style', value: v.bodyStyle },
                { label: 'Fuel Type', value: v.fuelType },
                ...(mpg ? [{ label: 'Fuel Economy', value: mpg }] : []),
                { label: 'Ext. Color', value: v.exteriorColor },
                { label: 'Int. Color', value: v.interiorColor },
                { label: 'Trim', value: v.trim },
                { label: 'VIN', value: v.vin !== 'TBD' ? v.vin : 'Available on request' },
                { label: 'Stock #', value: stockNumber || 'Available on request' },
              ].map((spec, i) => (
                <div class:list={['flex items-center px-4 py-3 text-sm', i % 2 === 0 ? 'bg-white' : 'bg-surface']}>
                  <span class="text-gray-400 font-medium w-36 shrink-0">{spec.label}</span>
                  <span class="font-semibold text-gray-900">{spec.value}</span>
                </div>
              ))}
            </div>

            <!-- C. Description -->
            {description && (
              <p class="text-sm text-gray-600 leading-relaxed">{description}</p>
            )}
          </div>

          <!-- Inspection + CARFAX + Warranty -->
          <div class="mb-8 space-y-4">
            <div class="bg-green-50 border border-green-200 rounded-xl p-5 flex items-start gap-4">
              <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-2xl text-green-700" style="font-variation-settings:'FILL' 1;">verified</span>
              </div>
              <div>
                <h3 class="font-headline font-bold text-green-900 mb-1">Fully Inspected by Independent Mechanic</h3>
                <p class="text-green-800 text-sm mb-3">Inspection report included with purchase. Review every component before you buy.</p>
                <div class="grid grid-cols-2 gap-x-4 gap-y-1.5">
                  {['Engine & Drivetrain', 'Brakes & Suspension', 'Tires & Wheels', 'Electrical Systems', 'Interior & Exterior', 'Fluid Levels', 'Lights & Signals', 'Steering & Alignment'].map(item => (
                    <div class="flex items-center gap-1.5 text-xs text-green-800">
                      <span class="material-symbols-outlined text-xs text-green-600 shrink-0" style="font-variation-settings:'FILL' 1;">check_circle</span>{item}
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <div class="bg-blue-50 border border-blue-100 rounded-xl p-5 flex items-start gap-4">
              <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-2xl text-blue-700" style="font-variation-settings:'FILL' 1;">description</span>
