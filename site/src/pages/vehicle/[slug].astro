  #lightbox-counter {
    position: absolute; top: 1.125rem; left: 50%; transform: translateX(-50%);
    color: rgba(255,255,255,0.65); font-size: 0.875rem; font-weight: 600; pointer-events: none;
  }
  #lightbox-prev, #lightbox-next {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,0.12); border: none; border-radius: 50%;
    width: 3.25rem; height: 3.25rem;
    display: flex; align-items: center; justify-content: center;
    color: white; cursor: pointer; z-index: 10; transition: background 0.15s;
  }
  #lightbox-prev:hover, #lightbox-next:hover { background: rgba(255,255,255,0.25); }
  #lightbox-prev { left: 1rem; }
  #lightbox-next { right: 1rem; }
  #lightbox-prev .material-symbols-outlined,
  #lightbox-next .material-symbols-outlined { font-size: 2rem; }
