---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import VehicleCard from '../../components/VehicleCard.astro';
import vehicles from '../../data/vehicles.json';

export function getStaticPaths() {
  return vehicles.map(v => ({
    params: { slug: v.slug },
    props: { vehicle: v },
  }));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { vehicle } = Astro.props;
const v = vehicle;
const titleText = `${v.year} ${v.make} ${v.model} ${v.trim}`;
const pageTitle = `${titleText} for Sale in Skokie, IL`;
const pageDesc = `${titleText} with ${v.mileage.toLocaleString()} miles for $${v.price.toLocaleString()} at Maxim Autos in Skokie, IL. ${v.engine}, ${v.transmission}, ${v.drivetrain}. Fully inspected with free CARFAX and independent inspection report. Same-day metal plates.`;

const seoSuffix = 'maxim-autos-skokie-il';

// Build photo arrays — DealerCenter CDN or local paths
let allPhotos: string[];
let thumbPhotos: string[];

if (v.photoUrls?.length > 0) {
  allPhotos = v.photoUrls;
  thumbPhotos = v.photoUrls;
} else {
  const exteriorPhotos = Array.from({ length: v.photos?.exterior ?? 0 }, (_, i) => {
    const num = String(i + 1).padStart(2, '0');
    return `${base}/${v.photoPath}/web/${v.photoPrefix}-photo-exterior-${seoSuffix}-${num}.jpg`;
  });
  const interiorPhotos = Array.from({ length: v.photos?.interior ?? 0 }, (_, i) => {
    const num = String(i + 1).padStart(2, '0');
    return `${base}/${v.photoPath}/web/${v.photoPrefix}-photo-interior-${seoSuffix}-${num}.jpg`;
  });
  allPhotos = [...exteriorPhotos, ...interiorPhotos];
  thumbPhotos = allPhotos.map(p => p.replace('/web/', '/thumb/'));
}

const otherVehicles = vehicles.filter(o => o.slug !== v.slug).slice(0, 3);
const smsBody = encodeURIComponent(`Hi Jerry, I'm interested in the ${titleText} listed on MaximAutos.com.`);

// Static payment estimate for sidebar (10% down, 9.9% APR, 60 months)
const downPayment = Math.round(v.price * 0.10);
const principal = v.price - downPayment;
const monthlyRate = 0.099 / 12;
const numPayments = 60;
const monthlyPayment = Math.round(
  principal * (monthlyRate * Math.pow(1 + monthlyRate, numPayments)) /
  (Math.pow(1 + monthlyRate, numPayments) - 1)
);

const highlights: string[] = (v as any).highlights || [];
const description: string = (v as any).description || '';
const stockNumber: string = (v as any).stockNumber || '';

const faqs = [
  {
    q: `Is the ${v.year} ${v.make} ${v.model} reliable?`,
    a: `The ${v.year} ${v.make} ${v.model} is well-regarded for its reliability. This specific vehicle has been thoroughly inspected by an independent mechanic. The inspection report is included with your purchase so you can review every detail before buying.`
  },
  {
    q: `Is this ${v.make} ${v.model} inspected before sale?`,
    a: `Yes. This ${v.year} ${v.make} ${v.model} has been fully inspected by an independent mechanic. The detailed inspection report is included with your purchase so you can review every component before buying.`
  },
  {
    q: `Can I get financing for a used ${v.make} ${v.model}?`,
    a: `Yes. Maxim Autos offers financing for all credit levels, including first-time buyers and those rebuilding credit. Contact Jerry directly to discuss financing options for this ${titleText}. There are no hidden fees. What you see is what you pay.`
  },
  {
    q: `Does this ${v.make} ${v.model} come with a CARFAX report?`,
    a: `Yes. A free CARFAX vehicle history report is included with every vehicle at Maxim Autos. You can review the full history of this ${titleText} before making a decision. Ask Jerry for the report anytime.`
  },
  {
    q: `Can I drive this ${v.make} ${v.model} home the same day?`,
    a: `Yes. Maxim Autos issues metal license plates on the spot and handles DMV registration instantly. You can drive this ${titleText} home the same day you purchase it. No waiting for temporary plates or paperwork.`
  },
  {
    q: `How many miles does this ${v.year} ${v.make} ${v.model} have?`,
    a: `This ${titleText} currently has ${v.mileage.toLocaleString()} miles on the odometer. The ${v.engine} engine with ${v.transmission.toLowerCase()} transmission and ${v.drivetrain} drivetrain is well-suited for daily driving.`
  },
  {
    q: `Are there any hidden fees on this ${v.make} ${v.model}?`,
    a: `No. Maxim Autos uses transparent, upfront pricing. The listed price of $${v.price.toLocaleString()} is the price you pay, plus standard state tax, title, and license fees. There are no hidden charges.`
  },
  {
    q: `What features does this ${titleText} include?`,
    a: `This ${titleText} comes equipped with: ${v.features.join(', ')}. The ${v.trim} trim level includes the ${v.engine} engine, ${v.transmission.toLowerCase()} transmission, and ${v.drivetrain} drivetrain.`
  }
];

const vehicleSchema = {
  "@context": "https://schema.org",
  "@type": "Car",
  "name": titleText,
  "description": pageDesc,
  "brand": { "@type": "Brand", "name": v.make },
  "model": v.model,
  "vehicleModelDate": String(v.year),
  "mileageFromOdometer": { "@type": "QuantitativeValue", "value": v.mileage, "unitCode": "SMI" },
  "color": v.exteriorColor,
  "vehicleInteriorColor": v.interiorColor,
  "vehicleEngine": { "@type": "EngineSpecification", "name": v.engine },
  "vehicleTransmission": v.transmission,
  "driveWheelConfiguration": v.drivetrain,
  "fuelType": v.fuelType,
  "bodyType": v.bodyStyle,
  "itemCondition": "https://schema.org/UsedCondition",
  "offers": {
    "@type": "Offer",
    "price": v.price,
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "AutoDealer",
      "name": "Maxim Autos",
      "telephone": "+1-847-510-8947",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Skokie",
        "addressRegion": "IL",
        "postalCode": "60077",
        "addressCountry": "US"
      }
    }
  },
  "image": allPhotos.length > 0 ? allPhotos[0] : undefined,
  "url": `https://maximautos.com/vehicle/${v.slug}`
};

if (v.vin && v.vin !== "TBD") {
  (vehicleSchema as any).vehicleIdentificationNumber = v.vin;
}

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<Layout title={pageTitle} description={pageDesc} ogImage={allPhotos.length > 0 ? allPhotos[0] : undefined}>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(vehicleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://maximautos.com/" },
        { "@type": "ListItem", "position": 2, "name": "Inventory", "item": "https://maximautos.com/inventory" },
        { "@type": "ListItem", "position": 3, "name": titleText }
      ]
    })} />
  </Fragment>
  <Header slot="header" />

  <!-- Photo data for JS (XSS-safe JSON embed) -->
  <script id="photo-data" type="application/json" set:html={JSON.stringify(allPhotos)} />

  <!-- ===== 1. TITLE + PRICE + CTAs ===== -->
  <section class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-5">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-4">
        <a href={`${base}/`} class="hover:text-navy transition-colors">Home</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <a href={`${base}/inventory`} class="hover:text-navy transition-colors">Inventory</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <span class="text-navy font-medium">{titleText}</span>
      </nav>
      <!-- Title row -->
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-5">
        <div>
          <h1 class="font-headline text-2xl md:text-3xl font-extrabold text-navy leading-tight mb-1">{titleText}</h1>
          <p class="text-gray-500 text-sm">
            {v.trim} &bull; {v.mileage.toLocaleString()} mi &bull; {v.exteriorColor}{stockNumber && <span> &bull; Stock #{stockNumber}</span>}
          </p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-center gap-4 lg:shrink-0">
          <!-- Price block -->
          <div>
            <span class="text-4xl font-extrabold text-navy" data-vehicle-price={v.price}>${v.price.toLocaleString()}</span>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-sm font-bold text-orange" id="header-monthly-payment">${monthlyPayment}/mo est.*</span>
              <button class="tab-switch-btn inline-flex items-center gap-1 text-xs font-bold text-white bg-orange hover:bg-orange-dark transition-colors px-2.5 py-1 rounded-full" data-switch-tab="financing">
                <span class="material-symbols-outlined text-xs" style="font-size:13px">tune</span>
                Customize Payment
              </button>
            </div>
          </div>
          <!-- CTA buttons -->
          <div class="flex gap-3">
            <a href={`sms:8475108947&body=${smsBody}`}
               class="flex items-center justify-center gap-2 bg-orange text-white px-6 py-3 rounded-xl font-bold text-base hover:bg-orange-dark transition-colors shadow-sm">
              <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">sms</span>
              Text Jerry
            </a>
            <a href="tel:8475108947"
               class="flex items-center justify-center gap-2 bg-navy text-white px-6 py-3 rounded-xl font-bold text-base hover:bg-navy-light transition-colors">
              <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">call</span>
              Call
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 2. GALLERY ===== -->
  <section class="bg-gray-900">
    <div class="max-w-7xl mx-auto">
      {allPhotos.length > 0 ? (
        <div>
          {/* Desktop: 60/40 split — hidden on mobile */}
          <div class="gallery-desktop hidden md:grid">
            {/* Left: hero (60%) */}
            <div class="relative overflow-hidden cursor-pointer group" id="gallery-hero" data-index="0">
              <img
                src={allPhotos[0]}
                alt={`${titleText} for sale at Maxim Autos Skokie IL`}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
              />
              {v.inspected && (
                <div class="absolute top-3 left-3 bg-navy text-white text-xs font-bold px-2.5 py-1 rounded-md flex items-center gap-1">
                  <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">verified</span>
                  FULLY INSPECTED
                </div>
              )}
              <div class="absolute bottom-3 left-3 bg-black/60 text-white text-sm font-semibold px-3 py-1.5 rounded-md flex items-center gap-1.5">
                <span class="material-symbols-outlined text-base">photo_camera</span>
                {allPhotos.length} photos &bull; Click to view all
              </div>
            </div>
            {/* Right: 2x2 grid (40%) */}
            <div class="gallery-right">
              {[1, 2, 3, 4].map((idx) => {
                const src = allPhotos[idx] ?? allPhotos[0];
                const showOverlay = idx === 4 && allPhotos.length > 5;
                const moreCount = allPhotos.length - 5;
                return (
                  <div class="relative overflow-hidden cursor-pointer group gallery-thumb" data-index={idx}>
                    <img
                      src={src}
                      alt={`${titleText} photo ${idx + 1}`}
                      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.04]"
                      loading="lazy"
                    />
                    {showOverlay && (
                      <div class="absolute inset-0 bg-black/65 flex flex-col items-center justify-center text-white pointer-events-none">
                        <span class="text-3xl font-extrabold">+{moreCount}</span>
                        <span class="text-sm font-semibold mt-1">more photos</span>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </div>

          {/* Mobile: single hero + view all button */}
          <div class="md:hidden relative">
            <div class="relative cursor-pointer" id="gallery-hero-mobile">
              <img
                src={allPhotos[0]}
                alt={`${titleText} for sale at Maxim Autos Skokie IL`}
                class="w-full aspect-video object-cover"
              />
              {v.inspected && (
                <div class="absolute top-3 left-3 bg-navy text-white text-xs font-bold px-2.5 py-1 rounded-md flex items-center gap-1">
                  <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">verified</span>
                  FULLY INSPECTED
                </div>
              )}
            </div>
            {allPhotos.length > 1 && (
              <button
                id="view-all-btn"
                class="absolute bottom-3 right-3 bg-black/70 text-white text-sm font-semibold px-3 py-1.5 rounded-md flex items-center gap-1.5"
              >
                <span class="material-symbols-outlined text-base">photo_library</span>
                View all {allPhotos.length} photos
              </button>
            )}
          </div>
        </div>
      ) : (
        <div class="bg-gray-800 h-64 flex items-center justify-center">
          <div class="text-center text-gray-500">
            <span class="material-symbols-outlined text-6xl mb-2 block">no_photography</span>
            <p class="font-medium text-gray-400">Photos coming soon</p>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ===== 3. TABS ===== -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto">
      <!-- Sticky tab nav with Text Jerry CTA on right (desktop) -->
      <div class="sticky top-[73px] z-30 bg-white border-b border-gray-200 flex items-center justify-between" id="tab-nav">
        <div class="flex overflow-x-auto" role="tablist" style="-ms-overflow-style:none;scrollbar-width:none;">
          <button class="tab-btn tab-active" data-tab="overview" role="tab" aria-selected="true">Overview</button>
          <button class="tab-btn" data-tab="specs" role="tab" aria-selected="false">Features &amp; Specs</button>
          <button class="tab-btn" data-tab="history" role="tab" aria-selected="false">History &amp; Inspection</button>
          <button class="tab-btn" data-tab="financing" role="tab" aria-selected="false">Financing</button>
        </div>
      </div>

      <!-- Tab content area -->
      <div class="px-6 lg:px-8 py-8">

        <!-- OVERVIEW TAB -->
        <div class="tab-panel" data-panel="overview">
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2">
              {highlights.length > 0 && (
                <div class="mb-6">
                  <h2 class="font-headline text-base font-bold text-navy mb-3">Highlights</h2>
                  <div class="flex flex-wrap gap-2">
                    {highlights.map((h: string) => (
                      <span class="inline-flex items-center gap-1.5 bg-green-50 text-green-800 border border-green-100 px-3 py-1.5 rounded-full text-sm font-semibold">
                        <span class="material-symbols-outlined text-sm text-green-600" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                        {h}
                      </span>
                    ))}
                  </div>
                </div>
              )}

              <h2 class="font-headline text-base font-bold text-navy mb-3">Quick Specs</h2>
              <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-6">
                {[
                  { label: 'Year', value: String(v.year) },
                  { label: 'Mileage', value: `${v.mileage.toLocaleString()} mi` },
                  { label: 'Engine', value: v.engine },
                  { label: 'Transmission', value: v.transmission },
                  { label: 'Drivetrain', value: v.drivetrain },
                  { label: 'Body Style', value: v.bodyStyle },
                ].map(spec => (
                  <div class="bg-surface rounded-lg p-3">
                    <p class="text-xs text-gray-400 uppercase tracking-wider font-semibold mb-0.5">{spec.label}</p>
                    <p class="text-sm font-bold text-gray-900">{spec.value}</p>
                  </div>
                ))}
              </div>

              {description && (
                <div class="mb-5">
                  <h3 class="font-headline text-base font-bold text-navy mb-2">About This Vehicle</h3>
                  <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
                </div>
              )}

              <div class="flex flex-wrap gap-2 pt-4 border-t border-gray-100">
                {[
                  { icon: 'description', color: 'bg-blue-50 text-blue-700', label: 'Free CARFAX' },
                  { icon: 'verified', color: 'bg-green-50 text-green-700', label: 'Fully Inspected' },
                  { icon: 'local_shipping', color: 'bg-purple-50 text-purple-700', label: 'Drive Home Today' },
                  { icon: 'sell', color: 'bg-blue-50 text-blue-700', label: 'No Hidden Fees' },
                ].map(b => (
                  <span class:list={['inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold', b.color]}>
                    <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">{b.icon}</span>
                    {b.label}
                  </span>
                ))}
              </div>
            </div>

            <div class="lg:col-span-1 space-y-4">
              <!-- Trust signals -->
              <div class="bg-surface rounded-xl p-5">
                <h3 class="font-headline font-bold text-navy text-sm mb-4">The Maxim Autos Difference</h3>
                <div class="space-y-3">
                  {[
                    { icon: 'shield', color: 'text-green-600', label: 'Fully Inspected', sub: 'Independent mechanic report included' },
                    { icon: 'description', color: 'text-blue-600', label: 'Free CARFAX Report', sub: 'Full vehicle history included' },
                    { icon: 'directions_car', color: 'text-orange', label: 'Drive Home Today', sub: 'Metal plates on the spot. Skip the DMV.' },
                    { icon: 'sell', color: 'text-yellow-600', label: 'No Hidden Fees', sub: 'Transparent upfront pricing' },
                  ].map(item => (
                    <div class="flex items-center gap-3">
                      <span class:list={['material-symbols-outlined text-xl shrink-0', item.color]} style="font-variation-settings: 'FILL' 1;">{item.icon}</span>
                      <div>
                        <p class="font-semibold text-sm text-gray-900">{item.label}</p>
                        <p class="text-xs text-gray-500">{item.sub}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
              <!-- CTA card -->
              <div class="bg-navy rounded-xl p-5 text-center">
                <p class="text-white/60 text-xs mb-3">Mon/Tue/Thu/Fri 3–7pm · Sat 10am–3pm · After-hours? Text anytime.</p>
                <a href={`sms:8475108947&body=${smsBody}`}
                   class="w-full flex items-center justify-center gap-2 bg-orange text-white py-3 rounded-lg font-bold text-base hover:bg-orange-dark transition-colors mb-2">
                  <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">sms</span>
                  Text Jerry
                </a>
                <a href="tel:8475108947"
                   class="w-full flex items-center justify-center gap-2 bg-white/10 text-white py-3 rounded-lg font-bold text-base hover:bg-white/20 transition-colors mb-2">
                  <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">call</span>
                  (847) 510-8947
                </a>
                <a href={`${base}/apply`}
                   class="w-full flex items-center justify-center gap-2 border border-orange/70 text-orange py-3 rounded-lg font-bold text-base hover:bg-orange hover:text-white hover:border-orange transition-colors">
                  <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">payments</span>
                  Apply for Financing
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- FEATURES & SPECS TAB -->
        <div class="tab-panel hidden" data-panel="specs">
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2">
              <h2 class="font-headline text-base font-bold text-navy mb-4">Vehicle Specifications</h2>
              <div class="grid grid-cols-2 gap-y-4 gap-x-6 mb-8">
                {[
                  { label: 'Year', value: v.year },
                  { label: 'Make', value: v.make },
                  { label: 'Model', value: v.model },
                  { label: 'Trim', value: v.trim },
                  { label: 'Mileage', value: `${v.mileage.toLocaleString()} mi` },
                  { label: 'Engine', value: v.engine },
                  { label: 'Transmission', value: v.transmission },
                  { label: 'Drivetrain', value: v.drivetrain },
                  { label: 'Fuel Type', value: v.fuelType },
                  { label: 'Body Style', value: v.bodyStyle },
                  { label: 'Ext. Color', value: v.exteriorColor },
                  { label: 'Int. Color', value: v.interiorColor },
                  { label: 'VIN', value: v.vin !== 'TBD' ? v.vin : 'Available on request' },
                  { label: 'Stock #', value: stockNumber || 'Available on request' },
                ].map(spec => (
                  <div class="border-b border-gray-100 pb-3">
                    <p class="text-xs text-gray-400 uppercase tracking-wider font-semibold mb-0.5">{spec.label}</p>
                    <p class="text-sm font-semibold text-gray-900">{spec.value}</p>
                  </div>
                ))}
              </div>
              {v.features.length > 0 && (
                <div>
                  <h2 class="font-headline text-base font-bold text-navy mb-4">Features &amp; Equipment</h2>
                  <div class="flex flex-wrap gap-2">
                    {v.features.map((feat: string) => (
                      <span class="inline-flex items-center gap-1 bg-surface text-gray-700 px-3 py-1.5 rounded-full text-sm font-medium border border-gray-200">
                        <span class="material-symbols-outlined text-sm text-orange" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                        {feat}
                      </span>
                    ))}
                  </div>
                </div>
              )}
            </div>
            <div class="lg:col-span-1">
              <div class="lg:sticky lg:top-[130px] bg-surface rounded-xl p-5 text-center border border-gray-200">
                <p class="text-sm text-gray-500 mb-3">Questions about this vehicle?</p>
                <a href={`sms:8475108947&body=${smsBody}`}
                   class="w-full flex items-center justify-center gap-2 bg-navy text-white py-3 rounded-lg font-bold text-sm hover:bg-navy-light transition-colors mb-2">
                  <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">sms</span>
                  Text (847) 510-8947
                </a>
                <a href="tel:8475108947"
                   class="w-full flex items-center justify-center gap-2 bg-white text-navy py-3 rounded-lg font-bold text-sm hover:bg-gray-50 transition-colors border border-gray-200">
                  <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">call</span>
                  Call Jerry
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- HISTORY & INSPECTION TAB -->
        <div class="tab-panel hidden" data-panel="history">
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2">
              <div class="bg-green-50 border border-green-200 rounded-xl p-5 mb-6 flex items-start gap-4">
                <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center shrink-0">
                  <span class="material-symbols-outlined text-3xl text-green-700" style="font-variation-settings: 'FILL' 1;">verified</span>
                </div>
                <div>
