    transition: background 0.15s;
  }
  #lightbox-prev:hover, #lightbox-next:hover { background: rgba(255,255,255,0.25); }
  #lightbox-prev { left: 1rem; }
  #lightbox-next { right: 1rem; }
  #lightbox-prev .material-symbols-outlined,
  #lightbox-next .material-symbols-outlined { font-size: 2rem; }
</style>

<script is:inline>
(function () {
  // Photo array from embedded JSON
  var photoDataEl = document.getElementById('photo-data');
  var photos = photoDataEl ? JSON.parse(photoDataEl.textContent) : [];
  var currentIndex = 0;

  // === LIGHTBOX ===
  var lightbox = document.getElementById('lightbox');
  var lightboxImg = document.getElementById('lightbox-img');
  var lightboxCounter = document.getElementById('lightbox-counter');

  function updateLightbox(index) {
    currentIndex = index;
    if (lightboxImg) lightboxImg.src = photos[index];
    if (lightboxCounter) lightboxCounter.textContent = (index + 1) + ' / ' + photos.length;
  }

  function openLightbox(index) {
    if (!lightbox || !photos.length) return;
    updateLightbox(index);
    lightbox.showModal();
  }

  // Gallery hero (desktop) click
  var galleryHero = document.getElementById('gallery-hero');
  if (galleryHero) {
    galleryHero.addEventListener('click', function () { openLightbox(0); });
  }

  // Gallery thumbnails (desktop right grid) clicks
  document.querySelectorAll('.gallery-thumb').forEach(function (el) {
    el.addEventListener('click', function () {
      openLightbox(parseInt(el.dataset.index, 10));
    });
  });

  // Mobile hero click
  var mobileHero = document.getElementById('gallery-hero-mobile');
  if (mobileHero) {
    mobileHero.addEventListener('click', function () { openLightbox(0); });
  }

  // Mobile "view all" button
  var viewAllBtn = document.getElementById('view-all-btn');
  if (viewAllBtn) {
    viewAllBtn.addEventListener('click', function () { openLightbox(0); });
  }

  var lightboxClose = document.getElementById('lightbox-close');
  var lightboxPrev = document.getElementById('lightbox-prev');
  var lightboxNext = document.getElementById('lightbox-next');

  if (lightboxClose) lightboxClose.addEventListener('click', function () { lightbox.close(); });
  if (lightboxPrev) lightboxPrev.addEventListener('click', function () { updateLightbox((currentIndex - 1 + photos.length) % photos.length); });
  if (lightboxNext) lightboxNext.addEventListener('click', function () { updateLightbox((currentIndex + 1) % photos.length); });

  if (lightbox) {
    lightbox.addEventListener('click', function (e) { if (e.target === lightbox) lightbox.close(); });
    lightbox.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft') updateLightbox((currentIndex - 1 + photos.length) % photos.length);
      if (e.key === 'ArrowRight') updateLightbox((currentIndex + 1) % photos.length);
    });
  }

  // === TABS ===
  var tabBtns = document.querySelectorAll('.tab-btn');
  var tabPanels = document.querySelectorAll('.tab-panel');

  function switchTab(name) {
    tabBtns.forEach(function (btn) {
      var active = btn.dataset.tab === name;
      btn.classList.toggle('tab-active', active);
      btn.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    tabPanels.forEach(function (panel) {
      panel.classList.toggle('hidden', panel.dataset.panel !== name);
    });
  }

  tabBtns.forEach(function (btn) {
    btn.addEventListener('click', function () { switchTab(btn.dataset.tab); });
  });

  // "Customize" → switch to Financing tab + scroll to tabs
  document.querySelectorAll('.tab-switch-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      switchTab(btn.dataset.switchTab);
      var tabNav = document.getElementById('tab-nav');
      if (tabNav) tabNav.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // === PAYMENT CALCULATOR (Financing tab) ===
  (function () {
    var price = parseFloat(document.querySelector('[data-vehicle-price]').dataset.vehiclePrice || 0);
    var downSlider = document.getElementById('fin-down-slider');
    var aprSlider = document.getElementById('fin-apr-slider');
    var termSel = document.getElementById('fin-term-selector');
    var downDisp = document.getElementById('fin-down-display');
    var aprDisp = document.getElementById('fin-apr-display');
    var resultEl = document.getElementById('fin-result');
    var principalEl = document.getElementById('fin-principal');
    var activeTerm = 60;

    function calc(p, d, apr, n) {
      var principal = p - d;
      if (principal <= 0) return 0;
      var r = (apr / 100) / 12;
      if (r === 0) return Math.round(principal / n);
      return Math.round(principal * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1));
    }

    function update() {
      if (!downSlider || !aprSlider) return;
      var d = parseFloat(downSlider.value);
      var apr = parseFloat(aprSlider.value);
      var payment = calc(price, d, apr, activeTerm);
      if (downDisp) downDisp.textContent = '$' + Math.round(d).toLocaleString();
      if (aprDisp) aprDisp.textContent = apr.toFixed(1) + '%';
      if (resultEl) resultEl.textContent = '$' + payment + '/mo';
      if (principalEl) principalEl.textContent = '$' + Math.round(price - d).toLocaleString();
      // Keep header payment estimate in sync
      var headerPayment = document.getElementById('header-monthly-payment');
      if (headerPayment) headerPayment.textContent = '$' + payment + '/mo*';
    }

    if (downSlider) { downSlider.value = Math.round(price * 0.10); downSlider.addEventListener('input', update); }
    if (aprSlider) aprSlider.addEventListener('input', update);
    if (termSel) {
      termSel.addEventListener('click', function (e) {
        var btn = e.target.closest('.fin-term-btn');
        if (!btn) return;
        activeTerm = parseInt(btn.dataset.term);
        termSel.querySelectorAll('.fin-term-btn').forEach(function (b) {
          var a = b.dataset.term == activeTerm;
          b.classList.toggle('bg-navy', a); b.classList.toggle('text-white', a); b.classList.toggle('border-navy', a);
          b.classList.toggle('bg-white', !a); b.classList.toggle('text-gray-600', !a); b.classList.toggle('border-gray-200', !a);
        });
        update();
      });
    }
    update();
  })();

  // === FAQ ACCORDION ===
  var faqList = document.getElementById('faq-list');
  if (faqList) {
    faqList.addEventListener('click', function (e) {
      var toggle = e.target.closest('.faq-toggle');
      if (!toggle) return;
      var item = toggle.closest('.faq-item');
      var answer = item.querySelector('.faq-answer');
      var icon = toggle.querySelector('.faq-icon');
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      answer.classList.toggle('hidden', expanded);
      icon.style.transform = expanded ? '' : 'rotate(180deg)';
    });
  }
})();
</script>
