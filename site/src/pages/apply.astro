    vertical-align: middle;
  }
  .app-badge--req { background: rgba(240,128,16,0.14); color: #b45309; }
  .app-badge--opt { background: #f3f4f6; color: #6b7280; }
  .app-section-title .app-badge { margin-left: 0.375rem; }
  .app-grid {
    display: grid;
