---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Sell Your Car or Trade In — Maxim Autos Skokie, IL';
const description = 'Sell your car or trade it in at Maxim Autos in Skokie, IL. Text Jerry your VIN for a quick offer. No obligation, fast response.';
---

<Layout title={title} description={description}>
  <Header slot="header" />

  <!-- Hero -->
  <section class="bg-navy py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Sell or Trade</span>
      <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
        Sell Your Car or Trade It In
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
        Text Jerry your VIN for a quick offer. No obligation.
      </p>
      <div class="mt-10">
        <a href="sms:8475108947&body=Hi Jerry, I'd like to get an offer on my vehicle. VIN: " class="inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors shadow-lg shadow-orange/20">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">sms</span>
          Text Your VIN to Jerry
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold">How It Works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { step: '1', title: 'Send Your Info', text: 'Submit the form below or text Jerry your vehicle details. A VIN gets you the fastest offer.', icon: 'send' },
          { step: '2', title: 'Get an Offer', text: 'Jerry reviews your vehicle info and responds with a fair, no-obligation offer. Usually the same day.', icon: 'price_check' },
          { step: '3', title: 'Sell or Trade', text: 'Accept the offer and get paid, or apply the value toward your next vehicle at Maxim Autos.', icon: 'handshake' },
        ].map(item => (
          <div class="text-center">
            <div class="w-14 h-14 bg-orange rounded-2xl flex items-center justify-center mx-auto mb-5">
              <span class="text-white font-headline font-extrabold text-xl">{item.step}</span>
            </div>
            <h3 class="font-headline text-lg font-bold mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Form -->
  <section class="py-20 bg-surface">
    <div class="max-w-2xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-4">Get Your Offer</h2>
        <p class="text-gray-600 text-lg">Fill out the form or text Jerry directly for the fastest response.</p>
      </div>

      <!-- TODO: Replace YOUR_SELLTRADE_FORM_ID with your Formspree form ID from formspree.io -->
      <form id="sell-trade-form" action="https://formspree.io/f/YOUR_SELLTRADE_FORM_ID" method="POST" class="space-y-6 bg-white p-8 rounded-2xl border border-gray-200">
        <input type="hidden" name="_subject" value="Sell/Trade Inquiry — Maxim Autos" />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="sell-name" class="block text-sm font-medium text-gray-700 mb-2">Name</label>
            <input
              type="text"
              id="sell-name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="sell-phone" class="block text-sm font-medium text-gray-700 mb-2">Phone</label>
            <input
              type="tel"
              id="sell-phone"
              name="phone"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="(555) 555-5555"
            />
          </div>
        </div>
        <div>
          <label for="sell-ymm" class="block text-sm font-medium text-gray-700 mb-2">Year / Make / Model</label>
          <input
            type="text"
            id="sell-ymm"
            name="year_make_model"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
            placeholder="e.g. 2019 Honda Civic"
          />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="sell-mileage" class="block text-sm font-medium text-gray-700 mb-2">Mileage</label>
            <input
              type="text"
              id="sell-mileage"
              name="mileage"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="e.g. 45,000"
            />
          </div>
          <div>
            <label for="sell-vin" class="block text-sm font-medium text-gray-700 mb-2">VIN <span class="text-gray-400">(optional)</span></label>
            <input
              type="text"
              id="sell-vin"
              name="vin"
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="17 characters"
            />
          </div>
        </div>
        <div>
          <label for="sell-condition" class="block text-sm font-medium text-gray-700 mb-2">Condition</label>
          <select
            id="sell-condition"
            name="condition"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
          >
            <option value="" disabled selected>Select condition</option>
            <option value="excellent">Excellent, no issues</option>
            <option value="good">Good, minor cosmetic wear</option>
            <option value="fair">Fair, needs some work</option>
            <option value="poor">Poor, significant issues</option>
          </select>
        </div>
        <button
          type="submit"
          class="w-full bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors flex items-center justify-center gap-2"
        >
          <span class="material-symbols-outlined">send</span>
          Submit for Offer
        </button>
        <p class="text-xs text-gray-400 text-center">No obligation. Jerry will follow up with an offer, usually the same day.</p>
      </form>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<script is:inline>
(function () {
  var form = document.getElementById('sell-trade-form');
  if (!form) return;
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    // Formspree not yet configured — route to SMS
    if (form.action.includes('YOUR_')) {
      var name = (document.getElementById('sell-name').value || '').trim();
      var ymm = (document.getElementById('sell-ymm').value || '').trim();
      var mileage = (document.getElementById('sell-mileage').value || '').trim();
      var body = encodeURIComponent('Hi Jerry, I\'m ' + (name || 'a visitor') + ' looking to sell/trade my ' + ymm + ' with ' + mileage + ' miles.');
      window.location.href = 'sms:8475108947&body=' + body;
      return;
    }
    var btn = form.querySelector('button[type="submit"]');
    var origText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="material-symbols-outlined">sync</span> Submitting...';
    fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    }).then(function (res) {
      if (res.ok) {
        form.innerHTML = '<div class="text-center py-12"><span class="material-symbols-outlined text-5xl text-green-500 mb-4 block" style="font-variation-settings:\'FILL\' 1;">check_circle</span><h3 class="font-headline text-xl font-bold text-navy mb-2">Offer Request Sent!</h3><p class="text-gray-600 mb-4">Jerry will review your vehicle info and respond with an offer, usually the same day.</p><a href="sms:8475108947&body=Hi Jerry, I just submitted a vehicle for an offer on your website." class="inline-flex items-center gap-2 bg-orange text-white px-6 py-3 rounded-xl font-bold hover:bg-orange-dark transition-colors"><span class="material-symbols-outlined" style="font-variation-settings:\'FILL\' 1;">sms</span>Text Jerry to Follow Up</a></div>';
      } else {
        btn.disabled = false;
        btn.innerHTML = origText;
        alert('Something went wrong. Please text Jerry directly at (847) 510-8947.');
      }
    }).catch(function () {
      btn.disabled = false;
      btn.innerHTML = origText;
      alert('Something went wrong. Please text Jerry directly at (847) 510-8947.');
    });
  });
})();
</script>
