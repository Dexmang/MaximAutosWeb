---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = 'Peace of Mind Warranty | Maxim Autos';
const description = '3-Month / 4,500-Mile Peace of Mind Warranty included with every vehicle at Maxim Autos. Covers major mechanical components. See full coverage terms.';
const effectiveDate = 'April 16, 2026';
---

<Layout title={title} description={description}>
  <Header slot="header" />

  <!-- Hero -->
  <section class="bg-navy py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Every Vehicle. Every Time.</span>
      <h1 class="font-headline text-4xl md:text-5xl font-extrabold text-white leading-tight tracking-tight mb-6">
        3-Month / 4,500-Mile Peace of Mind Warranty
      </h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto leading-relaxed">
        Included with every retail vehicle sale, unless buyer signs a separate written AS-IS acknowledgment.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="space-y-10 text-gray-700 leading-relaxed text-base">

        <!-- Supersedes AS-IS notice -->
        <div class="p-5 bg-orange/10 border-l-4 border-orange rounded-r-xl">
          <p class="font-bold text-navy mb-2">Important — This Warranty Supersedes the AS-IS Clause in Our Terms of Use</p>
          <p class="text-sm text-gray-700">
            Every retail vehicle sold by Maxim Autos includes this 3-Month / 4,500-Mile Peace of Mind Warranty as part of the sale, at no additional charge. This warranty takes precedence over any AS-IS language in our Terms of Use, unless the buyer and Maxim Autos execute a separate signed written AS-IS agreement at the point of sale, in which case the signed agreement controls.
          </p>
        </div>

        <!-- Coverage -->
        <div>
          <h2 class="font-headline text-2xl font-extrabold text-navy mb-4 pb-2 border-b border-gray-100">
            What Is Covered
          </h2>
          <p class="mb-4">Coverage begins on the date of sale and continues for <strong>90 days or 4,500 miles driven from delivery mileage, whichever occurs first.</strong> The warranty covers failure of the following major mechanical components caused by normal use:</p>
          <ul class="space-y-3 pl-4">
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-orange shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">check_circle</span>
              <span><strong>Engine:</strong> internally lubricated parts, cylinder block, cylinder head, pistons, crankshaft, camshaft, timing gears and chain, oil pump.</span>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-orange shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">check_circle</span>
              <span><strong>Transmission:</strong> automatic or manual transmission case, internal gears, torque converter, valve body, transfer case internal parts.</span>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-orange shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">check_circle</span>
              <span><strong>Drive axle:</strong> internally lubricated differential parts, axle shafts, CV joints, drive shafts.</span>
            </li>
          </ul>
        </div>

        <!-- Not covered -->
        <div>
          <h2 class="font-headline text-2xl font-extrabold text-navy mb-4 pb-2 border-b border-gray-100">
            What Is Not Covered
          </h2>
          <ul class="space-y-3 pl-4">
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-gray-400 shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">cancel</span>
              <span>Wear items: brakes, pads, rotors, tires, wipers, belts, hoses, batteries, bulbs, filters, spark plugs.</span>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-gray-400 shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">cancel</span>
              <span>Electrical, electronic, and computer components not listed in the "What Is Covered" section.</span>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-gray-400 shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">cancel</span>
              <span>Air conditioning, heating, and climate control components.</span>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-gray-400 shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">cancel</span>
              <span>Cosmetic items: paint, trim, upholstery, dashboard cracks, glass, weather stripping.</span>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-gray-400 shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">cancel</span>
              <span>Damage from misuse, racing, off-road use, collision, flood, fire, or lack of required maintenance.</span>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-gray-400 shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">cancel</span>
              <span>Pre-existing conditions disclosed in the CARFAX report, inspection report, or point-of-sale documentation.</span>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-gray-400 shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">cancel</span>
              <span>Towing, rental car costs, lodging, lost wages, or incidental and consequential damages.</span>
            </li>
          </ul>
        </div>

        <!-- How to claim -->
        <div>
          <h2 class="font-headline text-2xl font-extrabold text-navy mb-4 pb-2 border-b border-gray-100">
            How to Make a Claim
          </h2>
          <ol class="space-y-4 pl-4 list-decimal list-outside ml-4">
            <li><strong>Stop driving the vehicle</strong> if continuing to operate it could cause further damage. Continuing to drive after a failure may void coverage for any resulting additional damage.</li>
            <li><strong>Contact us before any repair begins.</strong> Call or text Jerry at <a href="tel:8475108947" class="text-orange font-bold hover:underline">(847) 510-8947</a>. Repairs started without prior authorization may not be covered.</li>
            <li><strong>Bring the vehicle to Maxim Autos</strong> or to an authorized repair facility we designate. In most cases we will handle the diagnosis and repair at our shop or a partner facility within the Chicago area.</li>
            <li><strong>Provide documentation:</strong> your bill of sale, odometer reading at the time of failure, and a description of the problem.</li>
          </ol>
        </div>

        <!-- Cost -->
        <div>
          <h2 class="font-headline text-2xl font-extrabold text-navy mb-4 pb-2 border-b border-gray-100">
            Your Cost
          </h2>
          <div class="p-5 bg-surface rounded-xl border border-gray-100">
            <p class="mb-2"><strong>Deductible:</strong> $0 per covered claim when repaired at Maxim Autos or an authorized partner facility.</p>
            <p class="mb-2"><strong>Outside repair facility:</strong> if you choose an outside facility without prior written authorization, reimbursement is limited to the amount Maxim Autos would have paid for the same repair, subject to receipt of itemized invoice and approval.</p>
            <p><strong>Maximum coverage per claim:</strong> actual cash value of the vehicle at time of failure.</p>
          </div>
        </div>

        <!-- Transferability -->
        <div>
          <h2 class="font-headline text-2xl font-extrabold text-navy mb-4 pb-2 border-b border-gray-100">
            Transferability and Term
          </h2>
          <p class="mb-3">This warranty is <strong>non-transferable</strong> and applies only to the original retail buyer of record on the bill of sale. The warranty terminates automatically upon any of the following:</p>
          <ul class="space-y-2 pl-4">
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-gray-400 shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">chevron_right</span>
              <span>90 days from date of sale, or 4,500 miles driven from delivery mileage, whichever occurs first.</span>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-gray-400 shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">chevron_right</span>
              <span>Sale, trade, or transfer of ownership of the vehicle.</span>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-gray-400 shrink-0 mt-0.5" style="font-variation-settings:'FILL' 1; font-size:1.1rem;">chevron_right</span>
              <span>Odometer tampering, disconnection, or replacement without notification.</span>
            </li>
          </ul>
        </div>

        <!-- Implied warranties -->
        <div>
          <h2 class="font-headline text-2xl font-extrabold text-navy mb-4 pb-2 border-b border-gray-100">
            Implied Warranties and State Law
          </h2>
          <p class="mb-3">This written warranty gives you specific legal rights. You may also have other rights which vary from state to state. Some states do not allow limitations on how long an implied warranty lasts, so the above limitation may not apply to you. Nothing in this warranty limits your rights under the <strong>federal Magnuson-Moss Warranty Act</strong> (15 U.S.C. § 2301) or the <strong>Illinois Consumer Fraud and Deceptive Business Practices Act</strong> (815 ILCS 505/).</p>
          <p>This warranty is classified as a <strong>Limited Warranty</strong> under Magnuson-Moss. The written terms above govern. No verbal representation by any sales representative creates a warranty obligation beyond what is written here.</p>
        </div>

        <!-- Contact -->
        <div>
          <h2 class="font-headline text-2xl font-extrabold text-navy mb-4 pb-2 border-b border-gray-100">
            Questions or Claims
          </h2>
          <div class="p-5 bg-surface rounded-xl border border-gray-100">
            <p class="font-bold text-gray-900 mb-1">Maxim Autos</p>
            <p class="text-gray-600">9101 Terminal Ave, Skokie, IL 60077</p>
            <p class="text-gray-600">Phone or Text: <a href="tel:8475108947" class="text-orange font-bold hover:underline">(847) 510-8947</a></p>
            <p class="text-gray-600">Email: <a href="mailto:jerryf@maximautos.com" class="text-orange font-bold hover:underline">jerryf@maximautos.com</a></p>
          </div>
          <p class="mt-4 text-sm text-gray-500">Effective Date: {effectiveDate}. Maxim Autos reserves the right to update this warranty for future sales. The warranty in effect on the date of your sale governs your vehicle.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-surface">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="font-headline text-2xl md:text-3xl font-extrabold mb-4">Ready to Find Your Car?</h2>
      <p class="text-gray-600 text-lg mb-8">Every vehicle on the lot is covered by this warranty.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href={`${base}/inventory`} class="inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors">
          Browse Inventory
        </a>
        <a href={`${base}/contact`} class="inline-flex items-center justify-center gap-2 bg-navy text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-navy-light transition-colors">
          Contact Jerry
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
