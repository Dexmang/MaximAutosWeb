---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = 'Used Car Financing in Skokie, IL | All Credit Levels | Maxim Autos';
const description = 'Financing for all credit levels at Maxim Autos in Skokie, IL. First-time buyers, rebuilding credit, all welcome. No credit check to browse. Apply in minutes.';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Can I get financing with bad credit?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Maxim Autos works with multiple lenders to find financing for all credit levels, including those rebuilding credit. We welcome first-time buyers and buyers with challenged credit." } },
    { "@type": "Question", "name": "How much down payment do I need?", "acceptedAnswer": { "@type": "Answer", "text": "Down payment requirements vary by lender and credit situation. Text Jerry at (847) 510-8947 to discuss your specific situation. There is no obligation." } },
    { "@type": "Question", "name": "Does applying affect my credit score?", "acceptedAnswer": { "@type": "Answer", "text": "Browsing inventory has no impact on your credit score. A formal credit application involves a soft or hard inquiry depending on the lender. The pre-qualification form on this page is not a credit application." } },
    { "@type": "Question", "name": "What interest rates are available?", "acceptedAnswer": { "@type": "Answer", "text": "Rates vary by lender, credit profile, and loan term. Maxim Autos works with multiple lenders to find the best available rate for your situation. The payment calculator on each vehicle listing shows estimated payments across different rates." } },
    { "@type": "Question", "name": "Can I get financing as a first-time buyer?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Maxim Autos specifically works with lenders who approve first-time buyers. There is no credit history requirement to apply." } }
  ]
};
---

<Layout title={title} description={description}>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.maximautos.com/" },
        { "@type": "ListItem", "position": 2, "name": "Financing", "item": "https://www.maximautos.com/financing" }
      ]
    })} />
  </Fragment>
  <Header slot="header" />

  <!-- Hero -->
  <section class="bg-navy py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Financing</span>
      <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
        Financing for All Credit Levels
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
        First-time buyer? Rebuilding credit? No problem. Maxim Autos works with multiple lenders to find you the best rate.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}/apply`} class="inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors shadow-lg shadow-orange/20">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">payments</span>
          Full Credit Application
        </a>
        <a href="#apply" class="inline-flex items-center justify-center gap-2 bg-white/10 border border-white/30 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/20 transition-colors">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">edit_note</span>
          Quick Pre-Qualify
        </a>
      </div>
    </div>
  </section>

  <!-- Payment Calculator -->
  <section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Estimate Your Payment</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold">Payment Calculator</h2>
        <p class="text-gray-500 mt-2">Adjust the numbers to see your estimated monthly payment.</p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <!-- Calculator -->
        <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
          <div class="space-y-5">
            <div>
              <label for="calc-price" class="block text-sm font-semibold text-gray-700 mb-2">Vehicle Price</label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-bold">$</span>
                <input type="number" id="calc-price" value="12000" min="1000" max="50000" step="500"
                  class="w-full pl-8 pr-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900" />
              </div>
            </div>
            <div>
              <label for="calc-down" class="block text-sm font-semibold text-gray-700 mb-2">Down Payment</label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-bold">$</span>
                <input type="number" id="calc-down" value="0" min="0" max="20000" step="500"
                  class="w-full pl-8 pr-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900" />
              </div>
            </div>
            <div>
              <label for="calc-term" class="block text-sm font-semibold text-gray-700 mb-2">Loan Term</label>
              <select id="calc-term"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900">
                <option value="36">36 months (3 years)</option>
                <option value="48">48 months (4 years)</option>
                <option value="60" selected>60 months (5 years)</option>
                <option value="72">72 months (6 years)</option>
              </select>
            </div>
            <div>
              <label for="calc-apr" class="block text-sm font-semibold text-gray-700 mb-2">Est. APR</label>
              <div class="relative">
                <input type="number" id="calc-apr" value="9.9" min="0" max="30" step="0.1"
                  class="w-full pl-4 pr-8 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900" />
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 font-bold">%</span>
              </div>
            </div>
          </div>
          <!-- Result -->
          <div class="mt-6 bg-navy rounded-2xl p-6 text-center">
            <p class="text-gray-400 text-sm mb-1">Estimated Monthly Payment</p>
            <p class="font-headline text-5xl font-extrabold text-white" id="calc-result">$227</p>
            <p class="text-gray-400 text-xs mt-2">*Estimate only. Actual rate and terms vary by credit and lender.</p>
          </div>
          <a href={`${base}/apply`}
            class="mt-5 w-full flex items-center justify-center gap-2 bg-orange text-white py-3.5 rounded-xl font-bold text-sm hover:bg-orange-dark transition-colors">
            <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">payments</span>
            Get Pre-Approved
          </a>
          <p class="text-xs text-gray-400 text-center mt-2">Soft pull pre-qualification. No impact to your credit score.</p>
        </div>

        <!-- Trust Points -->
        <div class="space-y-5">
          <h3 class="font-headline text-2xl font-extrabold text-navy">Why Finance Through Maxim?</h3>
          {[
            { icon: 'groups', title: 'All Credit Levels Welcome', text: 'Good, fair, rebuilding, or first-time buyer. We work with lenders who serve every situation.' },
            { icon: 'search_off', title: 'No Credit Check to Browse', text: 'Explore the full inventory with zero impact to your credit score.' },
            { icon: 'directions_car', title: 'Drive Home Today with Plates', text: 'Get approved, get your metal plates on the spot, skip the DMV entirely.' },
            { icon: 'person', title: 'Deal Directly with Jerry', text: 'No commissioned salespeople. Jerry handles every deal personally, start to finish.' },
            { icon: 'trending_up', title: 'Build or Rebuild Credit', text: 'A financed purchase reported to credit bureaus can help establish or improve your credit.' },
          ].map(item => (
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 bg-orange/10 rounded-xl flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-xl text-orange" style="font-variation-settings:'FILL' 1;">{item.icon}</span>
              </div>
              <div>
                <p class="font-bold text-navy text-sm">{item.title}</p>
                <p class="text-gray-500 text-sm leading-relaxed">{item.text}</p>
              </div>
            </div>
          ))}
          <div class="pt-2">
            <div class="hidden sm:inline-flex items-center gap-2 bg-navy text-white px-6 py-3 rounded-xl font-bold text-sm">
              <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">phone</span>
              (847) 510-8947
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Points -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: 'search_off', title: 'No Credit Check to Browse', text: 'Explore our full inventory online. No impact to your credit score.' },
          { icon: 'groups', title: 'All Credit Levels', text: 'Good, fair, or rebuilding. We work with lenders who serve every situation.' },
          { icon: 'person_add', title: 'First-Time Buyers', text: 'Building credit for the first time? We help first-time buyers get approved.' },
          { icon: 'trending_up', title: 'Rebuilding Credit', text: 'A financed vehicle purchase can help rebuild your credit history.' },
        ].map(item => (
          <div class="text-center p-8 rounded-xl border border-gray-100 hover:border-orange/20 hover:shadow-md transition-all">
            <div class="w-14 h-14 bg-navy/5 rounded-2xl flex items-center justify-center mx-auto mb-5">
              <span class="material-symbols-outlined text-3xl text-navy" style="font-variation-settings: 'FILL' 1;">{item.icon}</span>
            </div>
            <h3 class="font-headline text-lg font-bold mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-surface">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Simple Process</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold">How It Works</h2>
      </div>
      <div class="space-y-8">
        {[
          { step: '1', title: 'Browse & Choose', text: 'Explore our fully inspected inventory online or in person. Every vehicle comes with a CARFAX report and independent inspection.', icon: 'inventory_2' },
          { step: '2', title: 'Apply in Minutes', text: 'Fill out the pre-qualification form below or text Jerry directly. We work with multiple lenders to match you with the best rate available.', icon: 'edit_note' },
          { step: '3', title: 'Drive Home Today with Plates', text: 'Once approved, we handle everything: paperwork, registration, and metal plates on the spot. Skip the DMV. No temporary tags.', icon: 'directions_car' },
        ].map(item => (
          <div class="flex gap-6 items-start bg-white p-8 rounded-xl border border-gray-100">
            <div class="w-14 h-14 bg-orange rounded-2xl flex items-center justify-center shrink-0">
              <span class="text-white font-headline font-extrabold text-xl">{item.step}</span>
            </div>
            <div>
              <h3 class="font-headline text-xl font-bold mb-2">{item.title}</h3>
              <p class="text-gray-600 leading-relaxed">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pre-Qualification Form -->
  <section id="apply" class="py-20 bg-white">
    <div class="max-w-2xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Get Started</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-4">Pre-Qualify Now</h2>
        <p class="text-gray-600 text-lg">No obligation. No impact to your credit score.</p>
      </div>

      <form id="financing-form" action="https://formspree.io/f/xpqkwodb" method="POST" class="space-y-6 bg-surface p-8 rounded-2xl border border-gray-200">
        <input type="hidden" name="_subject" value="Financing Pre-Qualification — Maxim Autos" />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <div>
          <label for="fin-name" class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
          <input
            type="text"
            id="fin-name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
            placeholder="Your full name"
          />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="fin-email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
            <input
              type="email"
              id="fin-email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="you@email.com"
            />
          </div>
          <div>
            <label for="fin-phone" class="block text-sm font-medium text-gray-700 mb-2">Phone</label>
            <input
              type="tel"
              id="fin-phone"
              name="phone"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="(555) 555-5555"
            />
          </div>
        </div>
        <div>
          <label for="fin-budget" class="block text-sm font-medium text-gray-700 mb-2">Monthly Budget Range</label>
          <select
            id="fin-budget"
            name="monthly_budget"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
          >
            <option value="" disabled selected>Select your range</option>
            <option value="under-150">Under $150/month</option>
            <option value="150-250">$150 – $250/month</option>
            <option value="250-350">$250 – $350/month</option>
            <option value="350-500">$350 – $500/month</option>
            <option value="500-plus">$500+/month</option>
          </select>
        </div>
        <div>
          <label for="fin-credit" class="block text-sm font-medium text-gray-700 mb-2">Credit Situation</label>
          <select
            id="fin-credit"
            name="credit_situation"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
          >
            <option value="" disabled selected>Select your situation</option>
            <option value="excellent">Excellent</option>
            <option value="good">Good</option>
            <option value="fair">Fair</option>
            <option value="rebuilding">Rebuilding</option>
            <option value="first-time">First-Time Buyer</option>
          </select>
        </div>
        <button
          type="submit"
          class="w-full bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors flex items-center justify-center gap-2"
        >
          <span class="material-symbols-outlined">check_circle</span>
          Submit Pre-Qualification
        </button>
        <p class="text-xs text-gray-400 text-center">This is not a credit application. A team member will follow up to discuss your options.</p>
        <p class="text-xs text-gray-400 text-center">By submitting this form, you agree to our <a href={`${base}/privacy-policy`} class="text-orange hover:underline">Privacy Policy</a>.</p>
      </form>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-orange">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-white mb-4">Prefer to Talk First?</h2>
      <p class="text-white/90 text-lg mb-8">Call or text Jerry to discuss financing before you apply. No pressure, no obligation.</p>
      <div class="hidden sm:inline-flex items-center justify-center gap-2 bg-white text-navy px-8 py-4 rounded-xl font-bold text-lg">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">phone</span>
        (847) 510-8947
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<script is:inline>
(function () {
  function calcPayment() {
    var price = parseFloat(document.getElementById('calc-price').value) || 0;
    var down = parseFloat(document.getElementById('calc-down').value) || 0;
    var term = parseInt(document.getElementById('calc-term').value) || 60;
    var apr = parseFloat(document.getElementById('calc-apr').value) || 0;
    var principal = Math.max(price - down, 0);
    var result = document.getElementById('calc-result');
    if (!result) return;
    if (apr === 0) {
      result.textContent = '$' + Math.round(principal / term).toLocaleString();
      return;
    }
    var r = apr / 100 / 12;
    var payment = principal * (r * Math.pow(1 + r, term)) / (Math.pow(1 + r, term) - 1);
    result.textContent = isFinite(payment) ? '$' + Math.round(payment).toLocaleString() : '$0';
  }
  ['calc-price', 'calc-down', 'calc-term', 'calc-apr'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', calcPayment);
  });
  calcPayment();
})();
</script>

<script is:inline>
(function () {
  var form = document.getElementById('financing-form');
  if (!form) return;
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    // Formspree not yet configured — route to SMS
    if (form.action.includes('YOUR_')) {
      var name = (document.getElementById('fin-name').value || '').trim();
      var phone = (document.getElementById('fin-phone').value || '').trim();
      var budget = document.getElementById('fin-budget').value || '';
      var body = encodeURIComponent('Hi Jerry, my name is ' + (name || 'a visitor') + '. I want to pre-qualify for financing. Monthly budget: ' + budget + '. Best phone: ' + phone);
      window.location.href = 'sms:8475108947&body=' + body;
      return;
    }
    var btn = form.querySelector('button[type="submit"]');
    var origText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="material-symbols-outlined">sync</span> Submitting...';
    fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    }).then(function (res) {
      if (res.ok) {
        form.innerHTML = '<div class="text-center py-12"><span class="material-symbols-outlined text-5xl text-green-500 mb-4 block" style="font-variation-settings:\'FILL\' 1;">check_circle</span><h3 class="font-headline text-xl font-bold text-navy mb-2">Pre-Qualification Submitted!</h3><p class="text-gray-600 mb-4">Jerry will follow up with financing options. Usually same day.</p><a href="sms:8475108947&body=Hi Jerry, I just submitted a financing pre-qualification on your website." class="inline-flex items-center gap-2 bg-orange text-white px-6 py-3 rounded-xl font-bold hover:bg-orange-dark transition-colors"><span class="material-symbols-outlined" style="font-variation-settings:\'FILL\' 1;">sms</span>Text Jerry to Follow Up</a></div>';
      } else {
        btn.disabled = false;
        btn.innerHTML = origText;
        alert('Something went wrong. Please text Jerry directly at (847) 510-8947.');
      }
    }).catch(function () {
      btn.disabled = false;
      btn.innerHTML = origText;
      alert('Something went wrong. Please text Jerry directly at (847) 510-8947.');
    });
  });
})();
</script>
