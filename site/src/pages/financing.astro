---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Used Car Financing in Skokie, IL — All Credit Levels | Maxim Autos';
const description = 'Financing for all credit levels at Maxim Autos in Skokie, IL. First-time buyers, rebuilding credit — all welcome. No credit check to browse. Apply in minutes.';
---

<Layout title={title} description={description}>
  <Header slot="header" />

  <!-- Hero -->
  <section class="bg-navy py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Financing</span>
      <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
        Financing for All Credit Levels
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
        First-time buyer? Rebuilding credit? No problem. Maxim Autos works with multiple lenders to find you the best rate.
      </p>
    </div>
  </section>

  <!-- Key Points -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: 'search_off', title: 'No Credit Check to Browse', text: 'Explore our full inventory online — no impact to your credit score.' },
          { icon: 'groups', title: 'All Credit Levels', text: 'Good, fair, or rebuilding — we work with lenders who serve every situation.' },
          { icon: 'person_add', title: 'First-Time Buyers', text: 'Building credit for the first time? We help first-time buyers get approved.' },
          { icon: 'trending_up', title: 'Rebuilding Credit', text: 'A financed vehicle purchase can help rebuild your credit history.' },
        ].map(item => (
          <div class="text-center p-8 rounded-xl border border-gray-100 hover:border-orange/20 hover:shadow-md transition-all">
            <div class="w-14 h-14 bg-navy/5 rounded-2xl flex items-center justify-center mx-auto mb-5">
              <span class="material-symbols-outlined text-3xl text-navy" style="font-variation-settings: 'FILL' 1;">{item.icon}</span>
            </div>
            <h3 class="font-headline text-lg font-bold mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-surface">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Simple Process</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold">How It Works</h2>
      </div>
      <div class="space-y-8">
        {[
          { step: '1', title: 'Browse & Choose', text: 'Explore our quality-inspected inventory online or in person. Every vehicle comes with a CARFAX report and independent inspection.', icon: 'inventory_2' },
          { step: '2', title: 'Apply in Minutes', text: 'Fill out the pre-qualification form below or text Jerry directly. We work with multiple lenders to match you with the best rate available.', icon: 'edit_note' },
          { step: '3', title: 'Drive Home Today with Plates', text: 'Once approved, we handle everything — paperwork, registration, and metal plates on-the-spot. No DMV trip, no temporary tags.', icon: 'directions_car' },
        ].map(item => (
          <div class="flex gap-6 items-start bg-white p-8 rounded-xl border border-gray-100">
            <div class="w-14 h-14 bg-orange rounded-2xl flex items-center justify-center shrink-0">
              <span class="text-white font-headline font-extrabold text-xl">{item.step}</span>
            </div>
            <div>
              <h3 class="font-headline text-xl font-bold mb-2">{item.title}</h3>
              <p class="text-gray-600 leading-relaxed">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pre-Qualification Form -->
  <section class="py-20 bg-white">
    <div class="max-w-2xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Get Started</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-4">Pre-Qualify Now</h2>
        <p class="text-gray-600 text-lg">No obligation. No impact to your credit score.</p>
      </div>

      <form action="#" method="POST" class="space-y-6 bg-surface p-8 rounded-2xl border border-gray-200">
        <div>
          <label for="fin-name" class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
          <input
            type="text"
            id="fin-name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
            placeholder="Your full name"
          />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="fin-email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
            <input
              type="email"
              id="fin-email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="you@email.com"
            />
          </div>
          <div>
            <label for="fin-phone" class="block text-sm font-medium text-gray-700 mb-2">Phone</label>
            <input
              type="tel"
              id="fin-phone"
              name="phone"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="(555) 555-5555"
            />
          </div>
        </div>
        <div>
          <label for="fin-budget" class="block text-sm font-medium text-gray-700 mb-2">Monthly Budget Range</label>
          <select
            id="fin-budget"
            name="monthly_budget"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
          >
            <option value="" disabled selected>Select your range</option>
            <option value="under-150">Under $150/month</option>
            <option value="150-250">$150 – $250/month</option>
            <option value="250-350">$250 – $350/month</option>
            <option value="350-500">$350 – $500/month</option>
            <option value="500-plus">$500+/month</option>
          </select>
        </div>
        <div>
          <label for="fin-credit" class="block text-sm font-medium text-gray-700 mb-2">Credit Situation</label>
          <select
            id="fin-credit"
            name="credit_situation"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
          >
            <option value="" disabled selected>Select your situation</option>
            <option value="excellent">Excellent</option>
            <option value="good">Good</option>
            <option value="fair">Fair</option>
            <option value="rebuilding">Rebuilding</option>
            <option value="first-time">First-Time Buyer</option>
          </select>
        </div>
        <button
          type="submit"
          class="w-full bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors flex items-center justify-center gap-2"
        >
          <span class="material-symbols-outlined">check_circle</span>
          Submit Pre-Qualification
        </button>
        <p class="text-xs text-gray-400 text-center">This is not a credit application. A team member will follow up to discuss your options.</p>
      </form>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-orange">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-white mb-4">Prefer to Talk First?</h2>
      <p class="text-white/90 text-lg mb-8">Text Jerry to discuss financing before you apply. No pressure, no obligation.</p>
      <a href="sms:8475108947&body=Hi Jerry, I'd like to discuss financing options at Maxim Autos." class="inline-flex items-center justify-center gap-2 bg-white text-navy px-8 py-4 rounded-xl font-bold text-lg hover:bg-gray-100 transition-colors">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">sms</span>
        Text Jerry About Financing
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
