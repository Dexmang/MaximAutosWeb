---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import VehicleCard from '../../components/VehicleCard.astro';
import vehicles from '../../data/vehicles.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const liveVehicles = vehicles.filter(v => (v as any).status !== 'sold');
const title = 'Autos Usados en Venta en Skokie, IL | Maxim Autos';
const description = `Explora ${liveVehicles.length} autos usados completamente inspeccionados en Maxim Autos en Skokie, IL. Precios desde $${Math.min(...liveVehicles.map(v => v.price)).toLocaleString()} hasta $${Math.max(...liveVehicles.map(v => v.price)).toLocaleString()}. Cada vehiculo incluye reporte de inspeccion independiente y placas el mismo dia. Financiamiento disponible para todos los niveles de credito.`;

const bodyStyles = [...new Set(liveVehicles.map(v => v.bodyStyle))].sort();
const drivetrains = [...new Set(liveVehicles.map(v => v.drivetrain).filter(Boolean))].sort();
---

<Layout
  title={title}
  description={description}
  lang="es"
  hreflangEn="https://www.maximautos.com/inventory"
  hreflangEs="https://www.maximautos.com/es/inventario"
>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.maximautos.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Inventario", "item": "https://www.maximautos.com/es/inventario" }
      ]
    })} />
  </Fragment>

  <Header slot="header" lang="es" />

  <!-- Encabezado de pagina + filtros -->
  <section class="sticky top-[73px] z-40 bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-3">
      <div class="flex items-center justify-between mb-2">
        <div>
          <h1 class="font-headline text-lg font-extrabold text-navy leading-tight">Autos Usados en Skokie, IL</h1>
          <p class="text-xs text-gray-500 hidden sm:block">Todos los vehiculos completamente inspeccionados · CARFAX gratis incluido</p>
        </div>
        <div class="flex items-center gap-2 md:hidden">
          <select id="filter-sort" class="px-2 py-1.5 rounded-lg text-xs font-semibold border border-gray-200 bg-white text-gray-700 cursor-pointer">
            <option value="price-asc">Precio ↑</option>
            <option value="price-desc">Precio ↓</option>
            <option value="year-desc">Mas recientes</option>
            <option value="mileage-asc">Millas ↑</option>
          </select>
          <button id="mobile-filter-toggle" class="flex items-center gap-1 px-3 py-1.5 rounded-lg border border-gray-200 text-xs font-semibold text-gray-700 bg-white whitespace-nowrap">
            <span class="material-symbols-outlined text-sm">tune</span>
            Filtros<span id="mobile-filter-count" class="hidden ml-1 bg-orange text-white text-[10px] rounded-full px-1.5 leading-snug"></span>
          </button>
        </div>
      </div>

      <div id="filter-panel" class="hidden md:flex flex-col md:flex-row md:items-center gap-3 flex-wrap">
        <!-- Precio -->
        <div class="flex flex-col gap-1">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Precio</label>
          <div class="flex flex-wrap gap-1.5" id="filter-price">
            <button data-price="all" class="filter-btn filter-btn--active px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">Todos</button>
            <button data-price="under10k" class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">Menos de $10K</button>
            <button data-price="5000-8000" class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">$5K a $8K</button>
            <button data-price="8000-12000" class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">$8K a $12K</button>
            <button data-price="12000-15000" class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">$12K a $15K</button>
          </div>
        </div>

        <!-- Tipo de carroceria -->
        <div class="flex flex-col gap-1">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Tipo</label>
          <div class="flex flex-wrap gap-1.5" id="filter-body">
            <button data-body="all" class="filter-btn filter-btn--active px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">Todos</button>
            {bodyStyles.map(style => (
              <button data-body={style} class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">{style}</button>
            ))}
          </div>
        </div>

        <!-- Traccion -->
        <div class="flex flex-col gap-1">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Traccion</label>
          <div class="flex flex-wrap gap-1.5" id="filter-drive">
            <button data-drive="all" class="filter-btn filter-btn--active px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">Todos</button>
            {drivetrains.map(dt => (
              <button data-drive={dt} class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">{dt}</button>
            ))}
          </div>
        </div>

        <!-- Ordenar (solo escritorio) -->
        <div class="flex-col gap-1 md:ml-auto hidden md:flex">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Ordenar</label>
          <select id="filter-sort-desktop" class="px-3 py-1.5 rounded-lg text-xs font-semibold border border-gray-200 bg-white text-gray-700 focus:ring-2 focus:ring-orange/30 focus:border-orange cursor-pointer">
            <option value="price-asc">Precio: menor a mayor</option>
            <option value="price-desc">Precio: mayor a menor</option>
            <option value="year-desc">Mas recientes primero</option>
            <option value="mileage-asc">Millas: menor a mayor</option>
          </select>
        </div>
      </div>
    </div>
  </section>

  <!-- Entrega nacional -->
  <div class="bg-navy/5 border-b border-navy/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-3 flex items-center gap-3">
      <span class="material-symbols-outlined text-xl text-navy shrink-0" style="font-variation-settings:'FILL' 1;">local_shipping</span>
      <p class="text-sm text-gray-700">
        <span class="font-bold text-navy">No estas en el area?</span> Cualquiera de estos autos puede entregarse en tu puerta, en cualquier parte de EE.UU. Compra en linea, recoge o pide envio.
        <a href={`${base}/es/compra-en-linea`} class="text-orange font-bold hover:underline ml-1">Como funciona →</a>
      </p>
    </div>
  </div>

  <!-- Inventario -->
  <section class="py-6 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <p class="text-gray-600 font-medium" id="vehicle-count">
          Mostrando <span class="text-navy font-bold" id="count-num">{liveVehicles.length}</span> vehiculos
        </p>
        <button id="clear-filters" class="hidden text-sm text-orange font-semibold hover:underline">Limpiar Filtros</button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" id="vehicle-grid">
        {liveVehicles.map(v => (
          <div
            class="vehicle-item"
            data-price={v.price}
            data-body={v.bodyStyle}
            data-drive={v.drivetrain}
            data-year={v.year}
            data-mileage={v.mileage}
            data-slug={v.slug}
          >
            <VehicleCard
              lang="es"
              slug={v.slug}
              year={v.year}
              make={v.make}
              model={v.model}
              trim={v.trim}
              price={v.price}
              mileage={v.mileage}
              drivetrain={v.drivetrain}
              engine={v.engine}
              bodyStyle={v.bodyStyle}
              photoPath={v.photoPath}
              photoPrefix={v.photoPrefix}
              inspected={v.inspected}
              primaryPhotoUrl={v.primaryPhotoUrl}
              photos={v.photos}
              dealRating={(v as any).dealRating}
              priceSavings={(v as any).priceSavings}
            />
          </div>
        ))}
      </div>

      <p class="text-xs text-gray-400 mt-4">* Pago estimado basado en 10% de enganche, 9.9% APR, plazo de 60 meses. Solo para fines ilustrativos. Los terminos reales varian segun el credito.</p>

      <div id="no-results" class="hidden text-center py-20">
        <span class="material-symbols-outlined text-6xl text-gray-300 mb-4 block">search_off</span>
        <h3 class="font-headline text-xl font-bold text-gray-700 mb-2">Ningun vehiculo coincide con tus filtros</h3>
        <p class="text-gray-500 mb-6">Intenta ajustar el rango de precio o el tipo de carroceria.</p>
        <button id="reset-from-empty" class="inline-flex items-center gap-2 bg-gray-200 text-gray-700 px-6 py-3 rounded-lg font-bold text-sm hover:bg-gray-300 transition-colors">
          <span class="material-symbols-outlined text-lg">filter_alt_off</span>
          Limpiar Todos los Filtros
        </button>
      </div>
    </div>
  </section>

  <!-- Financiamiento -->
  <section class="bg-white border-t border-gray-100 py-10">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="bg-navy rounded-2xl px-8 py-7 flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="font-headline text-xl font-extrabold text-white mb-1">Financiamiento para Todos los Niveles de Credito</h3>
          <p class="text-white/70 text-sm">Buen credito, credito regular, reconstruyendo, o primer auto. Aplica en minutos. Sin compromiso.</p>
        </div>
        <a href={`${base}/es/aplicacion-de-credito`} class="shrink-0 inline-flex items-center justify-center gap-2 bg-orange text-white px-7 py-3.5 rounded-xl font-bold text-base hover:bg-orange-dark transition-colors whitespace-nowrap">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">payments</span>
          Aplicar para Financiamiento
        </a>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-16 bg-navy">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Inventario Seleccionado</span>
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-white mb-4">No Encuentras Lo que Buscas?</h2>
      <p class="text-white/70 text-lg mb-3">Jerry selecciona personalmente cada auto en este lote. No vendemos volumen, vendemos calidad.</p>
      <p class="text-white/60 text-base mb-8">Envianos un mensaje con lo que buscas: marca, modelo, presupuesto y caracteristicas. Jerry consigue autos cada semana y lo encontrara para ti.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <div class="hidden sm:inline-flex items-center justify-center gap-3 bg-white/10 border border-white/20 text-white px-8 py-4 rounded-xl font-bold text-lg">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang="es" />
</Layout>

<style is:inline>
  .filter-btn {
    background: #f8f9fa;
    color: #4b5563;
    border: 1px solid #e5e7eb;
  }
  .filter-btn:focus-visible {
    outline: 2px solid #f08010;
    outline-offset: 2px;
  }
  .filter-btn:hover {
    background: #edeeef;
    border-color: #d1d5db;
  }
  .filter-btn--active {
    background: #0a2540 !important;
    color: #fff !important;
    border-color: #0a2540 !important;
  }
</style>

<script is:inline>
(function () {
  const grid = document.getElementById('vehicle-grid');
  const cards = Array.from(grid.querySelectorAll('.vehicle-item'));
  const countEl = document.getElementById('count-num');
  const noResults = document.getElementById('no-results');
  const clearBtn = document.getElementById('clear-filters');
  const resetEmpty = document.getElementById('reset-from-empty');
  const sortSelect = document.getElementById('filter-sort');
  const sortDesktop = document.getElementById('filter-sort-desktop');

  const filterPanel = document.getElementById('filter-panel');
  const mobileToggle = document.getElementById('mobile-filter-toggle');
  const mobileCount = document.getElementById('mobile-filter-count');
  mobileToggle?.addEventListener('click', () => {
    filterPanel.classList.toggle('hidden');
  });

  function syncSort(val) {
    if (sortSelect) sortSelect.value = val;
    if (sortDesktop) sortDesktop.value = val;
  }
  sortDesktop?.addEventListener('change', function () {
    syncSort(this.value);
    applyFilters();
    applySorting();
  });

  let activePrice = 'all';
  let activeBody = 'all';
  let activeDrive = 'all';

  function setActiveBtn(group, key, value) {
    group.querySelectorAll('.filter-btn').forEach(btn => {
      btn.classList.toggle('filter-btn--active', btn.dataset[key] === value);
    });
  }

  function priceMatches(price, filter) {
    if (filter === 'all') return true;
    if (filter === 'under10k') return price < 10000;
    const [min, max] = filter.split('-').map(Number);
    return price >= min && price <= max;
  }

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const price = parseInt(card.dataset.price, 10);
      const body = card.dataset.body;
      const drive = card.dataset.drive;
      const show = priceMatches(price, activePrice)
        && (activeBody === 'all' || body === activeBody)
        && (activeDrive === 'all' || drive === activeDrive);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    countEl.textContent = visible;
    noResults.classList.toggle('hidden', visible > 0);
    grid.classList.toggle('hidden', visible === 0);
    const hasFilters = activePrice !== 'all' || activeBody !== 'all' || activeDrive !== 'all';
    clearBtn.classList.toggle('hidden', !hasFilters);
    if (mobileCount) {
      const count = (activePrice !== 'all' ? 1 : 0) + (activeBody !== 'all' ? 1 : 0) + (activeDrive !== 'all' ? 1 : 0);
      mobileCount.textContent = count;
      mobileCount.classList.toggle('hidden', count === 0);
    }
  }

  function applySorting() {
    const sortVal = sortSelect.value;
    const sorted = [...cards].sort((a, b) => {
      switch (sortVal) {
        case 'price-asc':   return parseInt(a.dataset.price) - parseInt(b.dataset.price);
        case 'price-desc':  return parseInt(b.dataset.price) - parseInt(a.dataset.price);
        case 'year-desc':   return parseInt(b.dataset.year) - parseInt(a.dataset.year);
        case 'mileage-asc': return parseInt(a.dataset.mileage) - parseInt(b.dataset.mileage);
        default: return 0;
      }
    });
    sorted.forEach(card => grid.appendChild(card));
  }

  function resetFilters() {
    activePrice = 'all';
    activeBody = 'all';
    activeDrive = 'all';
    setActiveBtn(document.getElementById('filter-price'), 'price', 'all');
    setActiveBtn(document.getElementById('filter-body'), 'body', 'all');
    setActiveBtn(document.getElementById('filter-drive'), 'drive', 'all');
    filterPanel?.classList.add('hidden');
    applyFilters();
  }

  function applyUrlParams() {
    const params = new URLSearchParams(window.location.search);
    const price = params.get('price');
    const body = params.get('body');
    const drive = params.get('drive');
    if (price) { activePrice = price; setActiveBtn(document.getElementById('filter-price'), 'price', price); }
    if (body)  { activeBody = body;   setActiveBtn(document.getElementById('filter-body'), 'body', body); }
    if (drive) { activeDrive = drive; setActiveBtn(document.getElementById('filter-drive'), 'drive', drive); }
  }

  document.getElementById('filter-price').addEventListener('click', function (e) {
    const btn = e.target.closest('.filter-btn');
    if (!btn) return;
    activePrice = btn.dataset.price;
    setActiveBtn(this, 'price', activePrice);
    applyFilters();
  });

  document.getElementById('filter-body').addEventListener('click', function (e) {
    const btn = e.target.closest('.filter-btn');
    if (!btn) return;
    activeBody = btn.dataset.body;
    setActiveBtn(this, 'body', activeBody);
    applyFilters();
  });

  document.getElementById('filter-drive').addEventListener('click', function (e) {
    const btn = e.target.closest('.filter-btn');
    if (!btn) return;
    activeDrive = btn.dataset.drive;
    setActiveBtn(this, 'drive', activeDrive);
    applyFilters();
  });

  sortSelect.addEventListener('change', function () {
    applyFilters();
    applySorting();
  });

  clearBtn.addEventListener('click', resetFilters);
  resetEmpty.addEventListener('click', resetFilters);

  applySorting();
  applyUrlParams();
  applyFilters();
})();
</script>
