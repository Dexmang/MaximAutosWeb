---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import VehicleCard from '../../components/VehicleCard.astro';
import { es } from '../../i18n/es';
import vehicles from '../../data/vehicles.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const esBase = `${base}/es`;
const siteUrl = 'https://www.maximautos.com';
const t = es;

const liveVehicles = vehicles.filter(v => (v as any).status !== 'sold');
const bodyStyles = [...new Set(liveVehicles.map(v => v.bodyStyle))].sort();
const drivetrains = [...new Set(liveVehicles.map(v => v.drivetrain).filter(Boolean))].sort();
const title = t.inventory.seoTitle;
const description = `${t.inventory.seoDescPrefix} ${liveVehicles.length} ${t.inventory.seoDescSuffix}`;
---

<Layout
  title={title}
  description={description}
  lang="es"
  alternateLang="en"
  alternateUrl={`${siteUrl}/inventory`}
  canonicalUrl={`${siteUrl}/es/inventory`}
>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/es/` },
        { "@type": "ListItem", "position": 2, "name": "Inventario", "item": `${siteUrl}/es/inventory` }
      ]
    })} />
  </Fragment>

  <Header slot="header" lang="es" t={t.nav} switcherHref={`${base}/inventory`} />

  <!-- Sticky Filter Bar -->
  <section class="sticky top-[73px] z-40 bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-3">
      <div class="flex items-center justify-between mb-2">
        <div>
          <h1 class="font-headline text-lg font-extrabold text-navy leading-tight">{t.inventory.h1}</h1>
          <p class="text-xs text-gray-500 hidden sm:block">{t.inventory.subtitle}</p>
        </div>
        <!-- Mobile controls -->
        <div class="flex items-center gap-2 md:hidden">
          <select id="filter-sort" class="px-2 py-1.5 rounded-lg text-xs font-semibold border border-gray-200 bg-white text-gray-700 cursor-pointer">
            <option value="price-asc">{t.inventory.sortAscLabel}</option>
            <option value="price-desc">{t.inventory.sortDescLabel}</option>
            <option value="year-desc">{t.inventory.sortNewLabel}</option>
            <option value="mileage-asc">{t.inventory.sortMiLabel}</option>
          </select>
          <button id="mobile-filter-toggle" class="flex items-center gap-1 px-3 py-1.5 rounded-lg border border-gray-200 text-xs font-semibold text-gray-700 bg-white whitespace-nowrap">
            <span class="material-symbols-outlined text-sm">tune</span>
            {t.inventory.filtersLabel}<span id="mobile-filter-count" class="hidden ml-1 bg-orange text-white text-[10px] rounded-full px-1.5 leading-snug"></span>
          </button>
        </div>
      </div>

      <!-- Filter panel -->
      <div id="filter-panel" class="hidden md:flex flex-col md:flex-row md:items-center gap-3 flex-wrap">
        <!-- Price -->
        <div class="flex flex-col gap-1">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">{t.inventory.priceLabel}</label>
          <div class="flex flex-wrap gap-1.5" id="filter-price">
            <button data-price="all" class="filter-btn filter-btn--active px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">{t.inventory.all}</button>
            <button data-price="under10k" class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">{t.inventory.under10k}</button>
            <button data-price="5000-8000" class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">{t.inventory.price5to8}</button>
            <button data-price="8000-12000" class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">{t.inventory.price8to12}</button>
            <button data-price="12000-15000" class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">{t.inventory.price12to15}</button>
          </div>
        </div>

        <!-- Body Style -->
        <div class="flex flex-col gap-1">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">{t.inventory.bodyStyleLabel}</label>
          <div class="flex flex-wrap gap-1.5" id="filter-body">
            <button data-body="all" class="filter-btn filter-btn--active px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">{t.inventory.all}</button>
            {bodyStyles.map(style => (
              <button data-body={style} class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">{style}</button>
            ))}
          </div>
        </div>

        <!-- Drivetrain -->
        <div class="flex flex-col gap-1">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">{t.inventory.driveLabel}</label>
          <div class="flex flex-wrap gap-1.5" id="filter-drive">
            <button data-drive="all" class="filter-btn filter-btn--active px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">{t.inventory.all}</button>
            {drivetrains.map(dt => (
              <button data-drive={dt} class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all">{dt}</button>
            ))}
          </div>
        </div>

        <!-- Sort (desktop) -->
        <div class="flex-col gap-1 md:ml-auto hidden md:flex">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">{t.inventory.sortLabel}</label>
          <select id="filter-sort-desktop" class="px-3 py-1.5 rounded-lg text-xs font-semibold border border-gray-200 bg-white text-gray-700 focus:ring-2 focus:ring-orange/30 focus:border-orange cursor-pointer">
            <option value="price-asc">{t.inventory.priceLowHigh}</option>
            <option value="price-desc">{t.inventory.priceHighLow}</option>
            <option value="year-desc">{t.inventory.newestFirst}</option>
            <option value="mileage-asc">{t.inventory.mileageLow}</option>
          </select>
        </div>
      </div>
    </div>
  </section>

  <!-- Shipping banner -->
  <div class="bg-navy/5 border-b border-navy/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-3 flex items-center gap-3">
      <span class="material-symbols-outlined text-xl text-navy shrink-0" style="font-variation-settings:'FILL' 1;">local_shipping</span>
      <p class="text-sm text-gray-700">
        <span class="font-bold text-navy">{t.inventory.shippingLead}</span> {t.inventory.shippingBody}
        <a href={`${base}/ship`} class="text-orange font-bold hover:underline ml-1">{t.inventory.shippingCta}</a>
      </p>
    </div>
  </div>

  <!-- Inventory Grid -->
  <section class="py-6 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <p class="text-gray-600 font-medium" id="vehicle-count">
          {t.inventory.showingPrefix} <span class="text-navy font-bold" id="count-num">{liveVehicles.length}</span> {t.inventory.showingSuffix}
        </p>
        <button id="clear-filters" class="hidden text-sm text-orange font-semibold hover:underline">{t.inventory.clearFilters}</button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" id="vehicle-grid">
        {liveVehicles.map(v => (
          <div
            class="vehicle-item"
            data-price={v.price}
            data-body={v.bodyStyle}
            data-drive={v.drivetrain}
            data-year={v.year}
            data-mileage={v.mileage}
            data-slug={v.slug}
          >
            <VehicleCard
              slug={v.slug} year={v.year} make={v.make} model={v.model} trim={v.trim}
              price={v.price} mileage={v.mileage} drivetrain={v.drivetrain} engine={v.engine}
              bodyStyle={v.bodyStyle} photoPath={v.photoPath} photoPrefix={v.photoPrefix}
              inspected={v.inspected} primaryPhotoUrl={v.primaryPhotoUrl} photos={v.photos}
              dealRating={(v as any).dealRating} priceSavings={(v as any).priceSavings}
              t={t.vehicleCard} financingHref={`${esBase}/financing`}
            />
          </div>
        ))}
      </div>

      <p class="text-xs text-gray-400 mt-4">{t.inventory.paymentDisclaimer}</p>

      <!-- No Results -->
      <div id="no-results" class="hidden text-center py-20">
        <span class="material-symbols-outlined text-6xl text-gray-300 mb-4 block">search_off</span>
        <h3 class="font-headline text-xl font-bold text-gray-700 mb-2">{t.inventory.noResultsTitle}</h3>
        <p class="text-gray-500 mb-6">{t.inventory.noResultsBody}</p>
        <button id="reset-from-empty" class="inline-flex items-center gap-2 bg-gray-200 text-gray-700 px-6 py-3 rounded-lg font-bold text-sm hover:bg-gray-300 transition-colors">
          <span class="material-symbols-outlined text-lg">filter_alt_off</span>
          {t.inventory.clearAllFilters}
        </button>
      </div>
    </div>
  </section>

  <!-- Financing Callout -->
  <section class="bg-white border-t border-gray-100 py-10">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="bg-navy rounded-2xl px-8 py-7 flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="font-headline text-xl font-extrabold text-white mb-1">{t.inventory.financingH3}</h3>
          <p class="text-white/70 text-sm">{t.inventory.financingBody}</p>
        </div>
        <a href={`${esBase}/apply`} class="shrink-0 inline-flex items-center justify-center gap-2 bg-orange text-white px-7 py-3.5 rounded-xl font-bold text-base hover:bg-orange-dark transition-colors whitespace-nowrap">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">payments</span>
          {t.inventory.financingCta}
        </a>
      </div>
    </div>
  </section>

  <!-- Car Finder -->
  <section class="py-16 bg-navy">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">{t.inventory.carFinderEyebrow}</span>
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-white mb-4">{t.inventory.carFinderH2}</h2>
      <p class="text-white/70 text-lg mb-3">{t.inventory.carFinderBody1}</p>
      <p class="text-white/60 text-base mb-8">{t.inventory.carFinderBody2}</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <div class="hidden sm:inline-flex items-center justify-center gap-3 bg-white/10 border border-white/20 text-white px-8 py-4 rounded-xl font-bold text-lg">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947 — {t.inventory.callOrText}
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang="es" t={t.footer} />
</Layout>

<style is:inline>
  .filter-btn { background: #f8f9fa; color: #4b5563; border: 1px solid #e5e7eb; }
  .filter-btn:focus-visible { outline: 2px solid #f08010; outline-offset: 2px; }
  .filter-btn:hover { background: #edeeef; border-color: #d1d5db; }
  .filter-btn--active { background: #0a2540 !important; color: #fff !important; border-color: #0a2540 !important; }
</style>

<script is:inline>
(function () {
  var grid = document.getElementById('vehicle-grid');
  var cards = Array.from(grid.querySelectorAll('.vehicle-item'));
  var countEl = document.getElementById('count-num');
  var noResults = document.getElementById('no-results');
  var clearBtn = document.getElementById('clear-filters');
  var resetEmpty = document.getElementById('reset-from-empty');
  var sortSelect = document.getElementById('filter-sort');
  var sortDesktop = document.getElementById('filter-sort-desktop');
  var filterPanel = document.getElementById('filter-panel');
  var mobileToggle = document.getElementById('mobile-filter-toggle');
  var mobileCount = document.getElementById('mobile-filter-count');

  mobileToggle && mobileToggle.addEventListener('click', function() { filterPanel.classList.toggle('hidden'); });

  function syncSort(val) {
    if (sortSelect) sortSelect.value = val;
    if (sortDesktop) sortDesktop.value = val;
  }
  sortDesktop && sortDesktop.addEventListener('change', function () { syncSort(this.value); applyFilters(); applySorting(); });

  var activePrice = 'all', activeBody = 'all', activeDrive = 'all';

  function setActiveBtn(group, key, value) {
    group.querySelectorAll('.filter-btn').forEach(function(btn) {
      btn.classList.toggle('filter-btn--active', btn.dataset[key] === value);
    });
  }

  function priceMatches(price, filter) {
    if (filter === 'all') return true;
    if (filter === 'under10k') return price < 10000;
    var parts = filter.split('-').map(Number);
    return price >= parts[0] && price <= parts[1];
  }

  function applyFilters() {
    var visible = 0;
    cards.forEach(function(card) {
      var price = parseInt(card.dataset.price, 10);
      var show = priceMatches(price, activePrice)
        && (activeBody === 'all' || card.dataset.body === activeBody)
        && (activeDrive === 'all' || card.dataset.drive === activeDrive);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    countEl.textContent = visible;
    noResults.classList.toggle('hidden', visible > 0);
    grid.classList.toggle('hidden', visible === 0);
    var hasFilters = activePrice !== 'all' || activeBody !== 'all' || activeDrive !== 'all';
    clearBtn.classList.toggle('hidden', !hasFilters);
    if (mobileCount) {
      var n = (activePrice !== 'all' ? 1 : 0) + (activeBody !== 'all' ? 1 : 0) + (activeDrive !== 'all' ? 1 : 0);
      mobileCount.textContent = n;
      mobileCount.classList.toggle('hidden', n === 0);
    }
  }

  function applySorting() {
    var sortVal = sortSelect.value;
    var sorted = cards.slice().sort(function(a, b) {
      switch (sortVal) {
        case 'price-asc':   return parseInt(a.dataset.price) - parseInt(b.dataset.price);
        case 'price-desc':  return parseInt(b.dataset.price) - parseInt(a.dataset.price);
        case 'year-desc':   return parseInt(b.dataset.year) - parseInt(a.dataset.year);
        case 'mileage-asc': return parseInt(a.dataset.mileage) - parseInt(b.dataset.mileage);
        default: return 0;
      }
    });
    sorted.forEach(function(card) { grid.appendChild(card); });
  }

  function resetFilters() {
    activePrice = 'all'; activeBody = 'all'; activeDrive = 'all';
    setActiveBtn(document.getElementById('filter-price'), 'price', 'all');
    setActiveBtn(document.getElementById('filter-body'), 'body', 'all');
    setActiveBtn(document.getElementById('filter-drive'), 'drive', 'all');
    filterPanel && filterPanel.classList.add('hidden');
    applyFilters();
  }

  function applyUrlParams() {
    var params = new URLSearchParams(window.location.search);
    var price = params.get('price'), body = params.get('body'), drive = params.get('drive');
    if (price) { activePrice = price; setActiveBtn(document.getElementById('filter-price'), 'price', price); }
    if (body)  { activeBody = body;   setActiveBtn(document.getElementById('filter-body'),  'body',  body);  }
    if (drive) { activeDrive = drive; setActiveBtn(document.getElementById('filter-drive'), 'drive', drive); }
  }

  document.getElementById('filter-price').addEventListener('click', function(e) {
    var btn = e.target.closest('.filter-btn'); if (!btn) return;
    activePrice = btn.dataset.price; setActiveBtn(this, 'price', activePrice); applyFilters();
  });
  document.getElementById('filter-body').addEventListener('click', function(e) {
    var btn = e.target.closest('.filter-btn'); if (!btn) return;
    activeBody = btn.dataset.body; setActiveBtn(this, 'body', activeBody); applyFilters();
  });
  document.getElementById('filter-drive').addEventListener('click', function(e) {
    var btn = e.target.closest('.filter-btn'); if (!btn) return;
    activeDrive = btn.dataset.drive; setActiveBtn(this, 'drive', activeDrive); applyFilters();
  });
  sortSelect.addEventListener('change', function() { applyFilters(); applySorting(); });
  clearBtn.addEventListener('click', resetFilters);
  resetEmpty.addEventListener('click', resetFilters);

  applySorting(); applyUrlParams(); applyFilters();
})();
</script>
