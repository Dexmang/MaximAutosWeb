<script is:inline>
(function () {
  // Cambio de pestanas
  var tabBuyer = document.getElementById('tab-buyer');
  var tabCobuyer = document.getElementById('tab-cobuyer');
  var sectionBuyer = document.getElementById('section-buyer');
  var sectionCobuyer = document.getElementById('section-cobuyer');

  tabBuyer.addEventListener('click', function () {
    tabBuyer.classList.add('app-tab--active');
    tabCobuyer.classList.remove('app-tab--active');
    sectionBuyer.classList.remove('hidden');
    sectionCobuyer.classList.add('hidden');
  });

  tabCobuyer.addEventListener('click', function () {
    tabCobuyer.classList.add('app-tab--active');
    tabBuyer.classList.remove('app-tab--active');
    sectionCobuyer.classList.remove('hidden');
    sectionBuyer.classList.add('hidden');
  });

  // Formateo de SSN (XXX-XX-XXXX)
  function formatSSN(input) {
    input.addEventListener('input', function () {
      var v = this.value.replace(/\D/g, '').slice(0, 9);
      if (v.length > 5) v = v.slice(0,3) + '-' + v.slice(3,5) + '-' + v.slice(5);
      else if (v.length > 3) v = v.slice(0,3) + '-' + v.slice(3);
      this.value = v;
    });
  }
  var buyerSSN = document.getElementById('buyer_ssn');
  var cobuyerSSN = document.getElementById('cobuyer_ssn');
  if (buyerSSN) formatSSN(buyerSSN);
  if (cobuyerSSN) formatSSN(cobuyerSSN);

  // Mostrar direccion anterior si < 2 anos en la actual
  function checkPrevAddress() {
    var years = parseInt(document.getElementById('buyer_years_address').value) || 0;
    var months = parseInt(document.getElementById('buyer_months_address').value) || 0;
    var totalMonths = years * 12 + months;
    var section = document.getElementById('buyer-prev-address-section');
    if (totalMonths < 24) section.classList.remove('hidden');
    else section.classList.add('hidden');
  }
  var yAddr = document.getElementById('buyer_years_address');
  var mAddr = document.getElementById('buyer_months_address');
  if (yAddr) yAddr.addEventListener('change', checkPrevAddress);
  if (mAddr) mAddr.addEventListener('change', checkPrevAddress);

  // Mostrar empleador anterior si < 2 anos en el trabajo actual
  function checkPrevEmployer() {
    var years = parseInt(document.getElementById('buyer_years_job').value) || 0;
    var months = parseInt(document.getElementById('buyer_months_job').value) || 0;
    var totalMonths = years * 12 + months;
    var section = document.getElementById('buyer-prev-employer-section');
    if (totalMonths < 24) section.classList.remove('hidden');
    else section.classList.add('hidden');
  }
  var yJob = document.getElementById('buyer_years_job');
  var mJob = document.getElementById('buyer_months_job');
  if (yJob) yJob.addEventListener('change', checkPrevEmployer);
  if (mJob) mJob.addEventListener('change', checkPrevEmployer);

  // Envio del formulario
  var form = document.getElementById('apply-form');
  var btn = document.getElementById('apply-submit-btn');
  if (!form) return;

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var origHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="material-symbols-outlined">sync</span> Enviando...';

    var fd = new FormData(form);
    var obj = {};
    fd.forEach(function(val, key) { obj[key] = val; });
    fetch(form.action, {
      method: 'POST',
      body: JSON.stringify(obj),
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }
    }).then(function (res) {
      if (res.ok) {
        form.closest('section').innerHTML = '<div class="max-w-2xl mx-auto px-6 py-20 text-center"><span class="material-symbols-outlined text-6xl text-green-500 mb-6 block" style="font-variation-settings:\'FILL\' 1;">check_circle</span><h2 class="font-headline text-2xl font-extrabold text-navy mb-3">Solicitud Enviada!</h2><p class="text-gray-600 text-lg mb-2">Jerry revisara tu solicitud y te dara seguimiento el mismo dia durante el horario de atencion.</p><p class="text-gray-600 text-base mt-4">Tienes preguntas? Envia un texto o llama a Jerry al 847-510-8947</p></div>';
      } else {
        btn.disabled = false;
        btn.innerHTML = origHtml;
        alert('Algo salio mal. Por favor envia un texto a Jerry al (847) 510-8947.');
      }
    }).catch(function () {
      btn.disabled = false;
      btn.innerHTML = origHtml;
      alert('Algo salio mal. Por favor envia un texto a Jerry al (847) 510-8947.');
    });
  });
})();
</script>
