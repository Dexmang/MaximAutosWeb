---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = 'Solicitud de Credito para Auto | Maxim Autos Skokie, IL';
const description = 'Aplica para financiamiento de auto en Maxim Autos en Skokie, IL. Todos los niveles de credito son bienvenidos, incluyendo primeros compradores y quienes reconstruyen su credito. Solicitud rapida y sencilla.';

const states = ['AL','AK','AZ','AR','CA','CO','CT','DE','FL','GA','HI','ID','IL','IN','IA','KS','KY','LA','ME','MD','MA','MI','MN','MS','MO','MT','NE','NV','NH','NJ','NM','NY','NC','ND','OH','OK','OR','PA','RI','SC','SD','TN','TX','UT','VT','VA','WA','WV','WI','WY'];
---

<Layout
  title={title}
  description={description}
  lang="es"
  hreflangEn="https://www.maximautos.com/apply"
  hreflangEs="https://www.maximautos.com/es/aplicacion-de-credito"
>
  <Header slot="header" lang="es" />

  <!-- Hero -->
  <section class="bg-navy py-10 lg:py-14">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Solicitud de Credito</span>
      <h1 class="font-headline text-3xl md:text-4xl lg:text-5xl font-extrabold text-white leading-tight tracking-tight mb-4">
        Solicitud de Financiamiento para Auto en Skokie, IL
      </h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">Todos los niveles de credito son bienvenidos. Primeros compradores, credito en reconstruccion, buen o regular credito. Llena el formulario y Jerry te contactara el mismo dia.</p>
      <p class="text-white/50 text-sm mt-3 max-w-xl mx-auto">No estas listo para la solicitud completa? <a href={`${base}/es/financiamiento`} class="text-orange hover:underline font-semibold">Precalifica primero</a> sin impacto a tu historial crediticio.</p>
    </div>
  </section>

  <!-- Main Form -->
  <section class="py-12 bg-surface">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">

      <!-- Buyer / Co-Buyer tabs -->
      <div class="flex border-b border-gray-300 mb-8">
        <button id="tab-buyer" class="app-tab app-tab--active px-6 py-3 font-bold text-sm" type="button">Titular</button>
        <button id="tab-cobuyer" class="app-tab px-6 py-3 font-bold text-sm" type="button">Co-Titular <span class="font-normal text-xs text-gray-400">(Opcional)</span></button>
      </div>

      <div class="bg-white border border-gray-200 rounded-xl px-5 py-4 mb-6 text-sm text-gray-600 flex flex-wrap items-center gap-x-6 gap-y-2">
        <span><span class="text-red-500 font-bold">*</span> Campo obligatorio</span>
        <span><span class="app-badge app-badge--req">Obligatorio</span> Seccion que debes completar</span>
        <span><span class="app-badge app-badge--opt">Opcional</span> Omite lo que no aplique</span>
      </div>

      <form id="apply-form" action="/api/credit-app" method="POST" class="space-y-8">
        <input type="hidden" name="_subject" value="Solicitud de Credito — Maxim Autos" />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

        <!-- ===== BUYER SECTION ===== -->
        <div id="section-buyer">

          <!-- Informacion Personal -->
          <div class="app-section">
            <h2 class="app-section-title">Informacion Personal <span class="app-badge app-badge--req">Obligatorio</span></h2>
            <div class="app-grid">
              <div>
                <label class="app-label">Nombre <span class="text-red-500">*</span></label>
                <input type="text" name="buyer_first_name" required class="app-input" placeholder="Tu nombre" />
              </div>
              <div>
                <label class="app-label">Apellido <span class="text-red-500">*</span></label>
                <input type="text" name="buyer_last_name" required class="app-input" placeholder="Tu apellido" />
              </div>
              <div>
                <label class="app-label">Correo Electronico <span class="text-red-500">*</span></label>
                <input type="email" name="buyer_email" required class="app-input" placeholder="tu@correo.com" />
              </div>
              <div>
                <label class="app-label">Telefono Celular <span class="text-red-500">*</span></label>
                <input type="tel" name="buyer_cell_phone" required class="app-input" placeholder="(555) 555-5555" />
              </div>
              <div>
                <label class="app-label">Telefono de Casa <span class="text-gray-400 font-normal text-xs">(Opcional)</span></label>
                <input type="tel" name="buyer_home_phone" class="app-input" placeholder="(555) 555-5555" />
              </div>
              <div>
                <label class="app-label">Fecha de Nacimiento <span class="text-red-500">*</span></label>
                <input type="date" name="buyer_dob" required class="app-input" />
              </div>
              <div class="col-span-2">
                <label class="app-label">Numero de Seguro Social <span class="text-red-500">*</span></label>
                <input type="text" id="buyer_ssn" name="buyer_ssn" required class="app-input" placeholder="XXX-XX-XXXX" maxlength="11" inputmode="numeric" autocomplete="off" />
                <p class="text-xs text-gray-400 mt-1">Requerido para procesar tu solicitud de credito. Enviado por conexion cifrada y nunca almacenado en nuestros servidores.</p>
              </div>
              <div>
                <label class="app-label">Numero de Licencia de Conducir <span class="text-gray-400 font-normal text-xs">(Opcional)</span></label>
                <input type="text" name="buyer_dl_number" class="app-input" placeholder="Numero de licencia" />
              </div>
              <div>
                <label class="app-label">Estado de la Licencia <span class="text-gray-400 font-normal text-xs">(Opcional)</span></label>
                <select name="buyer_dl_state" class="app-input">
                  <option value="">Estado</option>
                  {states.map(s => <option value={s}>{s}</option>)}
                </select>
              </div>
              <div>
                <label class="app-label">Fecha de Emision de Licencia <span class="text-gray-400 font-normal text-xs">(Opcional)</span></label>
                <input type="date" name="buyer_dl_issue" class="app-input" />
              </div>
              <div>
                <label class="app-label">Fecha de Vencimiento de Licencia <span class="text-gray-400 font-normal text-xs">(Opcional)</span></label>
                <input type="date" name="buyer_dl_expiry" class="app-input" />
              </div>
            </div>
          </div>

          <!-- Informacion de Residencia -->
          <div class="app-section">
            <h2 class="app-section-title">Informacion de Residencia <span class="app-badge app-badge--req">Obligatorio</span></h2>
            <div class="app-grid">
              <div class="col-span-2">
                <label class="app-label">Direccion <span class="text-red-500">*</span></label>
                <input type="text" name="buyer_address" required class="app-input" placeholder="123 Main St" />
              </div>
              <div>
                <label class="app-label">Ciudad <span class="text-red-500">*</span></label>
                <input type="text" name="buyer_city" required class="app-input" placeholder="Ciudad" />
              </div>
              <div>
                <label class="app-label">Estado <span class="text-red-500">*</span></label>
                <select name="buyer_state" required class="app-input">
                  <option value="">Estado</option>
                  {states.map(s => <option value={s}>{s}</option>)}
                </select>
              </div>
              <div>
                <label class="app-label">Codigo Postal <span class="text-red-500">*</span></label>
                <input type="text" name="buyer_zip" required class="app-input" placeholder="60077" maxlength="5" />
              </div>
              <div>
                <label class="app-label">Tipo de Vivienda <span class="text-red-500">*</span></label>
                <select name="buyer_housing_type" required class="app-input">
                  <option value="">Seleccionar</option>
                  <option value="Own">Propia</option>
                  <option value="Rent">Renta</option>
                  <option value="Live with Family">Vive con Familia</option>
                  <option value="Other">Otro</option>
                </select>
              </div>
              <div>
                <label class="app-label">Renta o Hipoteca Mensual <span class="text-red-500">*</span></label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 font-semibold">$</span>
                  <input type="number" name="buyer_monthly_housing" required class="app-input pl-7" placeholder="0" min="0" />
                </div>
              </div>
              <div>
                <label class="app-label">Anos en Esta Direccion <span class="text-red-500">*</span></label>
                <select id="buyer_years_address" name="buyer_years_address" required class="app-input">
                  <option value="">Anos</option>
                  {Array.from({length: 31}, (_, i) => <option value={i}>{i}</option>)}
                </select>
              </div>
              <div>
                <label class="app-label">Meses en Esta Direccion <span class="text-gray-400 font-normal text-xs">(Opcional)</span></label>
                <select id="buyer_months_address" name="buyer_months_address" class="app-input">
                  <option value="">Meses</option>
                  {Array.from({length: 12}, (_, i) => <option value={i}>{i}</option>)}
                </select>
              </div>
            </div>

            <!-- Direccion Anterior (mostrada si < 2 anos en la actual) -->
            <div id="buyer-prev-address-section" class="hidden mt-6 pt-6 border-t border-gray-100">
              <h3 class="text-sm font-bold text-navy mb-4">Direccion Anterior <span class="app-badge app-badge--req">Obligatorio</span> <span class="text-gray-400 font-normal">(menos de 2 anos en la direccion actual)</span></h3>
              <div class="app-grid">
                <div class="col-span-2">
                  <label class="app-label">Direccion Anterior</label>
                  <input type="text" name="buyer_prev_address" class="app-input" placeholder="123 Calle Anterior" />
                </div>
                <div>
                  <label class="app-label">Ciudad</label>
                  <input type="text" name="buyer_prev_city" class="app-input" placeholder="Ciudad" />
                </div>
                <div>
                  <label class="app-label">Estado</label>
                  <select name="buyer_prev_state" class="app-input">
                    <option value="">Estado</option>
                    {states.map(s => <option value={s}>{s}</option>)}
                  </select>
                </div>
                <div>
                  <label class="app-label">Codigo Postal</label>
                  <input type="text" name="buyer_prev_zip" class="app-input" placeholder="60077" maxlength="5" />
                </div>
                <div>
                  <label class="app-label">Anos Ahi</label>
                  <select name="buyer_prev_years_address" class="app-input">
                    <option value="">Anos</option>
                    {Array.from({length: 31}, (_, i) => <option value={i}>{i}</option>)}
                  </select>
                </div>
              </div>
            </div>
          </div>

          <!-- Informacion de Empleo -->
          <div class="app-section">
            <h2 class="app-section-title">Informacion de Empleo <span class="app-badge app-badge--opt">Opcional</span></h2>
            <div class="app-grid">
              <div class="col-span-2">
                <label class="app-label">Situacion Laboral</label>
                <select name="buyer_employment_status" class="app-input">
                  <option value="">Seleccionar</option>
                  <option value="Employed">Empleado</option>
                  <option value="Self-Employed">Trabajador Independiente</option>
                  <option value="Retired">Jubilado</option>
                  <option value="Student">Estudiante</option>
                  <option value="Other">Otro</option>
                </select>
              </div>
              <div>
                <label class="app-label">Nombre del Empleador</label>
                <input type="text" name="buyer_employer" class="app-input" placeholder="Nombre del empleador" />
              </div>
              <div>
                <label class="app-label">Puesto o Cargo</label>
                <input type="text" name="buyer_title" class="app-input" placeholder="Tu cargo" />
              </div>
              <div>
                <label class="app-label">Telefono del Empleador</label>
                <input type="tel" name="buyer_employer_phone" class="app-input" placeholder="(555) 555-5555" />
              </div>
              <div>
                <label class="app-label">Ingreso Mensual Bruto</label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 font-semibold">$</span>
                  <input type="number" name="buyer_monthly_income" class="app-input pl-7" placeholder="0" min="0" />
                </div>
              </div>
              <div>
                <label class="app-label">Anos en Este Trabajo</label>
                <select id="buyer_years_job" name="buyer_years_job" class="app-input">
                  <option value="">Anos</option>
                  {Array.from({length: 51}, (_, i) => <option value={i}>{i}</option>)}
                </select>
              </div>
              <div>
                <label class="app-label">Meses en Este Trabajo</label>
                <select id="buyer_months_job" name="buyer_months_job" class="app-input">
                  <option value="">Meses</option>
                  {Array.from({length: 12}, (_, i) => <option value={i}>{i}</option>)}
                </select>
              </div>
            </div>

            <!-- Empleador Anterior (mostrado si < 2 anos en el trabajo actual) -->
            <div id="buyer-prev-employer-section" class="hidden mt-6 pt-6 border-t border-gray-100">
              <h3 class="text-sm font-bold text-navy mb-4">Empleador Anterior <span class="text-gray-400 font-normal">(si tiene menos de 2 anos en el trabajo actual)</span></h3>
              <div class="app-grid">
                <div>
                  <label class="app-label">Nombre del Empleador Anterior</label>
                  <input type="text" name="buyer_prev_employer" class="app-input" placeholder="Nombre del empleador" />
                </div>
                <div>
                  <label class="app-label">Puesto o Cargo</label>
                  <input type="text" name="buyer_prev_title" class="app-input" placeholder="Tu cargo" />
                </div>
                <div>
                  <label class="app-label">Anos Ahi</label>
                  <select name="buyer_prev_years_job" class="app-input">
                    <option value="">Anos</option>
                    {Array.from({length: 51}, (_, i) => <option value={i}>{i}</option>)}
                  </select>
                </div>
                <div>
                  <label class="app-label">Meses Ahi</label>
                  <select name="buyer_prev_months_job" class="app-input">
                    <option value="">Meses</option>
                    {Array.from({length: 12}, (_, i) => <option value={i}>{i}</option>)}
                  </select>
                </div>
              </div>
            </div>
          </div>

        </div>

        <!-- ===== CO-BUYER SECTION (oculto por defecto) ===== -->
        <div id="section-cobuyer" class="hidden">

          <p class="text-sm text-gray-500 mb-6 -mt-2">Llena esta pestana solo si aplicas con un co-titular. Si no, todos estos campos son opcionales.</p>

          <!-- Informacion Personal del Co-Titular -->
          <div class="app-section">
            <h2 class="app-section-title">Informacion Personal del Co-Titular <span class="app-badge app-badge--opt">Opcional</span></h2>
            <div class="app-grid">
              <div>
                <label class="app-label">Nombre</label>
                <input type="text" name="cobuyer_first_name" class="app-input" placeholder="Tu nombre" />
              </div>
              <div>
                <label class="app-label">Apellido</label>
                <input type="text" name="cobuyer_last_name" class="app-input" placeholder="Tu apellido" />
              </div>
              <div>
                <label class="app-label">Correo Electronico</label>
                <input type="email" name="cobuyer_email" class="app-input" placeholder="tu@correo.com" />
              </div>
              <div>
                <label class="app-label">Telefono Celular</label>
                <input type="tel" name="cobuyer_cell_phone" class="app-input" placeholder="(555) 555-5555" />
              </div>
              <div>
                <label class="app-label">Fecha de Nacimiento</label>
                <input type="date" name="cobuyer_dob" class="app-input" />
              </div>
              <div>
                <label class="app-label">Numero de Seguro Social</label>
                <input type="text" id="cobuyer_ssn" name="cobuyer_ssn" class="app-input" placeholder="XXX-XX-XXXX" maxlength="11" inputmode="numeric" autocomplete="off" />
              </div>
              <div>
                <label class="app-label">Numero de Licencia de Conducir</label>
                <input type="text" name="cobuyer_dl_number" class="app-input" placeholder="Numero de licencia" />
              </div>
              <div>
                <label class="app-label">Estado de la Licencia</label>
                <select name="cobuyer_dl_state" class="app-input">
                  <option value="">Estado</option>
                  {states.map(s => <option value={s}>{s}</option>)}
                </select>
              </div>
            </div>
          </div>

          <!-- Residencia del Co-Titular -->
          <div class="app-section">
            <h2 class="app-section-title">Informacion de Residencia del Co-Titular <span class="app-badge app-badge--opt">Opcional</span></h2>
            <div class="app-grid">
              <div class="col-span-2">
                <label class="app-label">Direccion</label>
                <input type="text" name="cobuyer_address" class="app-input" placeholder="123 Main St" />
              </div>
              <div>
                <label class="app-label">Ciudad</label>
                <input type="text" name="cobuyer_city" class="app-input" placeholder="Ciudad" />
              </div>
              <div>
                <label class="app-label">Estado</label>
                <select name="cobuyer_state" class="app-input">
                  <option value="">Estado</option>
                  {states.map(s => <option value={s}>{s}</option>)}
                </select>
              </div>
              <div>
                <label class="app-label">Codigo Postal</label>
                <input type="text" name="cobuyer_zip" class="app-input" placeholder="60077" maxlength="5" />
              </div>
              <div>
                <label class="app-label">Tipo de Vivienda</label>
                <select name="cobuyer_housing_type" class="app-input">
                  <option value="">Seleccionar</option>
                  <option value="Own">Propia</option>
                  <option value="Rent">Renta</option>
                  <option value="Live with Family">Vive con Familia</option>
                  <option value="Other">Otro</option>
                </select>
              </div>
              <div>
                <label class="app-label">Renta o Hipoteca Mensual</label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 font-semibold">$</span>
                  <input type="number" name="cobuyer_monthly_housing" class="app-input pl-7" placeholder="0" min="0" />
                </div>
              </div>
            </div>
          </div>

          <!-- Empleo del Co-Titular -->
          <div class="app-section">
            <h2 class="app-section-title">Informacion de Empleo del Co-Titular <span class="app-badge app-badge--opt">Opcional</span></h2>
            <div class="app-grid">
              <div>
                <label class="app-label">Nombre del Empleador</label>
                <input type="text" name="cobuyer_employer" class="app-input" placeholder="Nombre del empleador" />
              </div>
              <div>
                <label class="app-label">Puesto o Cargo</label>
                <input type="text" name="cobuyer_title" class="app-input" placeholder="Tu cargo" />
              </div>
              <div>
                <label class="app-label">Telefono del Empleador</label>
                <input type="tel" name="cobuyer_employer_phone" class="app-input" placeholder="(555) 555-5555" />
              </div>
              <div>
                <label class="app-label">Ingreso Mensual Bruto</label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 font-semibold">$</span>
                  <input type="number" name="cobuyer_monthly_income" class="app-input pl-7" placeholder="0" min="0" />
                </div>
              </div>
              <div>
                <label class="app-label">Anos en Este Trabajo</label>
                <select name="cobuyer_years_job" class="app-input">
                  <option value="">Anos</option>
                  {Array.from({length: 51}, (_, i) => <option value={i}>{i}</option>)}
                </select>
              </div>
              <div>
                <label class="app-label">Meses en Este Trabajo</label>
                <select name="cobuyer_months_job" class="app-input">
                  <option value="">Meses</option>
                  {Array.from({length: 12}, (_, i) => <option value={i}>{i}</option>)}
                </select>
              </div>
            </div>
          </div>

        </div>

        <!-- ===== VEHICULO DE INTERES ===== -->
        <div class="app-section">
          <h2 class="app-section-title">Vehiculo de Interes <span class="app-badge app-badge--opt">Opcional</span></h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div>
              <label class="app-label">No. de Stock</label>
              <input type="text" name="vehicle_stock" class="app-input" placeholder="No. de Stock" />
            </div>
            <div>
              <label class="app-label">Ano</label>
              <input type="text" name="vehicle_year" class="app-input" placeholder="2021" maxlength="4" />
            </div>
            <div>
              <label class="app-label">Marca</label>
              <input type="text" name="vehicle_make" class="app-input" placeholder="Honda" />
            </div>
            <div>
              <label class="app-label">Modelo</label>
              <input type="text" name="vehicle_model" class="app-input" placeholder="Civic" />
            </div>
            <div>
              <label class="app-label">Precio del Vehiculo</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 font-semibold">$</span>
                <input type="number" name="vehicle_price" class="app-input pl-7" placeholder="0" min="0" />
              </div>
            </div>
            <div>
              <label class="app-label">Enganche</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 font-semibold">$</span>
                <input type="number" name="vehicle_down_payment" class="app-input pl-7" placeholder="0" min="0" />
              </div>
            </div>
            <div>
              <label class="app-label">Color Exterior</label>
              <input type="text" name="vehicle_ext_color" class="app-input" placeholder="Plata" />
            </div>
            <div>
              <label class="app-label">Color Interior</label>
              <input type="text" name="vehicle_int_color" class="app-input" placeholder="Negro" />
            </div>
          </div>
        </div>

        <!-- ===== VEHICULO DE INTERCAMBIO ===== -->
        <div class="app-section">
          <h2 class="app-section-title">Vehiculo para Intercambio <span class="app-badge app-badge--opt">Opcional</span></h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <div>
              <label class="app-label">Ano</label>
              <input type="text" name="trade_year" class="app-input" placeholder="2018" maxlength="4" />
            </div>
            <div>
              <label class="app-label">Marca</label>
              <input type="text" name="trade_make" class="app-input" placeholder="Toyota" />
            </div>
            <div>
              <label class="app-label">Modelo</label>
              <input type="text" name="trade_model" class="app-input" placeholder="Camry" />
            </div>
            <div>
              <label class="app-label">Kilometraje</label>
              <input type="number" name="trade_mileage" class="app-input" placeholder="85000" min="0" />
            </div>
            <div>
              <label class="app-label">VIN</label>
              <input type="text" name="trade_vin" class="app-input" placeholder="VIN de 17 caracteres" maxlength="17" />
            </div>
            <div>
              <label class="app-label">Saldo Pendiente</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 font-semibold">$</span>
                <input type="number" name="trade_payoff" class="app-input pl-7" placeholder="0" min="0" />
              </div>
            </div>
          </div>
        </div>

        <!-- ===== REFERENCIAS ===== -->
        <div class="app-section">
          <h2 class="app-section-title">Referencias Personales <span class="app-badge app-badge--opt">Opcional</span></h2>
          <p class="text-sm text-gray-500 mb-5">Algunos prestamistas piden referencias personales. Incluirlas puede acelerar tu aprobacion. Por favor lista personas que no vivan en tu hogar.</p>
          {[1, 2, 3].map(n => (
            <div class={`app-grid${n < 3 ? ' mb-5 pb-5 border-b border-gray-100' : ''}`}>
              <div>
                <label class="app-label">Referencia {n} — Nombre Completo</label>
                <input type="text" name={`ref${n}_name`} class="app-input" placeholder="Nombre completo" />
              </div>
              <div>
                <label class="app-label">Numero de Telefono</label>
                <input type="tel" name={`ref${n}_phone`} class="app-input" placeholder="(555) 555-5555" />
              </div>
              <div>
                <label class="app-label">Relacion</label>
                <select name={`ref${n}_relationship`} class="app-input">
                  <option value="">Seleccionar</option>
                  <option value="Family">Familiar</option>
                  <option value="Friend">Amigo/a</option>
                  <option value="Co-worker">Companero de trabajo</option>
                  <option value="Other">Otro</option>
                </select>
              </div>
            </div>
          ))}
        </div>

        <!-- ===== CONSENTIMIENTO ===== -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
          <p class="text-xs text-gray-500 leading-relaxed">
            Yo, el abajo firmante, con el proposito de obtener credito, certifico que la informacion proporcionada es correcta; autorizo a Maxim Autos y a las instituciones financieras a obtener informes de credito del consumidor (segun lo permitido por la Ley de Informes de Credito Justos) periodicamente y a verificar el historial de empleo; autorizo la verificacion de toda la informacion proporcionada; y entiendo que esta solicitud sera retenida independientemente de si es aprobada o no. Tambien autorizo la verificacion de mi identidad en las bases de datos OFAC aplicables.
          </p>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" name="privacy_consent" required value="yes" class="mt-0.5 w-4 h-4 accent-orange shrink-0" />
            <span class="text-sm text-gray-600">Al enviar esta solicitud, acepto la <a href={`${base}/privacy-policy`} class="text-orange hover:underline">Politica de Privacidad</a>. <span class="text-red-500">*</span></span>
          </label>
        </div>

        <!-- Enviar -->
        <div class="text-center">
          <p class="text-sm text-gray-500 mb-4">Al enviar esta solicitud, das tu consentimiento a que Maxim Autos te contacte por telefono, mensaje de texto o correo electronico. Tu informacion se maneja de acuerdo con nuestra <a href={`${base}/privacy-policy`} class="text-orange hover:underline">Politica de Privacidad</a>.</p>
          <button type="submit" id="apply-submit-btn"
            class="inline-flex items-center justify-center gap-2 bg-orange text-white px-12 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors shadow-lg shadow-orange/20">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">send</span>
            Enviar Solicitud
          </button>
          <p class="text-xs text-gray-400 mt-3">Un miembro del equipo te contactara el mismo dia durante el horario de atencion.</p>
        </div>

      </form>
    </div>
  </section>

  <!-- Barra de confianza -->
  <section class="py-10 bg-white border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
        {[
          { icon: 'groups', title: 'Todos los Creditos Bienvenidos', text: 'Buen credito, regular, reconstruyendo o primer comprador. Trabajamos con prestamistas para cada situacion.' },
          { icon: 'lock', title: 'Envio Seguro', text: 'Tu informacion se envia de forma segura y solo se comparte con prestamistas para procesar tu solicitud.' },
          { icon: 'schedule', title: 'Respuesta el Mismo Dia', text: 'Jerry revisa cada solicitud y te da seguimiento el mismo dia de atencion.' },
        ].map(item => (
          <div class="flex flex-col items-center gap-3">
            <span class="material-symbols-outlined text-3xl text-orange" style="font-variation-settings: 'FILL' 1;">{item.icon}</span>
            <h3 class="font-headline font-bold text-navy">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" lang="es" />
</Layout>

