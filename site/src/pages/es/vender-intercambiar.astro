---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = 'Vende Tu Auto o Intercambialo | Maxim Autos Skokie, IL';
const description = 'Vende tu auto o intercambialo en Maxim Autos en Skokie, IL. Envia el VIN a Jerry para una oferta rapida. Sin compromiso, respuesta rapida.';
---

<Layout
  title={title}
  description={description}
  lang="es"
  hreflangEn="https://www.maximautos.com/sell-trade"
  hreflangEs="https://www.maximautos.com/es/vender-intercambiar"
>
  <Header slot="header" lang="es" />

  <!-- Hero -->
  <section class="bg-navy py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Vender o Intercambiar</span>
      <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
        Vende Tu Auto o Intercambialo
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
        Envia el VIN de tu auto a Jerry para una oferta rapida. Sin compromiso.
      </p>
      <div class="mt-10">
        <div class="hidden sm:inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg shadow-lg shadow-orange/20">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947
        </div>
      </div>
    </div>
  </section>

  <!-- Como Funciona -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold">Como Funciona</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { step: '1', title: 'Envia Tu Informacion', text: 'Llena el formulario o envia un mensaje a Jerry con los detalles de tu vehiculo. El VIN nos da la oferta mas rapida.', icon: 'send' },
          { step: '2', title: 'Recibe una Oferta', text: 'Jerry revisa la informacion de tu vehiculo y responde con una oferta justa y sin compromiso. Generalmente el mismo dia.', icon: 'price_check' },
          { step: '3', title: 'Vende o Intercambia', text: 'Acepta la oferta y recibe tu pago, o aplica el valor hacia tu proximo vehiculo en Maxim Autos.', icon: 'handshake' },
        ].map(item => (
          <div class="text-center">
            <div class="w-14 h-14 bg-orange rounded-2xl flex items-center justify-center mx-auto mb-5">
              <span class="text-white font-headline font-extrabold text-xl">{item.step}</span>
            </div>
            <h3 class="font-headline text-lg font-bold mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Formulario -->
  <section class="py-20 bg-surface">
    <div class="max-w-2xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-4">Obtener Tu Oferta</h2>
        <p class="text-gray-600 text-lg">Llena el formulario o envia un mensaje a Jerry directamente para la respuesta mas rapida.</p>
      </div>

      <form id="sell-trade-form" action="https://formspree.io/f/xwvapwod" method="POST" class="space-y-6 bg-white p-8 rounded-2xl border border-gray-200">
        <input type="hidden" name="_subject" value="Consulta Vender/Intercambiar — Maxim Autos (ES)" />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="sell-name" class="block text-sm font-medium text-gray-700 mb-2">Nombre</label>
            <input
              type="text"
              id="sell-name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label for="sell-phone" class="block text-sm font-medium text-gray-700 mb-2">Telefono</label>
            <input
              type="tel"
              id="sell-phone"
              name="phone"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="(555) 555-5555"
            />
          </div>
        </div>
        <div>
          <label for="sell-ymm" class="block text-sm font-medium text-gray-700 mb-2">Ano / Marca / Modelo</label>
          <input
            type="text"
            id="sell-ymm"
            name="year_make_model"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
            placeholder="p.ej. 2019 Honda Civic"
          />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="sell-mileage" class="block text-sm font-medium text-gray-700 mb-2">Millaje</label>
            <input
              type="text"
              id="sell-mileage"
              name="mileage"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="p.ej. 45,000"
            />
          </div>
          <div>
            <label for="sell-vin" class="block text-sm font-medium text-gray-700 mb-2">VIN <span class="text-gray-400">(opcional)</span></label>
            <input
              type="text"
              id="sell-vin"
              name="vin"
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="17 caracteres"
            />
          </div>
        </div>
        <div>
          <label for="sell-condition" class="block text-sm font-medium text-gray-700 mb-2">Condicion</label>
          <select
            id="sell-condition"
            name="condition"
            required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
          >
            <option value="" disabled selected>Selecciona la condicion</option>
            <option value="excellent">Excelente, sin problemas</option>
            <option value="good">Bueno, desgaste cosmetico menor</option>
            <option value="fair">Regular, necesita algunos trabajos</option>
            <option value="poor">Malo, problemas significativos</option>
          </select>
        </div>
        <button
          type="submit"
          class="w-full bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors flex items-center justify-center gap-2"
        >
          <span class="material-symbols-outlined">send</span>
          Enviar para Oferta
        </button>
        <p class="text-xs text-gray-400 text-center">Sin compromiso. Jerry respondera con una oferta, generalmente el mismo dia.</p>
      </form>
    </div>
  </section>

  <Footer slot="footer" lang="es" />
</Layout>

<script is:inline>
(function () {
  var form = document.getElementById('sell-trade-form');
  if (!form) return;
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    if (form.action.includes('YOUR_')) {
      var name = (document.getElementById('sell-name').value || '').trim();
      var ymm = (document.getElementById('sell-ymm').value || '').trim();
      var mileage = (document.getElementById('sell-mileage').value || '').trim();
      var body = encodeURIComponent('Hola Jerry, soy ' + (name || 'un visitante') + ' y quiero vender/intercambiar mi ' + ymm + ' con ' + mileage + ' millas.');
      window.location.href = 'sms:8475108947&body=' + body;
      return;
    }
    var btn = form.querySelector('button[type="submit"]');
    var origText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="material-symbols-outlined">sync</span> Enviando...';
    fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    }).then(function (res) {
      if (res.ok) {
        form.innerHTML = '<div class="text-center py-12"><span class="material-symbols-outlined text-5xl text-green-500 mb-4 block" style="font-variation-settings:\'FILL\' 1;">check_circle</span><h3 class="font-headline text-xl font-bold text-navy mb-2">Solicitud Enviada!</h3><p class="text-gray-600 mb-4">Jerry revisara la informacion de tu vehiculo y te respondera con una oferta, generalmente el mismo dia.</p></div>';
      } else {
        btn.disabled = false;
        btn.innerHTML = origText;
        alert('Algo salio mal. Por favor envia un mensaje de texto a Jerry directamente al (847) 510-8947.');
      }
    }).catch(function () {
      btn.disabled = false;
      btn.innerHTML = origText;
      alert('Algo salio mal. Por favor envia un mensaje de texto a Jerry directamente al (847) 510-8947.');
    });
  });
})();
</script>
