---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import VehicleCard from '../../components/VehicleCard.astro';
import vehicles from '../../data/vehicles.json';
import reviews from '../../data/reviews.json';
import reviewsMeta from '../../data/reviews_meta.json';
import suburbs from '../../data/suburbs.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = 'Autos Usados en Skokie, IL | Maxim Autos';
const description = 'Maxim Autos: autos usados completamente inspeccionados de $5,000 a $15,000 en Skokie, IL. Placas el mismo dia. Sin tramites del DMV. Financiamiento para todos los niveles de credito. Resenas de 5 estrellas en Google.';
const featured = vehicles.filter(v => (v as any).status !== 'sold').slice(0, 6);
---

<Layout
  title={title}
  description={description}
  lang="es"
  hreflangEn="https://www.maximautos.com/"
  hreflangEs="https://www.maximautos.com/es/"
>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AutoDealer",
      "name": "Maxim Autos",
      "sameAs": [
        "https://www.google.com/maps/place/Maxim+Autos/@42.0464352,-87.7546134,17z/data=!3m1!4b1!4m6!3m5!1s0x880fcfcb0a430aed:0x4d36c77af06ce602!8m2!3d42.0464352!4d-87.7546134!16s%2Fg%2F11wmzx_p4t"
      ],
      "description": description,
      "url": "https://www.maximautos.com/es/",
      "telephone": "+1-847-510-8947",
      "email": "jfranco@maximautos.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Skokie",
        "addressRegion": "IL",
        "postalCode": "60077",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 42.0464352,
        "longitude": -87.7546134
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Thursday","Friday"], "opens": "15:00", "closes": "19:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "10:00", "closes": "15:00" }
      ],
      "priceRange": "$5,000 a $15,000",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": String(reviewsMeta.rating.toFixed(1)),
        "reviewCount": String(reviewsMeta.count),
        "bestRating": "5"
      }
    })} />
  </Fragment>

  <Header slot="header" lang="es" />

  <!-- Hero -->
  <section class="bg-navy overflow-hidden md:relative md:min-h-[448px] lg:min-h-[512px] md:flex md:items-center">
    <div class="relative w-full max-h-44 overflow-hidden md:max-h-none md:overflow-visible md:absolute md:inset-0 md:z-0">
      <picture>
        <source srcset={`${base}/brand/hero-family.webp`} type="image/webp" />
        <img
          src={`${base}/brand/hero-family.jpg`}
          alt="Familia disfrutando su auto comprado en Maxim Autos en Skokie IL"
          width="1024"
          height="572"
          class="w-full h-auto md:h-full md:object-cover md:object-center"
          loading="eager"
        />
      </picture>
      <div class="md:hidden absolute inset-0 bg-gradient-to-b from-navy/20 to-navy"></div>
      <div class="hidden md:block absolute inset-0 bg-gradient-to-r from-navy/90 via-navy/70 to-navy/20"></div>

      <!-- Rotating review card - lower right, desktop only -->
      {reviews.length > 0 && (
      <div class="hidden md:block absolute bottom-6 right-6 lg:bottom-8 lg:right-8 w-72 lg:w-80 bg-white/95 backdrop-blur-sm rounded-xl shadow-2xl p-4">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-1.5">
            <svg id="hero-review-google-logo" width="16" height="16" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="display:none;">
              <path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9.1 3.2l6.8-6.8C35.6 2.4 30.1 0 24 0 14.7 0 6.7 5.5 2.7 13.5l7.9 6.1C12.5 13.1 17.8 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 3-2.3 5.5-4.8 7.2l7.5 5.8c4.4-4.1 7.1-10.1 7.1-17z"/>
              <path fill="#FBBC05" d="M10.6 28.6A14.5 14.5 0 0 1 9.5 24c0-1.6.3-3.2.8-4.6L2.4 13.2A23.9 23.9 0 0 0 0 24c0 3.9.9 7.5 2.5 10.8l8.1-6.2z"/>
              <path fill="#34A853" d="M24 48c6.1 0 11.2-2 14.9-5.4l-7.5-5.8c-2 1.4-4.6 2.2-7.4 2.2-6.2 0-11.5-4.2-13.4-9.8l-8 6.2C6.5 42.5 14.6 48 24 48z"/>
            </svg>
            <span id="hero-review-source" class="text-gray-500 text-xs font-semibold"></span>
          </div>
          <div id="hero-review-stars" class="flex gap-0.5"></div>
        </div>
        <blockquote id="hero-review-text" class="text-gray-800 text-sm leading-relaxed mb-2" style="transition: opacity 0.3s ease; min-height: 64px;"></blockquote>
        <p id="hero-review-name" class="font-bold text-gray-700 text-xs mb-3" style="transition: opacity 0.3s ease;"></p>
        <div class="flex items-center justify-center gap-1.5">
          {reviews.map((_, i) => (
            <button
              class="hero-review-dot rounded-full border-0 cursor-pointer bg-gray-300"
              style="width:6px;height:6px;transition:all 0.3s ease;"
              data-index={String(i)}
              aria-label={'Mostrar resena ' + (i + 1)}
            ></button>
          ))}
        </div>
      </div>
      )}
    </div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-8 pt-4 pb-8 md:py-10">
      <div class="max-w-xl">
        <a href="https://www.google.com/search?q=Maxim+Autos+Skokie+IL+reviews" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white rounded-full px-4 py-2 mb-6 hover:bg-white/20 transition-colors">
          <span class="material-symbols-outlined text-orange text-base" style="font-variation-settings: 'FILL' 1;">star</span>
          <span class="font-bold text-sm">{reviewsMeta.rating.toFixed(1)} Estrellas en Google</span>
          <span class="text-white/60 text-xs">· {reviewsMeta.count} Resenas</span>
        </a>
        <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-4">
          Autos Usados <br/>en Skokie, IL
        </h1>
        <p class="font-headline text-lg md:text-2xl lg:text-3xl font-bold text-white mb-3">Autos Usados en los que Puedes Confiar.</p>
        <p class="text-lg md:text-xl text-white/80 mb-7 leading-relaxed">
          De $5K a $15K, seleccionados personalmente por el dueno. Lleva tu auto el mismo dia.
        </p>
        <div class="flex flex-wrap gap-2 mb-8">
          {[
            { label: 'Menos de $10K', href: `${base}/es/inventario?price=under10k` },
            { label: 'SUVs', href: `${base}/es/inventario?body=SUV` },
            { label: 'Sedanes', href: `${base}/es/inventario?body=Sedan` },
            { label: 'Ver Todo', href: `${base}/es/inventario` },
          ].map(chip => (
            <a href={chip.href}
               class="bg-white/15 backdrop-blur-sm border border-white/25 text-white text-sm font-semibold px-4 py-2 rounded-full hover:bg-white/30 transition-all">
              {chip.label}
            </a>
          ))}
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={`${base}/es/inventario`}
             class="inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors shadow-lg">
            Ver Inventario <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <div id="hero-reviews-data" data-reviews={JSON.stringify(reviews)} hidden aria-hidden="true"></div>

  <script is:inline>
    const heroReviews = JSON.parse(document.getElementById('hero-reviews-data').dataset.reviews);
    const textEl = document.getElementById('hero-review-text');
    const nameEl = document.getElementById('hero-review-name');
    const sourceEl = document.getElementById('hero-review-source');
    const googleLogo = document.getElementById('hero-review-google-logo');
    const starsEl = document.getElementById('hero-review-stars');
    const dots = Array.from(document.querySelectorAll('.hero-review-dot'));
    let current = 0;
    let timer;

    // La marca de Google se muestra solo en resenas cuyo origen es Google.
    function renderAttribution(review) {
      const isGoogle = review.source === 'Google';
      googleLogo.style.display = isGoogle ? '' : 'none';
      sourceEl.textContent = isGoogle ? 'Resena de Google' : 'Resena de ' + review.source;
      starsEl.textContent = '★'.repeat(review.rating);
      starsEl.className = 'flex gap-0.5 text-orange text-sm leading-none';
      starsEl.setAttribute('aria-label', review.rating + ' estrellas');
    }

    function showReview(i, animate) {
      if (animate) {
        textEl.style.opacity = '0';
        nameEl.style.opacity = '0';
      }
      setTimeout(() => {
        textEl.textContent = '"' + heroReviews[i].text + '"';
        nameEl.textContent = heroReviews[i].name;
        renderAttribution(heroReviews[i]);
        textEl.style.opacity = '1';
        nameEl.style.opacity = '1';
      }, animate ? 300 : 0);
      dots.forEach((d, j) => {
        d.style.width  = j === i ? '20px' : '6px';
        d.style.height = '6px';
        d.style.background = j === i ? '#E85D26' : '#D1D5DB';
      });
      current = i;
    }

    function startTimer() {
      timer = setInterval(() => showReview((current + 1) % heroReviews.length, true), 6000);
    }

    dots.forEach((d, i) => {
      d.addEventListener('click', () => {
        clearInterval(timer);
        showReview(i, true);
        startTimer();
      });
    });

    if (heroReviews.length && textEl) {
      showReview(0, false);
      startTimer();
    }
  </script>

  <!-- Vehiculos Destacados -->
  <section class="py-10 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex justify-between items-center mb-6">
        <div>
          <span class="text-orange font-bold uppercase tracking-widest text-sm mb-1 block">Inventario Actual</span>
          <h2 class="font-headline text-2xl md:text-3xl font-extrabold">Seleccionados a Mano. Cada Uno.</h2>
          <p class="text-gray-500 text-sm mt-1">No vendemos 200 autos. Vendemos los correctos.</p>
        </div>
        <a href={`${base}/es/inventario`} class="flex items-center gap-1 text-navy font-bold hover:text-orange transition-colors text-sm">
          Ver Todo <span class="material-symbols-outlined text-lg">arrow_forward</span>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featured.map(v => (
          <VehicleCard
            lang="es"
            slug={v.slug}
            year={v.year}
            make={v.make}
            model={v.model}
            trim={v.trim}
            price={v.price}
            mileage={v.mileage}
            drivetrain={v.drivetrain}
            engine={v.engine}
            bodyStyle={v.bodyStyle}
            photoPath={v.photoPath}
            photoPrefix={v.photoPrefix}
            inspected={v.inspected}
            primaryPhotoUrl={v.primaryPhotoUrl}
            photos={v.photos}
            dealRating={(v as any).dealRating}
            priceSavings={(v as any).priceSavings}
          />
        ))}
      </div>
      <p class="text-xs text-gray-400 mt-4">* Pago estimado con 10% de enganche, 9.9% APR, plazo de 60 meses. Solo para fines ilustrativos. Los términos reales varían según el crédito.</p>
      <div class="text-center mt-10 md:hidden">
        <a href={`${base}/es/inventario`} class="inline-flex items-center gap-2 bg-navy text-white px-8 py-4 rounded-xl font-bold hover:bg-navy-light transition-colors">
          Ver Todo el Inventario <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
      <!-- Entrega nacional -->
      <div class="mt-8 flex items-center justify-center gap-3 bg-navy/5 border border-navy/10 rounded-xl px-6 py-4">
        <span class="material-symbols-outlined text-2xl text-navy shrink-0" style="font-variation-settings:'FILL' 1;">local_shipping</span>
        <p class="text-sm text-gray-700">
          <span class="font-bold text-navy">Prefiero comprar desde casa?</span> Completa toda la compra en linea, local o a nivel nacional. Recoge en Skokie o pide entrega a domicilio.
          <a href={`${base}/es/compra-en-linea`} class="text-orange font-bold hover:underline ml-1">Como funciona →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Tres Pilares -->
  <section class="py-10 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="flex items-start gap-4 p-4 md:p-6 rounded-xl border border-gray-100 hover:border-orange/20 hover:shadow-md transition-all">
          <div class="w-12 h-12 bg-navy/5 rounded-xl flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-2xl text-navy" style="font-variation-settings: 'FILL' 1;">gpp_good</span>
          </div>
          <div class="min-w-0">
            <h3 class="font-headline text-base font-bold mb-1">Inspeccionado y Documentado</h3>
            <p class="text-gray-500 text-sm">Reporte de inspeccion independiente incluido · CARFAX gratis · Proteccion de tren motriz de Illinois en autos que califican</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 md:p-6 rounded-xl border border-gray-100 hover:border-orange/20 hover:shadow-md transition-all">
          <div class="w-12 h-12 bg-navy/5 rounded-xl flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-2xl text-navy" style="font-variation-settings: 'FILL' 1;">directions_car</span>
          </div>
          <div class="min-w-0">
            <h3 class="font-headline text-base font-bold mb-1">Placas el Mismo Dia</h3>
            <p class="text-gray-500 text-sm">Placas de metal en el momento. Sin tramites del DMV. Maneja a casa hoy.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 md:p-6 rounded-xl border border-gray-100 hover:border-orange/20 hover:shadow-md transition-all">
          <div class="w-12 h-12 bg-navy/5 rounded-xl flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-2xl text-navy" style="font-variation-settings: 'FILL' 1;">sell</span>
          </div>
          <div class="min-w-0">
            <h3 class="font-headline text-base font-bold mb-1">Nunca Cobramos Cargos de Dealer</h3>
            <p class="text-gray-500 text-sm">Sin cargos ocultos · Precios claros · Financiamiento para todos los niveles de credito</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Compramos Tu Auto -->
  <section class="py-10 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="bg-navy rounded-2xl p-8 md:p-10 flex flex-col md:flex-row items-center gap-6 md:gap-10">
        <div class="w-16 h-16 bg-orange/20 rounded-2xl flex items-center justify-center shrink-0">
          <span class="material-symbols-outlined text-4xl text-orange" style="font-variation-settings: 'FILL' 1;">monetization_on</span>
        </div>
        <div class="flex-1 text-center md:text-left">
          <h2 class="font-headline text-2xl md:text-3xl font-extrabold text-white mb-2">Vendes Tu Auto? Te Compramos Directamente.</h2>
          <p class="text-gray-300 text-base">Recibe una oferta rapida y justa. Sin juegos de concesionario, sin ofertas bajas. Manda una foto a Jerry con tu precio.</p>
        </div>
        <div class="hidden sm:inline-flex shrink-0 items-center gap-2 bg-white/10 border border-white/20 text-white px-8 py-4 rounded-xl font-bold text-lg whitespace-nowrap">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947
        </div>
      </div>
    </div>
  </section>

  <!-- Resenas -->
  <section class="py-12 bg-navy text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <div class="flex justify-center items-center gap-1 mb-4">
          {[1,2,3,4,5].map(() => (
            <span class="material-symbols-outlined text-orange text-2xl" style="font-variation-settings: 'FILL' 1;">star</span>
          ))}
        </div>
        <h2 class="font-headline text-3xl md:text-5xl font-extrabold mb-3">{reviewsMeta.rating.toFixed(1)} Estrellas en Google</h2>
        <p class="text-gray-400 text-lg">{reviewsMeta.count}+ resenas de vecinos del North Shore</p>
      </div>
      {reviews.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {reviews.map(review => (
          <div class="bg-white/5 p-8 rounded-xl border border-white/10">
            <div class="flex items-center gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <span class="material-symbols-outlined text-orange text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
              ))}
            </div>
            <p class="text-lg italic mb-6 leading-relaxed text-gray-300">"{review.text}"</p>
            <div class="flex items-center justify-between">
              <span class="font-bold text-orange">{review.name}</span>
              <span class="text-xs text-gray-500">{review.source}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={`${base}/testimonials`} class="inline-flex items-center gap-2 text-orange font-bold hover:underline">
          Leer Todas las Resenas <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
      )}
    </div>
  </section>

  <!-- Servicio en el North Shore -->
  <section class="py-10 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="flex-1">
          <h2 class="font-headline text-2xl md:text-3xl font-extrabold mb-3">Servicio en el North Shore de Chicago</h2>
          <p class="text-gray-600 mb-4">Ubicados en Skokie. Autos usados completamente inspeccionados de $5,000 a $15,000 con financiamiento para todos los niveles de credito.</p>
          <div class="flex flex-wrap gap-2 mb-5">
            {['Skokie', 'Evanston', 'Niles', 'Morton Grove', 'Lincolnwood', 'Des Plaines', 'Wilmette', 'Glenview', 'Chicago'].map(city => (
              <span class="px-3 py-1.5 bg-surface rounded-full text-sm font-medium text-gray-700 border border-gray-200">{city}</span>
            ))}
          </div>
          <a href="https://www.google.com/search?q=Maxim+Autos+9101+Terminal+Ave+Skokie+IL+60077+directions" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-navy text-white px-6 py-3 rounded-xl font-bold hover:bg-navy-light transition-colors">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">location_on</span>
            Como Llegar
          </a>
        </div>
        <div class="hidden md:block w-72 h-48 bg-surface rounded-2xl overflow-hidden border border-gray-200">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2970!2d-87.7546134!3d42.0464352!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x880fcfcb0a430aed%3A0x4d36c77af06ce602!2sMaxim%20Autos!5e0!3m2!1sen!2sus!4v1747612800000!5m2!1sen!2sus"
            width="100%" height="100%" style="border:0;" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            title="Ubicacion de Maxim Autos en Skokie IL"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-12 bg-navy">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-white mb-4">Listo para Encontrar Tu Proximo Auto?</h2>
      <p class="text-white/70 text-lg mb-8">Cada auto seleccionado e inspeccionado personalmente. Llama o manda un mensaje de texto a Jerry para una respuesta rapida.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <div class="hidden sm:inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947
        </div>
        <a href={`${base}/es/inventario`} class="inline-flex items-center justify-center gap-2 bg-white/10 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/20 transition-colors border border-white/20">
          Ver Inventario
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang="es" />
</Layout>
