---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { es } from '../../i18n/es';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const esBase = `${base}/es`;
const siteUrl = 'https://www.maximautos.com';
const t = es;

const successHtml = `<div class="text-center py-12"><span class="material-symbols-outlined text-5xl text-green-500 mb-4 block" style="font-variation-settings:'FILL' 1;">check_circle</span><h3 class="font-headline text-xl font-bold text-navy mb-2">${t.financing.successTitle}</h3><p class="text-gray-600 mb-4">${t.financing.successBody}</p><a href="sms:8475108947&body=Hola Jerry, acabo de enviar una pre-calificación de financiamiento en tu sitio web." class="inline-flex items-center gap-2 bg-orange text-white px-6 py-3 rounded-xl font-bold hover:bg-orange-dark transition-colors"><span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">sms</span>${t.financing.successTextCta}</a></div>`;
---

<Layout
  title={t.financing.seoTitle}
  description={t.financing.seoDescription}
  lang="es"
  alternateLang="en"
  alternateUrl={`${siteUrl}/financing`}
  canonicalUrl={`${siteUrl}/es/financing`}
>
  <Header slot="header" lang="es" t={t.nav} switcherHref={`${base}/financing`} />

  <!-- Hero -->
  <section class="bg-navy py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">{t.financing.heroEyebrow}</span>
      <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
        {t.financing.heroH1}
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">{t.financing.heroBody}</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${esBase}/apply`} class="inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors shadow-lg shadow-orange/20">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">payments</span>
          {t.financing.ctaFull}
        </a>
        <a href="#apply" class="inline-flex items-center justify-center gap-2 bg-white/10 border border-white/30 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/20 transition-colors">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">edit_note</span>
          {t.financing.ctaPreQual}
        </a>
      </div>
    </div>
  </section>

  <!-- Payment Calculator -->
  <section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">{t.financing.calcEyebrow}</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold">{t.financing.calcH2}</h2>
        <p class="text-gray-500 mt-2">{t.financing.calcSub}</p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <!-- Slider Calculator -->
        <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
          <div class="space-y-5">
            <div>
              <div class="flex justify-between items-center mb-2">
                <label class="text-sm font-semibold text-gray-700">{t.financing.vehiclePrice}</label>
                <span class="text-sm font-bold text-navy" id="calc-price-display">$12,000</span>
              </div>
              <input type="range" id="calc-price-slider" min="3000" max="20000" step="500" value="12000"
                class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-orange" />
              <div class="flex justify-between text-xs text-gray-400 mt-1"><span>$3,000</span><span>$20,000</span></div>
            </div>
            <div>
              <div class="flex justify-between items-center mb-2">
                <label class="text-sm font-semibold text-gray-700">{t.financing.downPayment}</label>
                <span class="text-sm font-bold text-navy" id="calc-down-display">$1,200</span>
              </div>
              <input type="range" id="calc-down-slider" min="0" max="6000" step="250" value="1200"
                class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-orange" />
              <div class="flex justify-between text-xs text-gray-400 mt-1"><span>$0</span><span id="calc-down-max-label">$6,000</span></div>
            </div>
            <div>
              <div class="flex justify-between items-center mb-2">
                <label class="text-sm font-semibold text-gray-700">{t.financing.interestRate}</label>
                <span class="text-sm font-bold text-navy" id="calc-apr-display">9.9%</span>
              </div>
              <input type="range" id="calc-apr-slider" min="3.9" max="24.9" step="0.5" value="9.9"
                class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-orange" />
              <div class="flex justify-between text-xs text-gray-400 mt-1"><span>3.9%</span><span>24.9%</span></div>
            </div>
            <div>
              <label class="text-sm font-semibold text-gray-700 block mb-2">{t.financing.loanTerm}</label>
              <div class="flex gap-2" id="calc-term-selector">
                <button data-term="36" class="calc-term-btn flex-1 py-2 rounded-lg text-sm font-bold border transition-all bg-white text-gray-600 border-gray-200 hover:border-navy">36mo</button>
                <button data-term="48" class="calc-term-btn flex-1 py-2 rounded-lg text-sm font-bold border transition-all bg-white text-gray-600 border-gray-200 hover:border-navy">48mo</button>
                <button data-term="60" class="calc-term-btn flex-1 py-2 rounded-lg text-sm font-bold border transition-all bg-navy text-white border-navy">60mo</button>
                <button data-term="72" class="calc-term-btn flex-1 py-2 rounded-lg text-sm font-bold border transition-all bg-white text-gray-600 border-gray-200 hover:border-navy">72mo</button>
              </div>
            </div>
          </div>
          <!-- Result -->
          <div class="mt-6 bg-navy rounded-2xl p-6 text-center">
            <p class="text-gray-400 text-sm mb-1">{t.financing.estimatedMonthly}</p>
            <p class="font-headline text-5xl font-extrabold text-white" id="calc-result">$228</p>
            <p class="text-gray-400 text-xs mt-2">{t.financing.calcDisclaimer}</p>
          </div>
          <a href={`${esBase}/apply`}
            class="mt-5 w-full flex items-center justify-center gap-2 bg-orange text-white py-3.5 rounded-xl font-bold text-sm hover:bg-orange-dark transition-colors">
            <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">payments</span>
            {t.financing.getPreApproved}
          </a>
          <p class="text-xs text-gray-400 text-center mt-2">{t.financing.softPull}</p>
        </div>

        <!-- Why Finance -->
        <div class="space-y-5">
          <h3 class="font-headline text-2xl font-extrabold text-navy">{t.financing.whyH3}</h3>
          {t.financing.whyItems.map(item => (
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 bg-orange/10 rounded-xl flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-xl text-orange" style="font-variation-settings:'FILL' 1;">{item.icon}</span>
              </div>
              <div>
                <p class="font-bold text-navy text-sm">{item.title}</p>
                <p class="text-gray-500 text-sm leading-relaxed">{item.text}</p>
              </div>
            </div>
          ))}
          <div class="pt-2">
            <div class="hidden sm:inline-flex items-center gap-2 bg-navy text-white px-6 py-3 rounded-xl font-bold text-sm">
              <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1;">phone</span>
              (847) 510-8947
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Points -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {t.financing.keyPoints.map(item => (
          <div class="text-center p-8 rounded-xl border border-gray-100 hover:border-orange/20 hover:shadow-md transition-all">
            <div class="w-14 h-14 bg-navy/5 rounded-2xl flex items-center justify-center mx-auto mb-5">
              <span class="material-symbols-outlined text-3xl text-navy" style="font-variation-settings: 'FILL' 1;">{item.icon}</span>
            </div>
            <h3 class="font-headline text-lg font-bold mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-surface">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">{t.financing.howEyebrow}</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold">{t.financing.howH2}</h2>
      </div>
      <div class="space-y-8">
        {t.financing.steps.map(item => (
          <div class="flex gap-6 items-start bg-white p-8 rounded-xl border border-gray-100">
            <div class="w-14 h-14 bg-orange rounded-2xl flex items-center justify-center shrink-0">
              <span class="text-white font-headline font-extrabold text-xl">{item.step}</span>
            </div>
            <div>
              <h3 class="font-headline text-xl font-bold mb-2">{item.title}</h3>
              <p class="text-gray-600 leading-relaxed">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pre-Qualification Form -->
  <section id="apply" class="py-20 bg-white">
    <div class="max-w-2xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">{t.financing.formEyebrow}</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold mb-4">{t.financing.formH2}</h2>
        <p class="text-gray-600 text-lg">{t.financing.formSub}</p>
      </div>

      <form id="financing-form"
        action="https://formspree.io/f/xpqkwodb"
        method="POST"
        class="space-y-6 bg-surface p-8 rounded-2xl border border-gray-200"
        data-success-html={successHtml}>
        <input type="hidden" name="_subject" value="Pre-Calificación de Financiamiento — Maxim Autos" />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <div>
          <label for="fin-name" class="block text-sm font-medium text-gray-700 mb-2">{t.financing.fullName}</label>
          <input type="text" id="fin-name" name="name" required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
            placeholder={t.financing.namePlaceholder} />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="fin-email" class="block text-sm font-medium text-gray-700 mb-2">{t.financing.email}</label>
            <input type="email" id="fin-email" name="email" required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="tu@correo.com" />
          </div>
          <div>
            <label for="fin-phone" class="block text-sm font-medium text-gray-700 mb-2">{t.financing.phone}</label>
            <input type="tel" id="fin-phone" name="phone" required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900"
              placeholder="(555) 555-5555" />
          </div>
        </div>
        <div>
          <label for="fin-budget" class="block text-sm font-medium text-gray-700 mb-2">{t.financing.monthlyBudget}</label>
          <select id="fin-budget" name="monthly_budget" required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900">
            <option value="" disabled selected>{t.financing.budgetSelect}</option>
            {t.financing.budgetOptions.map(o => <option value={o.value}>{o.label}</option>)}
          </select>
        </div>
        <div>
          <label for="fin-credit" class="block text-sm font-medium text-gray-700 mb-2">{t.financing.creditSituation}</label>
          <select id="fin-credit" name="credit_situation" required
            class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 transition-colors text-gray-900">
            <option value="" disabled selected>{t.financing.creditSelect}</option>
            {t.financing.creditOptions.map(o => <option value={o.value}>{o.label}</option>)}
          </select>
        </div>
        <button type="submit"
          class="w-full bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors flex items-center justify-center gap-2">
          <span class="material-symbols-outlined">check_circle</span>
          {t.financing.submitBtn}
        </button>
        <p class="text-xs text-gray-400 text-center">{t.financing.formDisclaimer}</p>
      </form>
    </div>
  </section>

  <!-- Talk First CTA -->
  <section class="py-16 bg-orange">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-white mb-4">{t.financing.talkH2}</h2>
      <p class="text-white/90 text-lg mb-8">{t.financing.talkBody}</p>
      <div class="hidden sm:inline-flex items-center justify-center gap-2 bg-white text-navy px-8 py-4 rounded-xl font-bold text-lg">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">phone</span>
        (847) 510-8947
      </div>
    </div>
  </section>

  <Footer slot="footer" lang="es" t={t.footer} />
</Layout>

<script is:inline>
(function () {
  var priceSlider = document.getElementById('calc-price-slider');
  var downSlider  = document.getElementById('calc-down-slider');
  var aprSlider   = document.getElementById('calc-apr-slider');
  var termSel     = document.getElementById('calc-term-selector');
  var priceDisp   = document.getElementById('calc-price-display');
  var downDisp    = document.getElementById('calc-down-display');
  var aprDisp     = document.getElementById('calc-apr-display');
  var downMaxLbl  = document.getElementById('calc-down-max-label');
  var result      = document.getElementById('calc-result');
  var activeTerm  = 60;

  function fmt(n) { return '$' + Math.round(n).toLocaleString(); }

  function calcPayment() {
    var price = parseFloat(priceSlider.value) || 0;
    var down  = parseFloat(downSlider.value)  || 0;
    var apr   = parseFloat(aprSlider.value)   || 0;
    var principal = Math.max(price - down, 0);
    if (!result) return;
    if (apr === 0) { result.textContent = fmt(principal / activeTerm); return; }
    var r = apr / 100 / 12;
    var payment = principal * (r * Math.pow(1 + r, activeTerm)) / (Math.pow(1 + r, activeTerm) - 1);
    result.textContent = isFinite(payment) ? fmt(payment) : '$0';
  }

  priceSlider.addEventListener('input', function () {
    var price = parseFloat(priceSlider.value);
    priceDisp.textContent = fmt(price);
    var newMax = Math.round(price * 0.5);
    downSlider.max = newMax;
    if (parseFloat(downSlider.value) > newMax) downSlider.value = newMax;
    downDisp.textContent = fmt(downSlider.value);
    downMaxLbl.textContent = fmt(newMax);
    calcPayment();
  });
  downSlider.addEventListener('input', function () { downDisp.textContent = fmt(downSlider.value); calcPayment(); });
  aprSlider.addEventListener('input', function () { aprDisp.textContent = parseFloat(aprSlider.value).toFixed(1) + '%'; calcPayment(); });
  if (termSel) {
    termSel.addEventListener('click', function (e) {
      var btn = e.target.closest('.calc-term-btn'); if (!btn) return;
      activeTerm = parseInt(btn.dataset.term);
      termSel.querySelectorAll('.calc-term-btn').forEach(function (b) {
        var a = b.dataset.term == activeTerm;
        b.classList.toggle('bg-navy', a); b.classList.toggle('text-white', a); b.classList.toggle('border-navy', a);
        b.classList.toggle('bg-white', !a); b.classList.toggle('text-gray-600', !a); b.classList.toggle('border-gray-200', !a);
      });
      calcPayment();
    });
  }
  calcPayment();
})();
</script>

<script is:inline>
(function () {
  var form = document.getElementById('financing-form');
  if (!form) return;
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var btn = form.querySelector('button[type="submit"]');
    var origText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="material-symbols-outlined">sync</span> Enviando...';
    fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    }).then(function (res) {
      if (res.ok) {
        form.innerHTML = form.dataset.successHtml;
      } else {
        btn.disabled = false;
        btn.innerHTML = origText;
        alert('Algo salió mal. Por favor escríbele a Jerry al (847) 510-8947.');
      }
    }).catch(function () {
      btn.disabled = false;
      btn.innerHTML = origText;
      alert('Algo salió mal. Por favor escríbele a Jerry al (847) 510-8947.');
    });
  });
})();
</script>
