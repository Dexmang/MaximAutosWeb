---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VehicleCard from '../components/VehicleCard.astro';
import vehicles from '../data/vehicles.json';
import reviewsMeta from '../data/reviews_meta.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const SUV_BODY_STYLES = ['SUV', 'Crossover', 'Crossover SUV'];

const live = vehicles.filter(v => (v as any).status !== 'sold');
const matches = live.filter(v =>
  SUV_BODY_STYLES.some(s => v.bodyStyle?.toLowerCase() === s.toLowerCase())
);

const canonicalUrl = 'https://www.maximautos.com/used-suvs-skokie-il';
const title = 'Used SUVs for Sale in Skokie, IL | Under $15,000 | Maxim Autos';
const description = 'Used SUVs for sale near Skokie, IL at Maxim Autos. $5,000 to $15,000. Every SUV fully inspected with a free CARFAX report. Same day metal plates. Financing for all credit levels.';

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Used SUVs for Sale in Skokie, IL",
  "itemListElement": matches.map((v, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Car",
      "name": `${v.year} ${v.make} ${v.model} ${v.trim}`,
      "brand": { "@type": "Brand", "name": v.make },
      "url": `https://www.maximautos.com/vehicle/${v.slug}`,
      "offers": {
        "@type": "Offer",
        "price": v.price,
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock"
      }
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.maximautos.com" },
    { "@type": "ListItem", "position": 2, "name": "Inventory", "item": "https://www.maximautos.com/inventory" },
    { "@type": "ListItem", "position": 3, "name": "Used SUVs", "item": canonicalUrl }
  ]
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "AutoDealer",
  "name": "Maxim Autos",
  "url": "https://www.maximautos.com",
  "telephone": "+1-847-510-8947",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "9101 Terminal Ave",
    "addressLocality": "Skokie",
    "addressRegion": "IL",
    "postalCode": "60077",
    "addressCountry": "US"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 42.0464352, "longitude": -87.7546134 },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": String(reviewsMeta.rating.toFixed(1)),
    "reviewCount": String(reviewsMeta.count),
    "bestRating": "5"
  }
};

const faqs = [
  {
    q: 'Does Maxim Autos sell used SUVs near Skokie?',
    a: 'Yes. Maxim Autos in Skokie regularly carries used SUVs and crossovers priced from $5,000 to $15,000. Every SUV on the lot is independently inspected and includes a free CARFAX report. Text Jerry at (847) 510-8947 for current availability.'
  },
  {
    q: 'What SUV brands does Maxim Autos typically carry?',
    a: 'Inventory rotates weekly. Past inventory has included Toyota RAV4, Honda CR-V, Hyundai Tucson, Ford Escape, Chevrolet Equinox, and Nissan Rogue, all priced in the $5,000 to $15,000 range. Every vehicle is owner-selected at auction for reliability and value.'
  },
  {
    q: 'Is financing available on used SUVs at Maxim Autos?',
    a: 'Yes. Financing is available for all credit levels on every vehicle at Maxim Autos, including used SUVs. Multiple lenders are available and a soft-pull pre-qualification can be done before you visit. Text Jerry at (847) 510-8947 to discuss options.'
  },
  {
    q: 'Can I drive a used SUV home the same day I buy it?',
    a: 'Yes. Maxim Autos is a licensed Illinois CVR (Computer Vehicle Registration) dealer. We issue real metal Illinois license plates at the dealership on the day of purchase. No temporary tags, no DMV trip.'
  },
  {
    q: 'Are there hidden fees on used SUVs at Maxim Autos?',
    a: 'No. The price listed is the price you pay plus standard Illinois tax, title, and license fees. There are no dealer documentation fees or hidden charges.'
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <Header slot="header" />

  <section class="bg-navy py-14 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <nav class="text-sm text-gray-400 mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 flex-wrap">
          <li><a href={`${base}/`} class="hover:text-white transition-colors">Home</a></li>
          <li class="text-gray-600">/</li>
          <li><a href={`${base}/inventory`} class="hover:text-white transition-colors">Inventory</a></li>
          <li class="text-gray-600">/</li>
          <li class="text-gray-300">Used SUVs</li>
        </ol>
      </nav>

      <!-- QuickAnswer block — designed for AI engine extraction -->
      <div class="bg-white/10 border border-white/20 rounded-xl px-6 py-5 mb-10 max-w-2xl">
        <p class="text-white/60 text-xs font-bold uppercase tracking-widest mb-2">Quick Answer</p>
        <p class="text-white text-base leading-relaxed">
          Maxim Autos sells used SUVs in Skokie, IL priced from $5,000 to $15,000. Every SUV is fully inspected, includes a free CARFAX report, and comes with same day Illinois metal plates. Located at 9101 Terminal Ave, Skokie, IL 60077. Call or text (847) 510-8947.
        </p>
      </div>

      <div class="text-center">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Used SUVs</span>
        <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-5">
          Used SUVs for Sale<br/>Near Skokie, IL
        </h1>
        <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
          Reliable used SUVs under $15,000 on Chicago's North Shore. Every vehicle inspected, free CARFAX, and metal Illinois plates the same day.
        </p>
      </div>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
        <div>
          <h2 class="font-headline text-2xl md:text-3xl font-extrabold text-navy">
            {matches.length === 0 ? 'SUV Inventory Rotates Weekly' : `${matches.length} Used SUV${matches.length !== 1 ? 's' : ''} Available`}
          </h2>
          <p class="text-gray-600 mt-1 text-sm">All inspected. No dealer fees. Free CARFAX.</p>
        </div>
        <a href={`${base}/inventory`} class="inline-flex items-center gap-2 text-orange font-semibold hover:underline text-sm">
          Full inventory <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
      </div>

      {matches.length === 0 ? (
        <div class="bg-surface border border-gray-200 rounded-xl p-8 text-center">
          <p class="text-gray-700">We rotate inventory weekly. Check back soon or text Jerry at <a href="sms:8475108947" class="text-orange font-bold">(847) 510-8947</a> to ask about incoming SUV inventory.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {matches.map(v => (
            <VehicleCard
              slug={v.slug}
              year={v.year}
              make={v.make}
              model={v.model}
              trim={v.trim}
              price={v.price}
              mileage={v.mileage}
              drivetrain={v.drivetrain}
              engine={v.engine}
              bodyStyle={v.bodyStyle}
              photoPath={v.photoPath}
              photoPrefix={v.photoPrefix}
              inspected={v.inspected}
              primaryPhotoUrl={v.primaryPhotoUrl}
              photos={v.photos}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="py-14 bg-surface">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <h2 class="font-headline text-2xl md:text-3xl font-extrabold text-navy mb-6">Why SUV Buyers on Chicago's North Shore Shop Maxim Autos</h2>
      <p class="text-gray-700 leading-relaxed mb-5">
        SUVs are the most searched body style in the $5,000 to $15,000 segment on Chicago's North Shore. Buyers in Skokie, Evanston, Niles, Morton Grove, and surrounding communities look for models like the Toyota RAV4, Honda CR-V, Hyundai Tucson, Ford Escape, Chevrolet Equinox, and Nissan Rogue. These models combine all-weather capability, cargo space, and long-term reliability at a price that makes sense for families and commuters.
      </p>
      <p class="text-gray-700 leading-relaxed mb-5">
        Every SUV at Maxim Autos goes through an independent mechanical inspection before it goes on the lot. The inspection report covers engine, drivetrain, brakes, suspension, tires, electrical systems, and interior and exterior condition. That report is included with your purchase at no extra cost. A free CARFAX vehicle history report is also included with every vehicle. Every qualifying used car is backed by Illinois' 15 day / 500 mile statutory powertrain protection. Extended coverage is available as an option at signing, ask Jerry for pricing when you visit.
      </p>
      <p class="text-gray-700 leading-relaxed mb-5">
        Maxim Autos is a licensed Illinois CVR dealer at 9101 Terminal Ave in Skokie. Every Illinois buyer drives home with real metal plates the same day. No DMV trip. No temporary tags. Financing is available for all credit levels, including first-time buyers and buyers rebuilding credit.
      </p>
      <p class="text-gray-700 leading-relaxed">
        SUV inventory rotates weekly. If the model or year you want is not on the lot today, text Jerry at (847) 510-8947 with the make, model, mileage range, and budget. Jerry sources at auction every week and will reach out when something fits.
      </p>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="text-orange font-bold uppercase tracking-widest text-sm mb-2 block">FAQ</span>
        <h2 class="font-headline text-2xl md:text-3xl font-extrabold">Common Questions about Used SUVs Near Skokie</h2>
      </div>
      <div class="space-y-4">
        {faqs.map(item => (
          <div class="bg-surface rounded-xl border border-gray-100 p-6">
            <h3 class="font-headline font-bold text-navy mb-2">{item.q}</h3>
            <p class="text-gray-600 leading-relaxed text-sm">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-navy">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-white mb-4">Looking for a Specific SUV?</h2>
      <p class="text-white/70 text-lg mb-8">Tell Jerry the make, model, year, and budget. He sources at auction every week.</p>
      <div class="hidden sm:inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg">
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">phone</span>
        (847) 510-8947
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
