---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VehicleCard from '../components/VehicleCard.astro';
import vehicles from '../data/vehicles.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = 'Used Cars for Sale in Skokie, IL';
const description = `Browse ${vehicles.length} fully inspected used cars for sale at Maxim Autos in Skokie, IL. Prices from $${Math.min(...vehicles.map(v => v.price)).toLocaleString()} to $${Math.max(...vehicles.map(v => v.price)).toLocaleString()}. Every vehicle includes an independent inspection report and same-day metal plates. Financing available for all credit levels.`;

const bodyStyles = [...new Set(vehicles.map(v => v.bodyStyle))].sort();
const drivetrains = [...new Set(vehicles.map(v => v.drivetrain).filter(Boolean))].sort();
---

<Layout title={title} description={description}>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://maximautos.com/" },
        { "@type": "ListItem", "position": 2, "name": "Inventory", "item": "https://maximautos.com/inventory" }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AutoDealer",
      "name": "Maxim Autos",
      "sameAs": [
        "https://www.google.com/maps/place/Maxim+Autos/@42.0464352,-87.7546134,17z/data=!3m1!4b1!4m6!3m5!1s0x880fcfcb0a430aed:0x4d36c77af06ce602!8m2!3d42.0464352!4d-87.7546134!16s%2Fg%2F11wmzx_p4t"
      ],
      "url": "https://maximautos.com/inventory",
      "telephone": "+1-847-510-8947",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Skokie",
        "addressRegion": "IL",
        "postalCode": "60077",
        "addressCountry": "US"
      },
      "makesOffer": vehicles.map(v => ({
        "@type": "Offer",
        "itemOffered": {
          "@type": "Car",
          "name": `${v.year} ${v.make} ${v.model} ${v.trim}`,
          "brand": { "@type": "Brand", "name": v.make },
          "model": v.model,
          "vehicleModelDate": String(v.year),
          "mileageFromOdometer": {
            "@type": "QuantitativeValue",
            "value": v.mileage,
            "unitCode": "SMI"
          },
          "color": v.exteriorColor,
          "vehicleInteriorColor": v.interiorColor,
          "vehicleEngine": { "@type": "EngineSpecification", "name": v.engine },
          "vehicleTransmission": v.transmission,
          "driveWheelConfiguration": v.drivetrain,
          "fuelType": v.fuelType,
          "bodyType": v.bodyStyle,
          "vehicleIdentificationNumber": v.vin !== "TBD" ? v.vin : undefined,
          "itemCondition": "https://schema.org/UsedCondition",
          "url": `https://maximautos.com/vehicle/${v.slug}`
        },
        "price": v.price,
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "seller": { "@type": "AutoDealer", "name": "Maxim Autos" }
      }))
    })} />
  </Fragment>

  <Header slot="header" />

  <!-- Compact Page Header + Filter Bar combined (keeps cars above fold) -->
  <section class="sticky top-[73px] z-40 bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-3">
      <!-- Compact header inline -->
      <div class="mb-3">
        <h1 class="font-headline text-xl font-extrabold text-navy leading-tight">Pre-Owned Cars in Skokie, IL</h1>
        <p class="text-xs text-gray-500">Every vehicle fully inspected · Free CARFAX included</p>
      </div>
      <div class="flex flex-col md:flex-row md:items-center gap-3 flex-wrap">
        <!-- Price Range -->
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Price</label>
          <div class="flex flex-wrap gap-2" id="filter-price">
            <button data-price="all" class="filter-btn filter-btn--active px-4 py-2 rounded-lg text-sm font-semibold transition-all">All</button>
            <button data-price="under10k" class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all">Under $10K</button>
            <button data-price="5000-8000" class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all">$5K&ndash;$8K</button>
            <button data-price="8000-12000" class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all">$8K&ndash;$12K</button>
            <button data-price="12000-15000" class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all">$12K&ndash;$15K</button>
          </div>
        </div>

        <!-- Body Style -->
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Body Style</label>
          <div class="flex flex-wrap gap-2" id="filter-body">
            <button data-body="all" class="filter-btn filter-btn--active px-4 py-2 rounded-lg text-sm font-semibold transition-all">All</button>
            {bodyStyles.map(style => (
              <button data-body={style} class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all">{style}</button>
            ))}
          </div>
        </div>

        <!-- Drivetrain -->
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Drive</label>
          <div class="flex flex-wrap gap-2" id="filter-drive">
            <button data-drive="all" class="filter-btn filter-btn--active px-4 py-2 rounded-lg text-sm font-semibold transition-all">All</button>
            {drivetrains.map(dt => (
              <button data-drive={dt} class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold transition-all">{dt}</button>
            ))}
          </div>
        </div>

        <!-- Sort -->
        <div class="flex flex-col gap-1.5 md:ml-auto">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Sort</label>
          <select id="filter-sort" class="px-4 py-2 rounded-lg text-sm font-semibold border border-gray-200 bg-white text-gray-700 focus:ring-2 focus:ring-orange/30 focus:border-orange cursor-pointer">
            <option value="price-asc">Price: Low to High</option>
            <option value="price-desc">Price: High to Low</option>
            <option value="year-desc">Newest First</option>
            <option value="mileage-asc">Mileage: Low to High</option>
          </select>
        </div>
      </div>
    </div>
  </section>

  <!-- Shipping callout -->
  <div class="bg-navy/5 border-b border-navy/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-3 flex items-center gap-3">
      <span class="material-symbols-outlined text-xl text-navy shrink-0" style="font-variation-settings:'FILL' 1;">local_shipping</span>
      <p class="text-sm text-gray-700">
        <span class="font-bold text-navy">Not local?</span> Any of these can be delivered to your door — anywhere in the U.S. Complete the purchase online, pick up or get it shipped.
        <a href={`${base}/ship`} class="text-orange font-bold hover:underline ml-1">How it works →</a>
      </p>
    </div>
  </div>

  <!-- Inventory Grid -->
  <section class="py-6 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Count + Active Filters -->
      <div class="flex items-center justify-between mb-8">
        <p class="text-gray-600 font-medium" id="vehicle-count">
          Showing <span class="text-navy font-bold" id="count-num">{vehicles.length}</span> vehicles
        </p>
        <button id="clear-filters" class="hidden text-sm text-orange font-semibold hover:underline">Clear Filters</button>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" id="vehicle-grid">
        {vehicles.map(v => (
          <div
            class="vehicle-item"
            data-price={v.price}
            data-body={v.bodyStyle}
            data-drive={v.drivetrain}
            data-year={v.year}
            data-mileage={v.mileage}
            data-slug={v.slug}
          >
            <VehicleCard
              slug={v.slug}
              year={v.year}
              make={v.make}
              model={v.model}
              trim={v.trim}
              price={v.price}
              mileage={v.mileage}
              drivetrain={v.drivetrain}
              engine={v.engine}
              bodyStyle={v.bodyStyle}
              photoPath={v.photoPath}
              photoPrefix={v.photoPrefix}
              inspected={v.inspected}
              primaryPhotoUrl={v.primaryPhotoUrl}
              photos={v.photos}
            />
          </div>
        ))}
      </div>

      <!-- Payment disclaimer -->
      <p class="text-xs text-gray-400 mt-4">* Est. payment based on 10% down, 9.9% APR, 60-month term. For illustrative purposes only. Actual terms vary by credit.</p>

      <!-- No Results -->
      <div id="no-results" class="hidden text-center py-20">
        <span class="material-symbols-outlined text-6xl text-gray-300 mb-4 block">search_off</span>
        <h3 class="font-headline text-xl font-bold text-gray-700 mb-2">No vehicles match your filters</h3>
        <p class="text-gray-500 mb-6">Try adjusting your price range or body style selection.</p>
        <button id="reset-from-empty" class="inline-flex items-center gap-2 bg-gray-200 text-gray-700 px-6 py-3 rounded-lg font-bold text-sm hover:bg-gray-300 transition-colors">
          <span class="material-symbols-outlined text-lg">filter_alt_off</span>
          Clear All Filters
        </button>
      </div>
    </div>
  </section>

  <!-- Financing Callout -->
  <section class="bg-white border-t border-gray-100 py-10">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="bg-navy rounded-2xl px-8 py-7 flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="font-headline text-xl font-extrabold text-white mb-1">Financing for All Credit Levels</h3>
          <p class="text-white/70 text-sm">Good credit, fair credit, rebuilding, or first-time buyer. Apply in minutes. No obligation.</p>
        </div>
        <a href={`${base}/apply`} class="shrink-0 inline-flex items-center justify-center gap-2 bg-orange text-white px-7 py-3.5 rounded-xl font-bold text-base hover:bg-orange-dark transition-colors whitespace-nowrap">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">payments</span>
          Apply for Financing
        </a>
      </div>
    </div>
  </section>

  <!-- Car Finder CTA -->
  <section class="py-16 bg-navy">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span class="text-orange font-bold uppercase tracking-widest text-sm mb-3 block">Hand-Picked Inventory</span>
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-white mb-4">Don't See What You're Looking For?</h2>
      <p class="text-white/70 text-lg mb-3">Jerry personally selects every pre-owned vehicle on this lot. We don't sell volume — we sell quality.</p>
      <p class="text-white/60 text-base mb-8">Text Jerry exactly what you want — make, model, budget, features. He sources vehicles weekly and will find it for you.</p>
      <!-- Mobile: clickable. Desktop: show phone number for reference -->
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="sms:8475108947&body=Hi Jerry, I'm looking for a specific vehicle. Can you help me find it?"
           class="sm:hidden inline-flex items-center justify-center gap-2 bg-orange text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-orange-dark transition-colors">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">sms</span>
          Text Jerry What You Want
        </a>
        <div class="hidden sm:inline-flex items-center justify-center gap-3 bg-white/10 border border-white/20 text-white px-8 py-4 rounded-xl font-bold text-lg">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">phone</span>
          (847) 510-8947 — Call or Text
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style is:inline>
  .filter-btn {
    background: #f8f9fa;
    color: #4b5563;
    border: 1px solid #e5e7eb;
  }
  .filter-btn:focus-visible {
    outline: 2px solid #f08010;
    outline-offset: 2px;
  }
  .filter-btn:hover {
    background: #edeeef;
    border-color: #d1d5db;
  }
  .filter-btn--active {
    background: #0a2540 !important;
    color: #fff !important;
    border-color: #0a2540 !important;
  }
</style>

<script is:inline>
(function () {
  const grid = document.getElementById('vehicle-grid');
  const cards = Array.from(grid.querySelectorAll('.vehicle-item'));
  const countEl = document.getElementById('count-num');
  const noResults = document.getElementById('no-results');
  const clearBtn = document.getElementById('clear-filters');
  const resetEmpty = document.getElementById('reset-from-empty');
  const sortSelect = document.getElementById('filter-sort');

  let activePrice = 'all';
  let activeBody = 'all';
  let activeDrive = 'all';

  function setActiveBtn(group, key, value) {
    group.querySelectorAll('.filter-btn').forEach(btn => {
      btn.classList.toggle('filter-btn--active', btn.dataset[key] === value);
    });
  }

  function priceMatches(price, filter) {
    if (filter === 'all') return true;
    if (filter === 'under10k') return price < 10000;
    const [min, max] = filter.split('-').map(Number);
    return price >= min && price <= max;
  }

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const price = parseInt(card.dataset.price, 10);
      const body = card.dataset.body;
      const drive = card.dataset.drive;
      const show = priceMatches(price, activePrice)
        && (activeBody === 'all' || body === activeBody)
        && (activeDrive === 'all' || drive === activeDrive);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    countEl.textContent = visible;
    noResults.classList.toggle('hidden', visible > 0);
    grid.classList.toggle('hidden', visible === 0);
    const hasFilters = activePrice !== 'all' || activeBody !== 'all' || activeDrive !== 'all';
    clearBtn.classList.toggle('hidden', !hasFilters);
  }

  function applySorting() {
    const sortVal = sortSelect.value;
    const sorted = [...cards].sort((a, b) => {
      switch (sortVal) {
        case 'price-asc':   return parseInt(a.dataset.price) - parseInt(b.dataset.price);
        case 'price-desc':  return parseInt(b.dataset.price) - parseInt(a.dataset.price);
        case 'year-desc':   return parseInt(b.dataset.year) - parseInt(a.dataset.year);
        case 'mileage-asc': return parseInt(a.dataset.mileage) - parseInt(b.dataset.mileage);
        default: return 0;
      }
    });
    sorted.forEach(card => grid.appendChild(card));
  }

  function resetFilters() {
    activePrice = 'all';
    activeBody = 'all';
    activeDrive = 'all';
    setActiveBtn(document.getElementById('filter-price'), 'price', 'all');
    setActiveBtn(document.getElementById('filter-body'), 'body', 'all');
    setActiveBtn(document.getElementById('filter-drive'), 'drive', 'all');
    applyFilters();
  }

  // Read URL params on load (from hero filter chips)
  function applyUrlParams() {
    const params = new URLSearchParams(window.location.search);
    const price = params.get('price');
    const body = params.get('body');
    const drive = params.get('drive');
    if (price) {
      activePrice = price;
      setActiveBtn(document.getElementById('filter-price'), 'price', price);
    }
    if (body) {
      activeBody = body;
      setActiveBtn(document.getElementById('filter-body'), 'body', body);
    }
    if (drive) {
      activeDrive = drive;
      setActiveBtn(document.getElementById('filter-drive'), 'drive', drive);
    }
  }

  document.getElementById('filter-price').addEventListener('click', function (e) {
    const btn = e.target.closest('.filter-btn');
    if (!btn) return;
    activePrice = btn.dataset.price;
    setActiveBtn(this, 'price', activePrice);
    applyFilters();
  });

  document.getElementById('filter-body').addEventListener('click', function (e) {
    const btn = e.target.closest('.filter-btn');
    if (!btn) return;
    activeBody = btn.dataset.body;
    setActiveBtn(this, 'body', activeBody);
    applyFilters();
  });

  document.getElementById('filter-drive').addEventListener('click', function (e) {
    const btn = e.target.closest('.filter-btn');
    if (!btn) return;
    activeDrive = btn.dataset.drive;
    setActiveBtn(this, 'drive', activeDrive);
    applyFilters();
  });

  sortSelect.addEventListener('change', function () {
    applyFilters();
    applySorting();
  });

  clearBtn.addEventListener('click', resetFilters);
  resetEmpty.addEventListener('click', resetFilters);

  applySorting();
  applyUrlParams();
  applyFilters();
})();
</script>
